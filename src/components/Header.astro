---
const navLinks = [
  { href: '/', label: 'Accueil', key: 'nav.home' },
  { href: '/devis', label: 'Obtenir un Devis', key: 'nav.devis' },
  { href: '/qui-sommes-nous', label: 'Qui sommes-nous', key: 'nav.about' },
  { href: '/contact', label: 'Nous Contacter', key: 'nav.contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="header" id="header">
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label="PR Logistics — Accueil">
      <img src="/assets/home/logo-navbar.jpg" alt="PR Logistics" />
    </a>

    <nav class="header__nav" id="nav" aria-label="Navigation principale">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`header__link ${currentPath === link.href ? 'header__link--actif' : ''}`}
          data-i18n={link.key}
        >
          {link.label}
        </a>
      ))}

      <!-- Sélecteur de langue dropdown -->
      <div class="lang-dropdown" id="langDropdown">
        <button class="lang-trigger" id="langTrigger" aria-haspopup="listbox" aria-expanded="false" aria-label="Langue / Language">
          <img class="lang-trigger__flag" id="langFlag" src="/assets/home/france.png" alt="FR" width="20" height="20" />
          <span class="lang-trigger__code" id="langCode">FR</span>
          <svg class="lang-trigger__chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
        <ul class="lang-menu" id="langMenu" role="listbox">
          <li>
            <button class="lang-option" data-lang-btn="fr" onclick="window.I18N.set('fr')" role="option" aria-label="Français">
              <img class="lang-option__flag" src="/assets/home/france.png" alt="FR" width="22" height="22" />
              <span class="lang-option__name">Français</span>
            </button>
          </li>
          <li>
            <button class="lang-option" data-lang-btn="en" onclick="window.I18N.set('en')" role="option" aria-label="English">
              <img class="lang-option__flag" src="/assets/home/english.png" alt="EN" width="22" height="22" />
              <span class="lang-option__name">English</span>
            </button>
          </li>
        </ul>
      </div>
    </nav>

    <button class="header__burger" id="burger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0,0,0,0.06);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .header.scrolled {
    box-shadow: 0 2px 30px rgba(0,0,0,0.08);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 84px;
    gap: 2rem;
  }

  .header__logo {
    display: flex;
    align-items: stretch;
    align-self: stretch;
    margin-left: -2rem;
  }

  .header__logo img {
    height: 84px;
    width: auto;
    border-radius: 0;
    display: block;
    object-fit: contain;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .header__link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--gris-fonce);
    transition: color 0.2s;
    position: relative;
  }

  .header__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--rouge);
    transform: scaleX(0);
    transition: transform 0.3s ease;
    border-radius: 1px;
  }

  .header__link:hover::after,
  .header__link--actif::after {
    transform: scaleX(1);
  }

  .header__link--actif {
    color: var(--rouge);
  }

  /* ── Dropdown langue ─────────────────────────────── */
  .lang-dropdown {
    position: relative;
    margin-left: 0.5rem;
  }

  .lang-trigger {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.32rem 0.72rem 0.32rem 0.52rem;
    border: 1.5px solid rgba(0,0,0,0.13);
    border-radius: 2rem;
    background: rgba(0,0,0,0.02);
    cursor: pointer;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--gris-fonce);
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  .lang-trigger:hover {
    border-color: rgba(0,0,0,0.25);
    background: rgba(0,0,0,0.04);
  }

  .lang-dropdown.open .lang-trigger {
    border-color: var(--gris-fonce);
    box-shadow: 0 0 0 3px rgba(0,0,0,0.06);
  }

  .lang-trigger__flag {
    width: 20px;
    height: 20px;
    border-radius: 3px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .lang-trigger__code {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .lang-trigger__chevron {
    margin-left: 0.05rem;
    color: var(--gris-moyen);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .lang-dropdown.open .lang-trigger__chevron {
    transform: rotate(180deg);
  }

  /* Menu déroulant */
  .lang-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    list-style: none;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.09);
    border-radius: 0.9rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.06);
    min-width: 130px;
    padding: 0.35rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px) scale(0.97);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: 200;
  }

  .lang-dropdown.open .lang-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .lang-menu li {
    padding: 0;
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    padding: 0.55rem 0.75rem;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: 0.6rem;
    transition: background 0.15s;
    text-align: left;
  }

  .lang-option:hover {
    background: var(--gris-clair);
  }

  .lang-option.lang-active {
    background: rgba(227,6,19,0.07);
  }

  .lang-option__flag {
    width: 22px;
    height: 22px;
    border-radius: 3px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .lang-option__name {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--gris-fonce);
  }

  /* ── Burger mobile ─────────────────────────────────── */
  .header__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .header__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--gris-fonce);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  @media (max-width: 768px) {
    .header__nav {
      display: none;
      position: absolute;
      top: 72px;
      left: 0;
      right: 0;
      background: rgba(255,255,255,0.97);
      backdrop-filter: blur(20px);
      flex-direction: column;
      padding: 1.5rem 2rem;
      gap: 1.2rem;
      border-bottom: 1px solid rgba(0,0,0,0.06);
      box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    }

    .header__nav.open {
      display: flex;
    }

    .header__burger {
      display: flex;
    }

    .lang-dropdown {
      margin-left: 0;
    }

    .lang-menu {
      right: auto;
      left: 0;
    }
  }
</style>

<script>
  const header  = document.getElementById('header');
  const burger  = document.getElementById('burger');
  const nav     = document.getElementById('nav');
  const dropdown  = document.getElementById('langDropdown');
  const trigger   = document.getElementById('langTrigger');
  const menu      = document.getElementById('langMenu');

  // Effet scroll
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
  });

  // Menu burger
  burger?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(isOpen));
  });

  // Dropdown langue — ouverture / fermeture
  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = dropdown?.classList.toggle('open');
    trigger.setAttribute('aria-expanded', String(isOpen));
  });

  // Fermer si clic extérieur
  document.addEventListener('click', (e) => {
    if (!dropdown?.contains(e.target as Node)) {
      dropdown?.classList.remove('open');
      trigger?.setAttribute('aria-expanded', 'false');
    }
  });

  // Fermer sur Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      dropdown?.classList.remove('open');
      trigger?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
