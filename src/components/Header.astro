---
const navLinks = [
  { href: '/', label: 'Accueil', key: 'nav.home' },
  { href: '/devis', label: 'Obtenir un Devis', key: 'nav.devis' },
  { href: '/qui-sommes-nous', label: 'Qui sommes-nous', key: 'nav.about' },
  { href: '/contact', label: 'Nous Contacter', key: 'nav.contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="header" id="header">
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label="PR Logistics — Accueil">
      <img src="/assets/logo.jpeg" alt="PR Logistics" width="160" height="50" />
    </a>

    <nav class="header__nav" id="nav" aria-label="Navigation principale">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`header__link ${currentPath === link.href ? 'header__link--actif' : ''}`}
          data-i18n={link.key}
        >
          {link.label}
        </a>
      ))}

      <!-- Sélecteur de langue -->
      <div class="lang-switcher" role="group" aria-label="Language">
        <button
          class="lang-btn"
          data-lang-btn="fr"
          onclick="window.I18N.set('fr')"
          aria-label="Français"
        >FR</button>
        <span class="lang-sep" aria-hidden="true">|</span>
        <button
          class="lang-btn"
          data-lang-btn="en"
          onclick="window.I18N.set('en')"
          aria-label="English"
        >EN</button>
      </div>
    </nav>

    <button class="header__burger" id="burger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0,0,0,0.06);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .header.scrolled {
    box-shadow: 0 2px 30px rgba(0,0,0,0.08);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 84px;
    gap: 2rem;
  }

  .header__logo img {
    height: 64px;
    width: auto;
    border-radius: 0.4rem;
    object-fit: contain;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .header__link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--gris-fonce);
    transition: color 0.2s;
    position: relative;
  }

  .header__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--rouge);
    transform: scaleX(0);
    transition: transform 0.3s ease;
    border-radius: 1px;
  }

  .header__link:hover::after,
  .header__link--actif::after {
    transform: scaleX(1);
  }

  .header__link--actif {
    color: var(--rouge);
  }

  /* Sélecteur de langue */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0;
    margin-left: 0.5rem;
    border: 1.5px solid rgba(0,0,0,0.13);
    border-radius: 2rem;
    padding: 0.18rem 0.28rem;
    background: rgba(0,0,0,0.02);
  }

  .lang-btn {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.22rem 0.55rem;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--gris-moyen);
    border-radius: 1.5rem;
    transition: background 0.18s, color 0.18s;
    line-height: 1;
  }

  .lang-btn:hover {
    color: var(--gris-fonce);
  }

  .lang-btn.lang-active {
    background: var(--gris-fonce);
    color: #fff;
  }

  .lang-sep {
    font-size: 0.65rem;
    color: rgba(0,0,0,0.2);
    pointer-events: none;
    user-select: none;
  }

  .header__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .header__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--gris-fonce);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  @media (max-width: 768px) {
    .header__nav {
      display: none;
      position: absolute;
      top: 72px;
      left: 0;
      right: 0;
      background: rgba(255,255,255,0.97);
      backdrop-filter: blur(20px);
      flex-direction: column;
      padding: 1.5rem 2rem;
      gap: 1.2rem;
      border-bottom: 1px solid rgba(0,0,0,0.06);
      box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    }

    .header__nav.open {
      display: flex;
    }

    .header__burger {
      display: flex;
    }

    .lang-switcher {
      margin-left: 0;
    }
  }
</style>

<script>
  const header = document.getElementById('header');
  const burger = document.getElementById('burger');
  const nav    = document.getElementById('nav');

  // Effet scroll
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
  });

  // Menu burger
  burger?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(isOpen));
  });
</script>
