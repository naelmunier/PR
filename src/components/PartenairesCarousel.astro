---
const partenaires = [
  { nom: 'Groupe RDT',       logo: '/assets/partenaires/rdt.png',          bg: '#fff' },
  { nom: 'Hachette Livre',   logo: '/assets/partenaires/hachette.png',      bg: '#fff' },
  { nom: 'JAS',              logo: '/assets/partenaires/jas.svg',           bg: '#fff' },
  { nom: 'SEKO Logistics',   logo: '/assets/partenaires/seko.png',          bg: '#fff' },
  { nom: 'KN Logistics',     logo: '/assets/partenaires/kn-logistics.svg',  bg: 'transparent' },
  { nom: 'InterCargo',       logo: '/assets/partenaires/intercargo.svg',    bg: '#fff' },
  { nom: 'Pont Emballage',   logo: '/assets/partenaires/ponteurope.svg',    bg: '#fff' },
  { nom: 'Lagrange',         logo: '/assets/partenaires/lagrange.svg',      bg: '#fff' },
  { nom: 'Kuehne+Nagel',     logo: '/assets/partenaires/kuehne-nagel.png',  bg: '#fff' },
  { nom: 'Ziegler',          logo: '/assets/partenaires/ziegler.png',       bg: '#fff' },
  { nom: 'Transcausse',      logo: '/assets/partenaires/transcausse.svg',   bg: '#fff' },
  { nom: 'BBL Cargo',        logo: '/assets/partenaires/bbl.svg',           bg: 'transparent' },
  { nom: 'CEVA Logistics',   logo: '/assets/partenaires/ceva.svg',          bg: '#fff' },
  { nom: 'SDCorp',           logo: '/assets/partenaires/sdcorp.svg',        bg: 'transparent' },
  { nom: 'Derudder',         logo: '/assets/partenaires/derudder.svg',      bg: '#fff' },
  { nom: 'Erport',           logo: '/assets/partenaires/erport.svg',        bg: '#fff' },
];

// Dupliquer 3× pour une boucle parfaitement infinie
const items = [...partenaires, ...partenaires, ...partenaires];
---

<section class="carousel-section" aria-label="Nos clients partenaires">
  <div class="carousel-header">
    <h2 class="titre">Ils nous ont fait <span>confiance</span></h2>
  </div>

  <div class="carousel-wrapper">
    <div class="carousel-track" id="carouselTrack">
      {items.map((p) => (
        <div class="carousel-item" title={p.nom}>
          <div class="logo-wrapper" style={`background: ${p.bg};`}>
            <img
              src={p.logo}
              alt={`Logo ${p.nom}`}
              loading="lazy"
              width="160"
              height="60"
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .carousel-section {
    background: #f9f9f9;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    padding: 1.2rem 0;
    overflow: hidden;
  }

  .carousel-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .titre {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--gris-fonce);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .titre span {
    color: var(--rouge);
  }

  .carousel-wrapper {
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
  }

  .carousel-track {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    width: max-content;
    animation: defiler 50s linear infinite;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes defiler {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-100% / 3)); }
  }

  .carousel-item {
    flex-shrink: 0;
    cursor: default;
  }

  .logo-wrapper {
    width: 160px;
    height: 60px;
    border-radius: 0.75rem;
    border: 1px solid rgba(0,0,0,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }

  .carousel-item:hover .logo-wrapper {
    transform: scale(1.06) translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.1);
  }

  .logo-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 0;
    filter: grayscale(20%);
    transition: filter 0.3s ease;
  }

  .carousel-item:hover .logo-wrapper img {
    filter: grayscale(0%);
  }
</style>
