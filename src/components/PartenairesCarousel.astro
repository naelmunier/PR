---
const partenaires = [
  { nom: 'Groupe RDT', couleur: '#e55a00', initiales: 'RDT' },
  { nom: 'Hachette Livre', couleur: '#003087', initiales: 'HL' },
  { nom: 'JAS', couleur: '#0057b8', initiales: 'JAS' },
  { nom: 'SEKO', couleur: '#e30613', initiales: 'SEKO' },
  { nom: 'KN Logistics', couleur: '#e30613', initiales: 'KN' },
  { nom: 'InterCargo', couleur: '#e30613', initiales: 'iC' },
  { nom: 'Pont Emballage', couleur: '#1b2a4a', initiales: 'PE' },
  { nom: 'Lagrange', couleur: '#2c5f2e', initiales: 'LG' },
  { nom: 'Kuehne+Nagel', couleur: '#003082', initiales: 'K+N' },
  { nom: 'Ziegler', couleur: '#f5d800', textColor: '#222', initiales: 'ZGL' },
  { nom: 'Transcausse', couleur: '#1b2a4a', initiales: 'TC' },
  { nom: 'BBL Cargo', couleur: '#003087', initiales: 'BBL' },
  { nom: 'CEVA Logistics', couleur: '#e30613', initiales: 'CVA' },
  { nom: 'SDCorp', couleur: '#2c2c2c', initiales: 'SD' },
  { nom: 'Derudder', couleur: '#005baa', initiales: 'DRD' },
  { nom: 'Erport', couleur: '#1b3a6b', initiales: 'ERP' },
];

// Dupliquer pour boucle infinie
const doublon = [...partenaires, ...partenaires];
---

<section class="section section--gris partenaires">
  <div class="container reveal">
    <h2 class="titre-section" style="text-align:center;">Ils nous font <span>confiance</span></h2>
    <p class="sous-titre" style="text-align:center; margin: 1rem auto 0;">
      Des leaders mondiaux de la logistique et du transport nous font confiance au quotidien.
    </p>
  </div>

  <div class="carousel-wrapper" aria-label="Logos des partenaires">
    <div class="carousel-track" id="carouselTrack">
      {doublon.map((p) => (
        <div class="carousel-item" title={p.nom}>
          <div
            class="logo-badge"
            style={`background-color: ${p.couleur}; color: ${p.textColor || '#fff'};`}
          >
            {p.initiales}
          </div>
          <span class="logo-nom">{p.nom}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .partenaires {
    overflow: hidden;
    padding-bottom: 5rem;
  }

  .carousel-wrapper {
    margin-top: 3.5rem;
    overflow: hidden;
    position: relative;
    /* Dégradé sur les bords */
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .carousel-track {
    display: flex;
    gap: 2rem;
    width: max-content;
    animation: defiler 40s linear infinite;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes defiler {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .carousel-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
    cursor: default;
  }

  .logo-badge {
    width: 100px;
    height: 60px;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .carousel-item:hover .logo-badge {
    transform: scale(1.08) translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }

  .logo-nom {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--gris-moyen);
    text-align: center;
    max-width: 100px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
