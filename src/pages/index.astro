---
import MainLayout from '../layouts/MainLayout.astro';
import PartenairesCarousel from '../components/PartenairesCarousel.astro';

const prestations = [
  { icone: '/assets/nos prestations/depotage-empotage.png', titre: 'Dépotage & Empotage',      desc: 'Déchargement et chargement de conteneurs et de camions avec rigueur et réactivité.' },
  { icone: '/assets/nos prestations/cross-docking.png',     titre: 'Cross Docking',             desc: 'Transfert direct de marchandises sans stockage intermédiaire pour optimiser vos flux.' },
  { icone: '/assets/nos prestations/trier.png',             titre: 'Triage',                    desc: 'Tri rigoureux de vos marchandises selon vos critères de classification.' },
  { icone: '/assets/nos prestations/qualite.png',           titre: 'Contrôle Qualité',          desc: 'Contrôles quantitatifs et qualitatifs (aspect extérieur) à réception de vos marchandises.' },
  { icone: '/assets/nos prestations/palette.png',           titre: 'Palettisation',             desc: 'Mise sur palettes selon vos spécifications pour une manutention optimale.' },
  { icone: '/assets/nos prestations/film-plastique.png',    titre: 'Filmage & Cerclage',        desc: 'Sécurisation de vos palettes par filmage et cerclage pour un transport en toute sécurité.' },
  { icone: '/assets/nos prestations/preparation-de-commande.png', titre: 'Préparation de commande', desc: 'Picking précis et préparation de commandes adaptés à vos besoins logistiques.' },
  { icone: '/assets/nos prestations/reconditionnemenent.png', titre: 'Reconditionnement',       desc: 'Remise en état et reconditionnement de vos produits selon vos exigences.' },
  { icone: '/assets/nos prestations/transport-de-livraison.png', titre: 'Transport',            desc: 'Fret conventionnel et traction conteneur depuis et vers le port du Havre.' },
];

const equipements = [
  { ico: '🏭', val: '8 000 m²',  label: 'Entrepôt sous douane' },
  { ico: '📦', val: '8 000',      label: 'Palettes de stockage' },
  { ico: '🔧', val: '5',          label: 'Banderoleuses' },
  { ico: '⛓️',  val: '1',          label: 'Chaîne de tri' },
  { ico: '🏗️',  val: '10',         label: 'Chariots élévateurs 1,6T – 5T' },
  { ico: '📹', val: '22',         label: 'Caméras sécurité 24/7' },
  { ico: '💻', val: '1',          label: 'WMS gestion des stocks' },
  { ico: '🚛', val: '1',          label: 'Tracteur de parc' },
];
---

<MainLayout title="PR Logistics – Le Havre" rawTitle={true}>

  <!-- CARROUSEL PARTENAIRES — juste sous la navbar -->
  <PartenairesCarousel />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg-photo" aria-hidden="true"></div>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="container hero__inner animate-in">
      <p class="hero__eyebrow">Depuis 2017 · Le Havre</p>
      <h1 class="hero__titre">Votre partenaire <span>logistique</span><br />au cœur du port du Havre</h1>
      <p class="hero__desc">
        PR Logistics est un prestataire indépendant spécialisé dans la <span class="hero__desc-rouge">logistique portuaire</span> et le <span class="hero__desc-rouge">transport</span>.
        Entrepôt sous douane de <span class="hero__desc-rouge">8 000 m²</span>, solutions sur mesure, réactivité garantie.
      </p>
      <div class="hero__ctas">
        <a href="/contact" class="btn btn--rouge">Nous contacter</a>
        <a href="/devis" class="btn btn--outline hero__btn-outline">Demander un devis</a>
      </div>
    </div>
    <div class="hero__scroll" aria-hidden="true">
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- PRESTATIONS -->
  <section class="section section--gris prestations-section">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom: 3.5rem;">
        <p class="eyebrow-rouge">Ce que nous faisons</p>
        <h2 class="titre-section">Nos <span>prestations</span></h2>
        <p class="sous-titre" style="margin: 1rem auto 0;">
          Une gamme complète de services logistiques adaptée aux exigences du commerce international.
        </p>
      </div>
      <div class="prestations-grid">
        {prestations.map((p, i) => (
          <div class="prestation-carte reveal" style={`transition-delay: ${i * 0.08}s`}>
            <div class="prestation-carte__icone">
              <img src={p.icone} alt={p.titre} width="48" height="48" loading="lazy" />
            </div>
            <h3 class="prestation-carte__titre">{p.titre}</h3>
            <p class="prestation-carte__desc">{p.desc}</p>
            <div class="prestation-carte__accent"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NOS MOYENS -->
  <section class="section moyens">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:3.5rem;">
        <p class="eyebrow-rouge">Nos équipements</p>
        <h2 class="titre-section">Des moyens à la <span>hauteur</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0;">
          PR Logistics dispose d'un entrepôt de 8 000 m² sur un terrain de 18 500 m² entièrement clos,
          télésurveillé 24h/7j par la sécurité portuaire.
        </p>
      </div>

      <div class="c3d-wrapper reveal">
        <button class="c3d-arrow c3d-arrow--prev" id="c3dPrev" aria-label="Précédent">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="c3d-scene">
          <div class="c3d-ring" id="c3dRing">
            {equipements.map((e, i) => (
              <div class="c3d-card" data-index={i}>
                <span class="c3d-card__ico" aria-hidden="true">{e.ico}</span>
                <span class="c3d-card__val">{e.val}</span>
                <span class="c3d-card__label">{e.label}</span>
              </div>
            ))}
          </div>
        </div>
        <button class="c3d-arrow c3d-arrow--next" id="c3dNext" aria-label="Suivant">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

      <div class="c3d-dots" id="c3dDots"></div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section cta-section">
    <div class="cta-blob cta-blob--1" aria-hidden="true"></div>
    <div class="cta-blob cta-blob--2" aria-hidden="true"></div>
    <div class="container" style="position:relative;">
      <div class="cta-bloc reveal">
        <h2 class="titre-section">Prêt à optimiser votre <span>logistique</span> ?</h2>
        <p style="color:var(--gris-moyen); max-width:520px; margin: 1.2rem auto 0; font-size:1.1rem;">
          Contactez-nous dès aujourd'hui pour étudier ensemble vos besoins logistiques.
        </p>
        <div style="display:flex; gap:1rem; justify-content:center; margin-top:2.5rem; flex-wrap:wrap;">
          <a href="/contact" class="btn btn--rouge">Nous contacter</a>
          <a href="/devis" class="btn btn--outline">Demander un devis</a>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const ring    = document.getElementById('c3dRing') as HTMLElement;
    const dotsEl  = document.getElementById('c3dDots') as HTMLElement;
    const prevBtn = document.getElementById('c3dPrev') as HTMLButtonElement;
    const nextBtn = document.getElementById('c3dNext') as HTMLButtonElement;
    if (!ring) return;

    const cards      = Array.from(ring.querySelectorAll<HTMLElement>('.c3d-card'));
    const total      = cards.length;          // 8
    const angleStep  = 360 / total;           // 45°
    const radius     = 260;                   // px

    let current  = 0;
    let autoTimer: ReturnType<typeof setInterval>;

    /* — Position initiale de chaque carte dans l'anneau 3D — */
    cards.forEach((card, i) => {
      card.style.transform = `rotateY(${i * angleStep}deg) translateZ(${radius}px)`;
    });

    /* — Création des points de navigation — */
    cards.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.className = 'c3d-dot';
      dot.setAttribute('aria-label', `Élément ${i + 1}`);
      dot.addEventListener('click', () => { clearAuto(); goTo(i); startAuto(); });
      dotsEl.appendChild(dot);
    });

    /* — Rotation vers l'index donné — */
    function goTo(index: number) {
      current = ((index % total) + total) % total;
      ring.style.transform = `rotateY(${-current * angleStep}deg)`;

      cards.forEach((card, i) =>
        card.classList.toggle('c3d-card--active', i === current)
      );
      dotsEl.querySelectorAll<HTMLElement>('.c3d-dot').forEach((dot, i) =>
        dot.classList.toggle('c3d-dot--active', i === current)
      );
    }

    function startAuto() {
      autoTimer = setInterval(() => goTo(current + 1), 3400);
    }
    function clearAuto() { clearInterval(autoTimer); }

    prevBtn?.addEventListener('click', () => { clearAuto(); goTo(current - 1); startAuto(); });
    nextBtn?.addEventListener('click', () => { clearAuto(); goTo(current + 1); startAuto(); });

    /* Pause au survol */
    ring.addEventListener('mouseenter', clearAuto);
    ring.addEventListener('mouseleave', startAuto);

    goTo(0);
    startAuto();
  });
</script>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Photo de fond */
  .hero__bg-photo {
    position: absolute;
    inset: 0;
    background: url('/assets/home/port-havre-2.jpg') center center / cover no-repeat;
    pointer-events: none;
    animation: hero-dezoom 18s ease-out forwards;
  }

  @keyframes hero-dezoom {
    from {
      transform: scale(1.12);
      filter: blur(1.5px) brightness(0.62);
    }
    to {
      transform: scale(1.04);
      filter: blur(0.8px) brightness(0.62);
    }
  }

  /* Dégradé sombre en bas pour transition douce */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10,10,10,0.1) 0%,
      rgba(10,10,10,0.05) 50%,
      rgba(10,10,10,0.45) 100%
    );
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    text-align: center;
    max-width: 860px;
    margin: 0 auto;
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .hero__eyebrow {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    color: rgba(255,255,255,0.75);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.4rem;
    background: rgba(255,255,255,0.1);
    padding: 0.35rem 1rem;
    border-radius: 2rem;
    backdrop-filter: blur(6px);
  }

  .hero__titre {
    font-size: calc(var(--font-size-hero) * 0.9);
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.03em;
    line-height: 1.08;
    margin-bottom: 1.6rem;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }

  .hero__titre span {
    color: #ff4d57;
  }

  .hero__desc {
    font-size: 1.25rem;
    color: rgba(255,255,255,0.93);
    max-width: 660px;
    margin: 2.2rem auto 2.8rem;
    line-height: 1.75;
    text-shadow: 0 1px 8px rgba(0,0,0,0.25);
  }

  .hero__desc-rouge {
    color: #ff4d57;
    font-weight: 600;
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__btn-outline {
    border-color: rgba(255,255,255,0.7) !important;
    color: white !important;
  }

  .hero__btn-outline:hover {
    background: rgba(255,255,255,0.15) !important;
    border-color: white !important;
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    justify-content: center;
  }

  .hero__scroll-line {
    width: 2px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.6), transparent);
    border-radius: 2px;
    animation: scroll-down 1.5s ease-in-out infinite;
  }

  @keyframes scroll-down {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* QUI SOMMES-NOUS */
  .eyebrow-rouge {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--rouge);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.8rem;
  }

  .qsn__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .qsn__stats {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .qsn__stat-badge {
    background: linear-gradient(135deg, var(--rouge), #b00010);
    border-radius: var(--rayon-lg);
    padding: 2.5rem;
    text-align: center;
    color: white;
  }

  .qsn__annee {
    display: block;
    font-size: 4rem;
    font-weight: 800;
    line-height: 1;
  }

  .qsn__annee-label {
    font-size: 0.9rem;
    opacity: 0.8;
    margin-top: 0.3rem;
    display: block;
  }

  .qsn__info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .qsn__info-item {
    background: var(--gris-clair);
    border-radius: var(--rayon);
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
  }

  .qsn__info-val {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--gris-fonce);
    line-height: 1;
  }

  .qsn__info-val small {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--rouge);
    margin-left: 3px;
  }

  .qsn__info-label {
    font-size: 0.75rem;
    color: var(--gris-moyen);
    margin-top: 0.3rem;
  }

  /* PRESTATIONS */
  .prestations-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .prestation-carte {
    background: white;
    border-radius: var(--rayon-lg);
    overflow: hidden;
    padding: 2rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    transition:
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    position: relative;
    cursor: default;
  }

  .prestation-carte:hover {
    transform: translateY(-10px) scale(1.03);
    box-shadow: 0 20px 50px rgba(0,0,0,0.14);
  }

  .prestation-carte__icone {
    width: 48px;
    height: 48px;
    margin-bottom: 1rem;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .prestation-carte__icone img {
    width: 48px;
    height: 48px;
    object-fit: contain;
    border-radius: 0;
  }

  .prestation-carte:hover .prestation-carte__icone {
    transform: scale(1.2) translateY(-3px);
  }

  .prestation-carte__titre {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--gris-fonce);
    margin-bottom: 0.5rem;
    transition: color 0.3s;
  }

  .prestation-carte:hover .prestation-carte__titre {
    color: var(--rouge);
  }

  .prestation-carte__desc {
    font-size: 0.92rem;
    color: var(--gris-moyen);
    line-height: 1.65;
  }

  /* Barre rouge animée en bas de carte */
  .prestation-carte__accent {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    width: 0;
    background: var(--rouge);
    border-radius: 0 0 var(--rayon-lg) var(--rayon-lg);
    transition: width 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .prestation-carte:hover .prestation-carte__accent {
    width: 100%;
  }

  /* MOYENS — CARROUSEL 3D */
  .c3d-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .c3d-scene {
    flex: 1;
    height: 300px;
    perspective: 920px;
    perspective-origin: 50% 50%;
    overflow: visible;
  }

  .c3d-ring {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .c3d-card {
    position: absolute;
    width: 152px;
    height: 190px;
    left: 50%;
    top: 50%;
    margin-left: -76px;
    margin-top: -95px;
    background: white;
    border-radius: 1.4rem;
    box-shadow: 0 6px 28px rgba(0,0,0,0.09);
    border: 1.5px solid transparent;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 1.4rem 1rem;
    text-align: center;
    backface-visibility: hidden;
    transition: box-shadow 0.4s, border-color 0.4s;
    user-select: none;
  }

  .c3d-card--active {
    box-shadow: 0 16px 48px rgba(227,6,19,0.16), 0 4px 16px rgba(0,0,0,0.08);
    border-color: rgba(227,6,19,0.2);
  }

  .c3d-card__ico {
    font-size: 2.4rem;
    line-height: 1;
  }

  .c3d-card__val {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--rouge);
    line-height: 1;
  }

  .c3d-card__label {
    font-size: 0.78rem;
    color: var(--gris-moyen);
    line-height: 1.35;
  }

  .c3d-arrow {
    flex-shrink: 0;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1.5px solid #e0e0e0;
    background: white;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, box-shadow 0.2s, border-color 0.2s, color 0.2s;
    color: var(--gris-fonce);
    z-index: 10;
  }

  .c3d-arrow:hover {
    background: var(--rouge);
    border-color: var(--rouge);
    color: white;
    box-shadow: 0 4px 20px rgba(227,6,19,0.25);
  }

  .c3d-dots {
    display: flex;
    justify-content: center;
    gap: 0.55rem;
    margin-top: 2.8rem;
  }

  .c3d-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d0d0d0;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.3s, transform 0.3s;
  }

  .c3d-dot--active {
    background: var(--rouge);
    transform: scale(1.4);
  }

  /* CTA FINAL */
  .cta-section {
    position: relative;
    background: linear-gradient(135deg, #fff 0%, var(--gris-clair) 100%);
    overflow: hidden;
  }

  .cta-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(90px);
  }

  .cta-blob--1 {
    width: 520px;
    height: 520px;
    top: -160px;
    right: -120px;
    background: rgba(227, 6, 19, 0.12);
  }

  .cta-blob--2 {
    width: 420px;
    height: 420px;
    bottom: -130px;
    left: -100px;
    background: rgba(227, 6, 19, 0.10);
  }

  .cta-bloc {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .qsn__grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero__titre {
      font-size: 2.4rem;
    }

    .prestations-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .c3d-scene {
      height: 260px;
    }
  }

  @media (max-width: 600px) {
    .prestations-grid {
      grid-template-columns: 1fr;
    }

    .hero__titre {
      font-size: 2rem;
    }

    .c3d-scene {
      height: 240px;
    }
  }
</style>
