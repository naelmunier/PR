---
import MainLayout from '../layouts/MainLayout.astro';

const offres: {
  poste: string;
  type: string;
  lieu: string;
  desc: string;
  key: string;
}[] = [
  // {
  //   poste: 'Agent logistique',
  //   type: 'CDI',
  //   lieu: 'Le Havre (76)',
  //   desc: 'Prise en charge des opérations de dépotage, empotage et gestion des stocks en entrepôt.',
  //   key: 'agent-logistique',
  // },
];
---

<MainLayout
  title="Rejoignez-nous"
  description="Rejoignez l'équipe PR Logistics au Havre. Consultez nos offres d'emploi et déposez votre candidature spontanée."
  canonicalPath="/rejoignez-nous"
>

  <!-- ═══ HERO ═══════════════════════════════════════════════════ -->
  <section class="rec-hero">
    <div class="rec-blob rec-blob--1" aria-hidden="true"></div>
    <div class="rec-blob rec-blob--2" aria-hidden="true"></div>
    <div class="container rec-hero__inner animate-in">
      <p class="eyebrow-rouge wr" style="--d:0" data-i18n="recrutement.eyebrow">Carrières</p>
      <h1 class="rec-hero__titre">
        <span class="wr" style="--d:1" data-i18n="recrutement.hero.w1">Rejoignez</span>
        <span class="wr rec-hero__accent" style="--d:2" data-i18n="recrutement.hero.w2">l'équipe</span>
      </h1>
      <p class="rec-hero__sub wr" style="--d:3" data-i18n="recrutement.subtitle">
        Une équipe à taille humaine, au cœur du port du Havre.
      </p>
    </div>
  </section>

  <!-- ═══ CHOIX ════════════════════════════════════════════════ -->
  <section class="section modes-select" id="modesSelect">
    <div class="container">
      <div class="modes-intro reveal">
        <p class="eyebrow-rouge wr" style="--d:0.5" data-i18n="recrutement.choix.eyebrow">Par où commencer ?</p>
        <h2 class="titre-section" style="margin:0.4rem 0 0.8rem;">
          <span class="wr" style="--d:0.7" data-i18n-html="recrutement.choix.title">Que souhaitez-vous <em class="rec-hero__accent">faire ?</em></span>
        </h2>
      </div>

      <div class="modes-grid reveal">

        <!-- Offres d'emploi -->
        <div class="service-card" data-mode="offres" role="button" tabindex="0"
             aria-label="Consulter les offres d'emploi">
          <div class="service-card__icon-wrap">
            <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <rect x="2" y="7" width="20" height="14" rx="2"/>
              <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
            </svg>
          </div>
          <div class="service-card__body">
            <h3 class="service-card__title" data-i18n="recrutement.choix.offres.title">Offres d'emploi</h3>
            <p class="service-card__desc" data-i18n="recrutement.choix.offres.desc">Consultez nos postes actuellement ouverts chez PR Logistics.</p>
          </div>
          <div class="service-card__footer">
            <span class="service-card__cta">
              <span data-i18n="recrutement.choix.offres.cta">Voir les offres</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
          <div class="service-card__selected-badge" aria-hidden="true">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            <span data-i18n="recrutement.choix.selected">Sélectionné</span>
          </div>
        </div>

        <!-- Candidature spontanée -->
        <div class="service-card" data-mode="candidature" role="button" tabindex="0"
             aria-label="Déposer une candidature spontanée">
          <div class="service-card__icon-wrap">
            <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <line x1="19" y1="8" x2="19" y2="14"/>
              <line x1="22" y1="11" x2="16" y2="11"/>
            </svg>
          </div>
          <div class="service-card__body">
            <h3 class="service-card__title" data-i18n="recrutement.choix.cand.title">Candidature spontanée</h3>
            <p class="service-card__desc" data-i18n="recrutement.choix.cand.desc">Votre profil nous intéresse, avec ou sans offre en cours.</p>
          </div>
          <div class="service-card__footer">
            <span class="service-card__cta">
              <span data-i18n="recrutement.choix.cand.cta">Déposer ma candidature</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
          <div class="service-card__selected-badge" aria-hidden="true">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            <span data-i18n="recrutement.choix.selected">Sélectionné</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ OFFRES D'EMPLOI (hidden until card selected) ══════════ -->
  <section class="content-section" id="offresSection" style="display:none;">
    <div class="container">

      <!-- Topbar retour -->
      <div class="form-topbar">
        <button type="button" class="btn-retour" id="btnRetourOffres">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          <span data-i18n="recrutement.choix.retour">Changer de rubrique</span>
        </button>
        <div class="form-mode-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
          <span data-i18n="recrutement.choix.offres.title">Offres d'emploi</span>
        </div>
      </div>

      <!-- Contenu offres -->
      {offres.length > 0 ? (
        <div class="offres-grid" id="offresGrid">
          {offres.map((offre, i) => (
            <div class="offre-carte" style={`animation-delay:${i * 0.08}s`}>
              <div class="offre-carte__top">
                <h3 class="offre-carte__poste">{offre.poste}</h3>
                <div class="offre-carte__tags">
                  <span class="offre-tag offre-tag--type">{offre.type}</span>
                  <span class="offre-tag offre-tag--lieu">{offre.lieu}</span>
                </div>
              </div>
              <p class="offre-carte__desc">{offre.desc}</p>
              <button type="button" class="offre-carte__cta" data-poste={offre.poste} data-i18n="recrutement.offre.postuler">
                Postuler
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
            </div>
          ))}
        </div>
      ) : (
        <div class="offres-vide" id="offresVide">
          <div class="offres-vide__icone">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="2" y="7" width="20" height="14" rx="2"/>
              <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
              <line x1="12" y1="12" x2="12" y2="16"/>
              <line x1="10" y1="14" x2="14" y2="14"/>
            </svg>
          </div>
          <h3 class="offres-vide__titre" data-i18n="recrutement.offres.empty.title">Aucun poste ouvert pour le moment</h3>
          <p class="offres-vide__desc" data-i18n="recrutement.offres.empty.desc">
            Nos prochaines opportunités seront publiées ici. N'hésitez pas à nous envoyer une candidature spontanée.
          </p>
          <button type="button" class="btn-switch-cand" id="btnSwitchCand" data-i18n="recrutement.choix.cand.cta">
            Déposer ma candidature
          </button>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ FORMULAIRE CANDIDATURE (hidden until card selected) ═══ -->
  <section class="content-section" id="formSection" style="display:none;">
    <div class="container">

      <!-- Topbar retour -->
      <div class="form-topbar">
        <button type="button" class="btn-retour" id="btnRetourForm">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          <span data-i18n="recrutement.choix.retour">Changer de rubrique</span>
        </button>
        <div class="form-mode-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          <span data-i18n="recrutement.choix.cand.title">Candidature spontanée</span>
        </div>
      </div>

      <!-- Formulaire -->
      <div class="candidature-wrapper" id="formWrapper">
        <form id="formCandidature" class="candidature-form" novalidate enctype="multipart/form-data">

          <div class="cand-row">
            <div class="cand-group">
              <label class="cand-label" for="prenom"><span data-i18n="recrutement.field.prenom">Prénom</span> <span class="req-star">*</span></label>
              <input type="text" id="prenom" name="prenom" class="cand-input" placeholder="Prénom" required autocomplete="given-name" />
            </div>
            <div class="cand-group">
              <label class="cand-label" for="nom"><span data-i18n="recrutement.field.nom">Nom</span> <span class="req-star">*</span></label>
              <input type="text" id="nom" name="nom" class="cand-input" placeholder="Nom" required autocomplete="family-name" />
            </div>
          </div>

          <div class="cand-row">
            <div class="cand-group">
              <label class="cand-label" for="cand-email"><span data-i18n="recrutement.field.email">Email</span> <span class="req-star">*</span></label>
              <input type="email" id="cand-email" name="email" class="cand-input" placeholder="prenom@exemple.fr" required autocomplete="email" />
            </div>
            <div class="cand-group">
              <label class="cand-label" for="telephone">
                <span data-i18n="recrutement.field.tel">Téléphone</span>
                <span class="req-star">*</span>
              </label>
              <input type="tel" id="telephone" name="telephone" class="cand-input" placeholder="+33 6 00 00 00 00" required autocomplete="tel" />
            </div>
          </div>

          <div class="cand-group cand-group--full">
            <label class="cand-label" for="poste">
              <span data-i18n="recrutement.field.poste">Poste visé</span>
              <span class="cand-optional" data-i18n="recrutement.optional">(optionnel)</span>
            </label>
            <input type="text" id="poste" name="poste" class="cand-input" placeholder="Ex : Agent logistique, Chauffeur, Administratif" autocomplete="off" />
          </div>

          <div class="cand-group cand-group--full">
            <label class="cand-label" for="message">
              <span data-i18n="recrutement.field.message">Message</span>
              <span class="cand-optional" data-i18n="recrutement.optional">(optionnel)</span>
            </label>
            <textarea id="message" name="message" class="cand-textarea" rows="4" placeholder="Votre parcours, vos motivations, vos disponibilités"></textarea>
          </div>

          <div class="cand-group cand-group--full">
            <label class="cand-label" for="cv"><span data-i18n="recrutement.field.cv">CV</span> <span class="req-star">*</span></label>
            <label class="cand-upload" for="cv" id="cvLabel">
              <div class="cand-upload__ico">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="17 8 12 3 7 8"/>
                  <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
              </div>
              <span class="cand-upload__text" id="cvText" data-i18n="recrutement.upload.cv">Cliquez ou déposez votre CV ici</span>
              <span class="cand-upload__hint" data-i18n="recrutement.upload.hint">PDF, DOC, DOCX · max 6 Mo</span>
              <input type="file" id="cv" name="cv" accept=".pdf,.doc,.docx" required class="cand-upload__input" />
            </label>
          </div>

          <div class="cand-group cand-group--full">
            <label class="cand-label" for="lettre">
              <span data-i18n="recrutement.field.lettre">Lettre de motivation</span>
              <span class="cand-optional" data-i18n="recrutement.optional">(optionnelle)</span>
            </label>
            <label class="cand-upload" for="lettre" id="lettreLabel">
              <div class="cand-upload__ico">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                  <polyline points="10 9 9 9 8 9"/>
                </svg>
              </div>
              <span class="cand-upload__text" id="lettreText" data-i18n="recrutement.upload.lettre">Cliquez ou déposez votre lettre ici</span>
              <span class="cand-upload__hint" data-i18n="recrutement.upload.hint">PDF, DOC, DOCX · max 6 Mo</span>
              <input type="file" id="lettre" name="lettre" accept=".pdf,.doc,.docx" class="cand-upload__input" />
            </label>
          </div>

          <div class="cand-rgpd" id="rgpdWrap">
            <input type="checkbox" id="rgpd" name="rgpd" required />
            <label for="rgpd" class="cand-rgpd__label">
              <span data-i18n="recrutement.rgpd">J'accepte que mes données soient traitées par PR Logistics dans le cadre de ma candidature, conformément au RGPD.</span>
              <span class="req-star">*</span>
            </label>
          </div>

          <button type="submit" class="cand-btn" id="candSubmit">
            <span class="cand-btn__text" data-i18n="recrutement.submit">Envoyer ma candidature</span>
            <span class="cand-btn__loading" hidden>
              <svg class="cand-spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
              </svg>
              <span data-i18n="recrutement.sending">Envoi en cours</span>
            </span>
          </button>

        </form>

        <div class="cand-error" id="candError" hidden>
          <p data-i18n="recrutement.error">Une erreur est survenue. Veuillez réessayer ou nous contacter à <a href="mailto:lehavre@pr-logistics.fr">lehavre@pr-logistics.fr</a>.</p>
        </div>

        <!-- Succès -->
        <div class="cand-success" id="candSuccess" hidden>
          <p class="eyebrow-rouge" style="margin-bottom:0.8rem;">Merci</p>
          <div class="success-words" id="successWords"></div>
          <p class="success-sub" id="successSub" data-i18n="recrutement.success.sub">
            Notre équipe étudie chaque profil avec soin.<br>Vous recevrez un email de confirmation dans quelques instants.
          </p>
        </div>

      </div>
    </div>
  </section>

</MainLayout>

<script is:inline>
(function () {

  // ── Sélection mode ────────────────────────────────────────────
  var grid = document.querySelector('.modes-grid');

  function selectMode(mode) {
    // Mise à jour visuelle des cartes
    grid.classList.add('has-selection');
    document.querySelectorAll('.service-card[data-mode]').forEach(function(c) {
      c.classList.toggle('selected', c.dataset.mode === mode);
    });

    var offresSection = document.getElementById('offresSection');
    var formSection   = document.getElementById('formSection');

    // Préparer les sections (reset état)
    [offresSection, formSection].forEach(function(s) {
      if (s) {
        s.style.opacity   = '0';
        s.style.transform = 'translateY(28px)';
        s.style.transition = 'none';
        s.style.display    = 'none';
      }
    });

    var target = mode === 'offres' ? offresSection : formSection;
    if (!target) return;

    target.style.display = 'block';

    // Animer les éléments enfants en stagger
    var topbar  = target.querySelector('.form-topbar');
    var content = target.querySelector('.offres-grid, .offres-vide, .candidature-wrapper');
    var els = [topbar, content].filter(Boolean);
    els.forEach(function(el) {
      el.style.transition = 'none';
      el.style.opacity    = '0';
      el.style.transform  = 'translateY(28px)';
    });

    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        target.style.transition  = 'opacity 0.55s cubic-bezier(0.16,1,0.3,1), transform 0.55s cubic-bezier(0.16,1,0.3,1)';
        target.style.opacity     = '1';
        target.style.transform   = 'translateY(0)';

        els.forEach(function(el, i) {
          setTimeout(function() {
            el.style.transition = 'opacity 0.5s cubic-bezier(0.16,1,0.3,1), transform 0.5s cubic-bezier(0.16,1,0.3,1)';
            el.style.opacity    = '1';
            el.style.transform  = 'translateY(0)';
          }, 80 + i * 90);
        });

        // Scroll fluide
        setTimeout(function() {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 120);
      });
    });
  }

  // Clic sur les cartes
  document.querySelectorAll('.service-card[data-mode]').forEach(function(card) {
    card.addEventListener('click', function() { selectMode(this.dataset.mode); });
    card.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectMode(this.dataset.mode); }
    });
  });

  // Boutons retour
  ['btnRetourOffres', 'btnRetourForm'].forEach(function(id) {
    var btn = document.getElementById(id);
    if (!btn) return;
    btn.addEventListener('click', function() {
      // Réinitialiser
      grid.classList.remove('has-selection');
      document.querySelectorAll('.service-card[data-mode]').forEach(function(c) {
        c.classList.remove('selected');
      });
      ['offresSection', 'formSection'].forEach(function(sid) {
        var s = document.getElementById(sid);
        if (s) {
          s.style.transition = 'opacity 0.3s ease';
          s.style.opacity    = '0';
          setTimeout(function() { s.style.display = 'none'; }, 300);
        }
      });
      setTimeout(function() {
        document.getElementById('modesSelect').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 80);
    });
  });

  // Bouton "Déposer ma candidature" depuis offres vide
  var btnSwitch = document.getElementById('btnSwitchCand');
  if (btnSwitch) btnSwitch.addEventListener('click', function() { selectMode('candidature'); });

  // Boutons "Postuler" depuis offres
  document.querySelectorAll('[data-poste]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var posteInput = document.getElementById('poste');
      if (posteInput) posteInput.value = this.getAttribute('data-poste');
      selectMode('candidature');
    });
  });

  // ── Fichier upload ────────────────────────────────────────────
  function setupFileInput(inputId, textId) {
    var input = document.getElementById(inputId);
    var text  = document.getElementById(textId);
    if (!input || !text) return;
    input.addEventListener('change', function () {
      if (this.files && this.files[0]) {
        var f    = this.files[0];
        var name = f.name.length > 34 ? f.name.slice(0, 31) + '…' : f.name;
        var size = f.size > 1024 * 1024
          ? (f.size / (1024 * 1024)).toFixed(1) + ' Mo'
          : Math.round(f.size / 1024) + ' Ko';
        text.textContent = name + ' (' + size + ')';
        text.style.color = '#16a34a';
        document.getElementById(inputId === 'cv' ? 'cvLabel' : 'lettreLabel')
          .classList.add('cand-upload--ok');
      }
    });
  }
  setupFileInput('cv', 'cvText');
  setupFileInput('lettre', 'lettreText');

  // ── Word reveal succès ────────────────────────────────────────
  function showWordReveal(text) {
    var el = document.getElementById('successWords');
    if (!el) return;
    el.innerHTML = '';
    text.split(' ').forEach(function(word, i) {
      var span = document.createElement('span');
      span.className = 'sw';
      span.textContent = word;
      span.style.setProperty('--wi', i);
      el.appendChild(span);
    });
    requestAnimationFrame(function() {
      requestAnimationFrame(function() { el.classList.add('sw-active'); });
    });
  }

  // ── Soumission ────────────────────────────────────────────────
  var form       = document.getElementById('formCandidature');
  var btn        = document.getElementById('candSubmit');
  var formWrap   = document.getElementById('formWrapper');
  var errBox     = document.getElementById('candError');
  var successBox = document.getElementById('candSuccess');
  var successSub = document.getElementById('successSub');

  if (!form) return;

  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    var rgpd = document.getElementById('rgpd');
    if (!rgpd.checked) {
      document.getElementById('rgpdWrap').classList.add('cand-rgpd--error');
      rgpd.focus();
      return;
    }

    btn.querySelector('.cand-btn__text').hidden = true;
    btn.querySelector('.cand-btn__loading').hidden = false;
    btn.disabled = true;
    errBox.hidden = true;

    var t0 = Date.now();

    try {
      var fd  = new FormData(form);
      var res = await fetch('/send-candidature.php', { method: 'POST', body: fd });
      var raw = await res.text();
      var data;
      try { data = JSON.parse(raw.trim()); } catch(_) { data = {}; }

      var elapsed = Date.now() - t0;
      if (elapsed < 700) await new Promise(function(r) { setTimeout(r, 700 - elapsed); });

      if (data.success) {
        // Masquer le formulaire, montrer le succès
        form.style.transition = 'opacity 0.3s ease';
        form.style.opacity    = '0';
        setTimeout(function() {
          form.hidden       = true;
          errBox.hidden     = true;
          successBox.hidden = false;
          successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });

          var lang = window.__lang || 'fr';
          showWordReveal(lang === 'en'
            ? 'Your application is in good hands.'
            : 'Votre candidature est entre de bonnes mains.');

          if (successSub) {
            successSub.style.opacity    = '0';
            successSub.style.transform  = 'translateY(12px)';
            successSub.style.transition = 'opacity 0.5s ease 0.9s, transform 0.5s ease 0.9s';
            requestAnimationFrame(function() {
              requestAnimationFrame(function() {
                successSub.style.opacity   = '1';
                successSub.style.transform = 'translateY(0)';
              });
            });
          }
        }, 320);
      } else {
        throw new Error(data.error || 'Erreur serveur');
      }
    } catch (_) {
      errBox.hidden = false;
      btn.querySelector('.cand-btn__text').hidden = false;
      btn.querySelector('.cand-btn__loading').hidden = true;
      btn.disabled = false;
    }
  });

  // Retirer erreur RGPD au premier changement
  var rgpdInput = document.getElementById('rgpd');
  if (rgpdInput) {
    rgpdInput.addEventListener('change', function() {
      document.getElementById('rgpdWrap').classList.remove('cand-rgpd--error');
    });
  }

})();
</script>

