---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Qui sommes-nous"
  description="Découvrez l'histoire de PR Logistics, fondée en 2017 par Patrick Richer au cœur du port du Havre. 15 collaborateurs, une croissance constante, des valeurs solides."
>

  <!-- EN-TÊTE -->
  <section class="page-hero">
    <div class="container page-hero__inner">
      <p class="eyebrow-rouge animate-in" data-i18n="about.eyebrow">Notre entreprise</p>
      <h1 class="titre-section animate-in" style="animation-delay:0.1s;" data-i18n-html="about.title">
        Qui sommes-<span>nous</span> ?
      </h1>
      <p class="sous-titre animate-in" style="animation-delay:0.2s; margin: 1rem auto 0;" data-i18n="about.subtitle">
        Prestataire logistique indépendant au cœur du port du Havre, nous mettons notre expertise au service de vos flux depuis 2017.
      </p>
    </div>
  </section>

  <!-- NOTRE HISTOIRE -->
  <section class="section histoire">
    <div class="container">
      <div class="histoire__grid">
        <div class="reveal">
          <p class="eyebrow-rouge" data-i18n="about.history.eyebrow">Notre histoire</p>
          <h2 class="titre-section" data-i18n-html="about.history.title">L'aventure <span>PR Logistics</span></h2>
          <p class="histoire__texte" data-i18n-html="about.history.p1">
            C'est en <strong>2017</strong> que débute l'aventure PR Logistics. Après plus de
            <strong>25 années</strong> passées au poste de responsable logistique au sein de
            différentes structures, <strong>Patrick Richer</strong> décide de créer la société
            PR Logistics.
          </p>
          <p class="histoire__texte" data-i18n-html="about.history.p2">
            Aujourd'hui, PR Logistics c'est <strong>15 collaborateurs</strong> à votre service
            pour vous apporter des solutions concrètes à toutes vos problématiques de logistique
            en entrepôt. Vos flux sont organisés et gérés avec des moyens techniques adaptés
            pour répondre au mieux à vos besoins.
          </p>
          <p class="histoire__texte" data-i18n-html="about.history.p3">
            PR Logistics est une société <strong>indépendante</strong> située au cœur du port
            du Havre, disposant d'un entrepôt de <strong>8 000 m²</strong> sur un terrain de
            <strong>18 500 m²</strong> entièrement clos et télésurveillé 24h/7j par la sécurité
            portuaire.
          </p>
        </div>

        <div class="histoire__timeline reveal" style="transition-delay:0.15s;">
          <div class="timeline__item">
            <div class="timeline__annee">2017</div>
            <div class="timeline__contenu">
              <h3 data-i18n="about.tl.2017.h">Fondation</h3>
              <p data-i18n="about.tl.2017.p">Patrick Richer crée PR Logistics au cœur du port du Havre.</p>
            </div>
          </div>
          <div class="timeline__item">
            <div class="timeline__annee">2021</div>
            <div class="timeline__contenu">
              <h3 data-i18n="about.tl.2021.h">Consolidation</h3>
              <p data-i18n="about.tl.2021.p">1 322 000 € de CA — 1 500 conteneurs traités.</p>
            </div>
          </div>
          <div class="timeline__item">
            <div class="timeline__annee">2022</div>
            <div class="timeline__contenu">
              <h3 data-i18n="about.tl.2022.h">Développement</h3>
              <p data-i18n="about.tl.2022.p">1 698 000 € de CA — 1 700 conteneurs traités.</p>
            </div>
          </div>
          <div class="timeline__item">
            <div class="timeline__annee">2023</div>
            <div class="timeline__contenu">
              <h3 data-i18n="about.tl.2023.h">Accélération</h3>
              <p data-i18n="about.tl.2023.p">2 177 000 € de CA — 2 100 conteneurs traités.</p>
            </div>
          </div>
          <div class="timeline__item timeline__item--actif">
            <div class="timeline__annee">2026</div>
            <div class="timeline__contenu">
              <h3 data-i18n="about.tl.2026.h">Expansion</h3>
              <p data-i18n="about.tl.2026.p">Acquisition d'un nouvel entrepôt.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CERTIFICATIONS ICPE + BREEAM -->
  <section class="section section--gris certif">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:3rem;">
        <p class="eyebrow-rouge" data-i18n="about.certif.eyebrow">Conformité & qualité</p>
        <h2 class="titre-section" data-i18n-html="about.certif.title">PR Logistics <span>aujourd'hui</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0;" data-i18n="about.certif.subtitle">
          Nos installations respectent les exigences réglementaires les plus strictes, pour vous offrir un cadre logistique sûr, durable et certifié.
        </p>
      </div>

      <div class="certif-grid reveal">
        <!-- ICPE -->
        <div class="certif-carte">
          <div class="certif-carte__header">
            <span class="certif-badge certif-badge--bleu" data-i18n="about.icpe.badge">Rubrique réglementaire</span>
            <img src="/assets/certifications/logo-icpe.png" alt="ICPE" class="certif-logo" />
          </div>
          <h3 class="certif-carte__titre">ICPE</h3>
          <p class="certif-carte__desc" data-i18n="about.icpe.desc">
            Installation Classée pour la Protection de l'Environnement. Nos activités sont soumises à déclaration préfectorale et contrôlées régulièrement, garantissant la sécurité industrielle et la protection de l'environnement.
          </p>
          <ul class="icpe-rubriques">
            <li class="icpe-rubrique">
              <span class="icpe-rubrique__code">1510</span>
              <span class="icpe-rubrique__desc">Entrepôts couverts</span>
            </li>
            <li class="icpe-rubrique">
              <span class="icpe-rubrique__code">1530</span>
              <span class="icpe-rubrique__desc">Papier, carton ou matériaux combustibles analogues</span>
            </li>
            <li class="icpe-rubrique">
              <span class="icpe-rubrique__code">1532</span>
              <span class="icpe-rubrique__desc">Bois sec et matériaux à base de bois</span>
            </li>
            <li class="icpe-rubrique">
              <span class="icpe-rubrique__code">2662</span>
              <span class="icpe-rubrique__desc">Polymères (matières plastiques, caoutchoucs, etc.)</span>
            </li>
            <li class="icpe-rubrique">
              <span class="icpe-rubrique__code">2663</span>
              <span class="icpe-rubrique__desc">Stockage de pneumatiques et produits de caoutchouc</span>
            </li>
            <li class="icpe-rubrique">
              <span class="icpe-rubrique__code">2925</span>
              <span class="icpe-rubrique__desc">Ateliers de charge d'accumulateurs</span>
            </li>
            <li class="icpe-rubrique">
              <span class="icpe-rubrique__code">4755</span>
              <span class="icpe-rubrique__desc">Matières et objets explosibles</span>
            </li>
          </ul>
        </div>

        <!-- BREEAM -->
        <div class="certif-carte reveal" style="transition-delay:0.12s;">
          <div class="certif-carte__header">
            <span class="certif-badge certif-badge--vert" data-i18n="about.breeam.badge">Certification internationale</span>
            <img src="/assets/certifications/BREEAM_Logo.png" alt="BREEAM" class="certif-logo" />
          </div>
          <h3 class="certif-carte__titre">BREEAM</h3>
          <p class="certif-carte__desc" data-i18n="about.breeam.desc">
            Certification mondiale de performance environnementale des bâtiments. Notre entrepôt atteste d'une efficacité énergétique optimale et d'un engagement concret pour une logistique durable.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- AGRÉMENTS -->
  <section class="section agrements-section">
    <div class="container" style="position:relative;">
      <div class="agrements-inner reveal">
        <div class="agrements-texte">
          <span class="certif-badge certif-badge--bleu" style="align-self:flex-start;" data-i18n="about.agr.badge">Marchandises spécifiques</span>
          <div class="agrements-titre-row">
            <h2 class="titre-section" style="font-size:2.34rem; margin:0;" data-i18n-html="about.agr.title">Nos <span>agréments</span></h2>
          </div>
          <p class="sous-titre" style="margin:0.8rem 0 0; font-size:1rem;" data-i18n="about.agr.subtitle">
            PR Logistics est habilité à traiter des marchandises soumises à réglementation stricte — vous garantissant conformité et sécurité à chaque flux.
          </p>
        </div>
        <div class="agrements-liste">
          <div class="agrement">
            <img src="/assets/certifications/dangereux.png" alt="Entrepôt de type A" class="agrement__logo" />
            <span class="agrement__nom" data-i18n="about.agr.typeA">Entrepôt de type A (agrément import/export)</span>
            <span class="agrement__statut agrement__statut--ok" data-i18n="about.agr.agree">Agréé</span>
          </div>
          <div class="agrement">
            <img src="/assets/certifications/dangereux.png" alt="Marchandises dangereuses" class="agrement__logo" />
            <span class="agrement__nom" data-i18n="about.agr.dangereux">Marchandises dangereuses</span>
            <span class="agrement__statut agrement__statut--ok" data-i18n="about.agr.agree">Agréé</span>
          </div>
          <div class="agrement">
            <img src="/assets/certifications/froid.png" alt="Prises Reefer" class="agrement__logo" />
            <span class="agrement__nom" data-i18n="about.agr.reefer">Prises Reefer</span>
            <span class="agrement__statut agrement__statut--ok" data-i18n="about.agr.agree">Agréé</span>
          </div>
          <div class="agrement">
            <img src="/assets/certifications/bio.png" alt="Bio" class="agrement__logo" />
            <span class="agrement__nom" data-i18n="about.agr.bio">Bio</span>
            <span class="agrement__statut agrement__statut--soon" data-i18n="about.agr.soon">À venir</span>
          </div>
          <div class="agrement">
            <img src="/assets/certifications/alcool.png" alt="Alcool" class="agrement__logo" />
            <span class="agrement__nom" data-i18n="about.agr.alcool">Alcool</span>
            <span class="agrement__statut agrement__statut--soon" data-i18n="about.agr.soon">À venir</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GRAPHIQUES DE CROISSANCE -->
  <section class="section croissance">
    <div class="agr-blob agr-blob--1" aria-hidden="true"></div>
    <div class="agr-blob agr-blob--2" aria-hidden="true"></div>
    <div class="container" style="position:relative;">
      <div class="reveal" style="text-align:center; margin-bottom:3.5rem;">
        <p class="eyebrow-rouge" data-i18n="about.growth.eyebrow">Performances</p>
        <h2 class="titre-section" data-i18n-html="about.growth.title">Notre <span>croissance</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0;" data-i18n="about.growth.subtitle">
          Une croissance continue depuis la création, portée par la confiance de nos partenaires.
        </p>
      </div>

      <div class="graphiques-grid">
        <!-- Graphique CA -->
        <div class="graphique-carte reveal">
          <div class="graphique-carte__header">
            <h3 data-i18n="about.chart.ca">Chiffre d'affaires</h3>
            <span class="badge-hausse" data-i18n="about.chart.ca.badge">+74% en 4 ans</span>
          </div>
          <div class="graphique-carte__canvas-wrapper">
            <canvas id="chartCA" aria-label="Évolution du chiffre d'affaires 2021-2025"></canvas>
          </div>
        </div>

        <!-- Graphique Conteneurs -->
        <div class="graphique-carte reveal" style="transition-delay:0.15s;">
          <div class="graphique-carte__header">
            <h3 data-i18n="about.chart.cont">Volume de conteneurs traités</h3>
            <span class="badge-hausse" data-i18n="about.chart.cont.badge">+113% en 4 ans</span>
          </div>
          <div class="graphique-carte__canvas-wrapper">
            <canvas id="chartConteneurs" aria-label="Évolution du volume de conteneurs 2021-2025"></canvas>
          </div>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<!-- Chart.js via CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const rouge = '#e30613';
    const bleu  = '#1b2a4a';

    // Plugin inline : affiche les valeurs au-dessus des barres
    const labelAuDessus = {
      id: 'labelAuDessus',
      afterDatasetsDraw(chart: any) {
        const { ctx, data } = chart;
        chart.data.datasets.forEach((_: any, di: number) => {
          const meta = chart.getDatasetMeta(di);
          meta.data.forEach((bar: any, index: number) => {
            const val = data.datasets[di].data[index];
            const label = data.datasets[di].labels?.[index] ?? '';
            ctx.save();
            ctx.font = 'bold 13px -apple-system, BlinkMacSystemFont, Inter, sans-serif';
            ctx.fillStyle = '#1d1d1f';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'bottom';
            ctx.fillText(label, bar.x, bar.y - 6);
            ctx.restore();
          });
        });
      },
    };

    const optionsCommun = {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(10,10,10,0.85)',
          padding: 12,
          cornerRadius: 10,
          titleFont: { size: 13, weight: '700' },
          bodyFont: { size: 13 },
        },
      },
      scales: {
        x: {
          grid: { display: false },
          border: { display: false },
          ticks: {
            font: { size: 14, weight: '600' },
            color: '#1d1d1f',
          },
        },
        y: {
          display: false,
          grid: { display: false },
          border: { display: false },
          beginAtZero: true,
        },
      },
      elements: {
        bar: { borderRadius: 8, borderSkipped: false },
      },
    };

    // --- Graphique CA ---
    const ctxCA = (document.getElementById('chartCA') as HTMLCanvasElement)?.getContext('2d');
    if (ctxCA) {
      new (window as any).Chart(ctxCA, {
        type: 'bar',
        plugins: [labelAuDessus],
        data: {
          labels: ['2021', '2023', '2025'],
          datasets: [{
            data: [1322000, 2177000, 2300000],
            labels: ['1,3M€', '2,2M€', '2,3M€'],
            backgroundColor: [
              'rgba(227,6,19,0.45)',
              'rgba(227,6,19,0.75)',
              'rgba(227,6,19,1)',
            ],
            borderColor: 'transparent',
            borderWidth: 0,
          }],
        },
        options: {
          ...optionsCommun,
          plugins: {
            ...optionsCommun.plugins,
            tooltip: {
              ...optionsCommun.plugins.tooltip,
              callbacks: {
                label: (ctx: any) => ` ${ctx.parsed.y.toLocaleString('fr-FR')} €`,
              },
            },
          },
          scales: {
            ...optionsCommun.scales,
            y: { ...optionsCommun.scales.y, max: 2800000 },
          },
        },
      });
    }

    // --- Graphique Conteneurs ---
    const ctxC = (document.getElementById('chartConteneurs') as HTMLCanvasElement)?.getContext('2d');
    if (ctxC) {
      new (window as any).Chart(ctxC, {
        type: 'bar',
        plugins: [labelAuDessus],
        data: {
          labels: ['2021', '2023', '2025'],
          datasets: [{
            data: [1500, 2100, 3200],
            labels: ['1 500', '2 100', '3 200'],
            backgroundColor: [
              'rgba(27,42,74,0.35)',
              'rgba(27,42,74,0.65)',
              'rgba(27,42,74,1)',
            ],
            borderColor: 'transparent',
            borderWidth: 0,
          }],
        },
        options: {
          ...optionsCommun,
          plugins: {
            ...optionsCommun.plugins,
            tooltip: {
              ...optionsCommun.plugins.tooltip,
              callbacks: {
                label: (ctx: any) => ` ${ctx.parsed.y.toLocaleString('fr-FR')} EVP`,
              },
            },
          },
          scales: {
            ...optionsCommun.scales,
            y: { ...optionsCommun.scales.y,
              min: 1000,
              max: 3800,
            },
          },
        },
      });
    }
  });
</script>

<style>
  /* PAGE HERO */
  .page-hero {
    background: linear-gradient(135deg, var(--gris-clair), white);
    padding: 5rem 0 4rem;
    text-align: center;
  }

  /* HISTOIRE */
  .histoire__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .histoire__texte {
    font-size: 1.15rem;
    color: var(--gris-moyen);
    line-height: 1.8;
    margin-top: 1rem;
  }

  .histoire__texte strong {
    color: var(--gris-fonce);
    font-weight: 600;
  }

  /* TIMELINE */
  .histoire__timeline {
    position: relative;
    padding-left: 2rem;
  }

  .histoire__timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    bottom: 12px;
    width: 2px;
    background: linear-gradient(to bottom, var(--rouge), rgba(227,6,19,0.1));
    border-radius: 2px;
  }

  .timeline__item {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
    margin-bottom: 2rem;
    position: relative;
  }

  .timeline__item::before {
    content: '';
    position: absolute;
    left: -2.4rem;
    top: 6px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: white;
    border: 2px solid rgba(227,6,19,0.3);
    transition: all 0.3s;
  }

  .timeline__item--actif::before {
    background: var(--rouge);
    border-color: var(--rouge);
    box-shadow: 0 0 0 4px rgba(227,6,19,0.15);
  }

  .timeline__annee {
    font-size: 1rem;
    font-weight: 800;
    color: var(--rouge);
    min-width: 44px;
    padding-top: 2px;
  }

  .timeline__contenu h3 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--gris-fonce);
    margin-bottom: 0.2rem;
  }

  .timeline__contenu p {
    font-size: 1rem;
    color: var(--gris-moyen);
    line-height: 1.5;
  }

  /* supprimé : kpi-grid (remplacé par certif + agréments) */

  /* GRAPHIQUES */
  .graphiques-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .graphique-carte {
    background: white;
    border-radius: var(--rayon-lg);
    padding: 2rem 2rem 1.5rem;
    box-shadow: 0 4px 30px rgba(0,0,0,0.07);
  }

  .graphique-carte__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .graphique-carte__header h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--gris-fonce);
  }

  .badge-hausse {
    font-size: 0.75rem;
    font-weight: 700;
    color: #15803d;
    background: #dcfce7;
    padding: 0.3rem 0.8rem;
    border-radius: 2rem;
  }

  .graphique-carte__canvas-wrapper {
    height: 220px;
    position: relative;
  }

  /* Légende barres */
  .graphique-carte__legende {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }


  /* CERTIFICATIONS */
  .certif-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .certif-carte {
    background: white;
    border-radius: var(--rayon-lg);
    padding: 1.6rem 1.8rem;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .certif-carte__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .certif-logo {
    height: 38px;
    width: auto;
    object-fit: contain;
    border-radius: 0 !important;
  }

  .certif-badge {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.28rem 0.8rem;
    border-radius: 2rem;
  }

  .certif-badge--bleu {
    background: rgba(27,42,74,0.09);
    color: var(--bleu-marine);
  }

  .certif-badge--vert {
    background: #dcfce7;
    color: #15803d;
  }

  .certif-carte__titre {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--gris-fonce);
    letter-spacing: -0.02em;
  }

  .certif-carte__desc {
    font-size: 0.92rem;
    color: var(--gris-moyen);
    line-height: 1.65;
  }

  /* ICPE rubriques */
  .icpe-rubriques {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .icpe-rubrique {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .icpe-rubrique__code {
    flex-shrink: 0;
    background: rgba(227,6,19,0.09);
    color: var(--rouge);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    padding: 0.18rem 0.5rem;
    border-radius: 0.4rem;
    min-width: 3rem;
    text-align: center;
  }

  .icpe-rubrique__desc {
    color: var(--gris-moyen);
    padding-top: 0.1rem;
  }

  /* AGRÉMENTS */
  .agrements-section {
    background: linear-gradient(135deg, #fff 0%, var(--gris-clair) 100%);
  }

  /* Blobs rouges flous sur la section Croissance */
  .croissance {
    position: relative;
    overflow: hidden;
  }

  .agr-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(90px);
  }

  .agr-blob--1 {
    width: 480px;
    height: 480px;
    top: -140px;
    right: -120px;
    background: rgba(227, 6, 19, 0.07);
  }

  .agr-blob--2 {
    width: 380px;
    height: 380px;
    bottom: -120px;
    left: -90px;
