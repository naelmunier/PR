---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Transport"
  description="LH Affrètement, notre entreprise de transport dédiée depuis Le Havre. Transport routier, maritime, aérien, ferroviaire et affrètement sur-mesure partout en France."
  canonicalPath="/transport"
>

  <!-- ═══ 1. HERO ═══════════════════════════════════════════════ -->
  <section class="page-hero transport-hero">
    <div class="container page-hero__inner">
      <img
        src="/assets/lhaffretement/lh-affretement.jpeg"
        alt="LH Affrètement"
        class="hero-lh-grande animate-in"
      />
      <p class="eyebrow-rouge animate-in" style="animation-delay:0.1s;" data-i18n="transport.hero.eyebrow">Transport & Affrètement</p>
      <h1 class="titre-section animate-in" style="animation-delay:0.18s;" data-i18n-html="transport.hero.title">
        Transport <span>dédié</span> depuis Le Havre
      </h1>
      <p class="sous-titre animate-in" style="animation-delay:0.28s; margin:1rem auto 0; max-width:640px;" data-i18n="transport.hero.subtitle">
        Avec LH Affrètement, notre entreprise de transport dédiée, vos marchandises sont prises en charge de A à Z — réactivité, fiabilité et solutions sur-mesure, partout en France.
      </p>
    </div>
  </section>

  <!-- ═══ 2. EN QUELQUES MOTS ═══════════════════════════════════ -->
  <section class="section section--gris lh-mots-section">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:3rem;">
        <p class="eyebrow-rouge" data-i18n="transport.mots.eyebrow">En quelques mots…</p>
        <h2 class="titre-section" data-i18n-html="transport.partner.title">LH <span>Affrètement</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0; max-width:620px;" data-i18n="transport.partner.desc1">
          LH Affrètement est notre entreprise de transport dédiée, spécialisée dans l'affrètement de marchandises. Elle agit comme interface opérationnelle entre vous et les transporteurs partenaires pour vous garantir le meilleur service au meilleur coût.
        </p>
      </div>

      <div class="atouts-grid">
        <div class="atout-card reveal" style="transition-delay:0.05s;">
          <div class="atout-card__icon">
            <img src="/assets/lhaffretement/réactivité.png" alt="Réactivité" />
          </div>
          <h3 class="atout-card__title" data-i18n="transport.eng.reactivite">Réactivité maximale</h3>
          <p class="atout-card__desc" data-i18n="transport.atout.reactivite.desc">Disponibilité et rapidité de réponse dans toutes les situations — même les plus urgentes.</p>
        </div>

        <div class="atout-card reveal" style="transition-delay:0.12s;">
          <div class="atout-card__icon">
            <img src="/assets/lhaffretement/sur-mesure.png" alt="Sur-mesure" />
          </div>
          <h3 class="atout-card__title" data-i18n="transport.eng.surmesure">Solutions sur-mesure</h3>
          <p class="atout-card__desc" data-i18n="transport.atout.surmesure.desc">Chaque demande est unique. Nous adaptons la solution transport à votre besoin, pas l'inverse.</p>
        </div>

        <div class="atout-card reveal" style="transition-delay:0.19s;">
          <div class="atout-card__icon">
            <img src="/assets/lhaffretement/interlocuteur-unique.png" alt="Interlocuteur unique" />
          </div>
          <h3 class="atout-card__title" data-i18n="transport.eng.interlocuteur">Interlocuteur unique</h3>
          <p class="atout-card__desc" data-i18n="transport.atout.interlocuteur.desc">Un seul contact pour l'ensemble de vos flux transport — suivi, coordination et reporting centralisés.</p>
        </div>

        <div class="atout-card reveal" style="transition-delay:0.26s;">
          <div class="atout-card__icon">
            <img src="/assets/lhaffretement/reseau.png" alt="Réseau" />
          </div>
          <h3 class="atout-card__title" data-i18n="transport.eng.reseau">Réseau solide & performant</h3>
          <p class="atout-card__desc" data-i18n="transport.atout.reseau.desc">Un réseau dense de transporteurs partenaires, sélectionnés pour leur fiabilité et leur expertise terrain.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 3. SERVICES CAROUSEL ══════════════════════════════════ -->
  <section class="section transport-services-section">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:2.8rem;">
        <p class="eyebrow-rouge" data-i18n="transport.services.eyebrow">Nos services</p>
        <h2 class="titre-section" data-i18n-html="transport.services.title">Des solutions pour <span>chaque besoin</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0;" data-i18n="transport.services.subtitle">
          De l'affrètement routier à la gestion d'urgences, nous couvrons l'ensemble des modes de transport.
        </p>
      </div>

      <div class="svc-carousel-outer reveal">
        <div class="svc-carousel-track" id="svcTrack">

          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.routier.title">Transport Routier</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.routier.desc">Fret conventionnel, camion complet (FTL) ou groupage (LTL) — notre réseau couvre toute la France depuis Le Havre.</p>
          </div>

          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 17h18M12 3 4 9v8h16V9z"/><path d="M12 3v6M8 9h8"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.maritime.title">Transport Maritime</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.maritime.desc">Coordination du fret maritime en partenariat avec les armateurs — import, export et transbordement depuis Le Havre.</p>
          </div>

          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.8 19.2 16 11l3.5-3.5C21 6 21 4 19 4s-2 1-3.5 2.5L9 4 4.8 6.2l7 3.5-2.6 2.6L7.5 12 5 11.5l-2 2 6 3.5 3.5 2 2-2-1.5-3 2.6-2.6 3.5 7Z"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.aerien.title">Transport Aérien</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.aerien.desc">Solutions express prioritaires pour vos envois urgents ou à haute valeur ajoutée, vers toutes destinations.</p>
          </div>

          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="3" width="16" height="14" rx="2"/><path d="M4 11h16M12 3v8M8 19l-2 2m10-2 2 2"/><circle cx="8" cy="18" r="1" fill="currentColor"/><circle cx="16" cy="18" r="1" fill="currentColor"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.ferroviaire.title">Ferroviaire & Fluvial</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.ferroviaire.desc">Solutions intermodales combinant rail et voie d'eau pour une logistique durable et économique.</p>
          </div>

          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.affretement.title">Affrètement Sur-Mesure</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.affretement.desc">Véhicule entier dédié ou groupage optimisé — la solution la plus adaptée à chaque flux.</p>
          </div>

          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.urgence.title">Gestion d'Urgences</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.urgence.desc">Réactivité maximale — organisation de chargements en dehors des plages habituelles si nécessaire.</p>
          </div>

        </div>
        <div class="svc-dots" id="svcDots">
          <button class="svc-dot svc-dot--active" data-idx="0" aria-label="Page 1"></button>
          <button class="svc-dot" data-idx="1" aria-label="Page 2"></button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 4. RÉPARTITION MODALE ════════════════════════════════ -->
  <section class="section section--gris modes-section" id="modesSection">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:2.8rem;">
        <p class="eyebrow-rouge" data-i18n="transport.modes.eyebrow">Répartition des activités</p>
        <h2 class="titre-section" data-i18n-html="transport.modes.title">Le transport <span>routier</span> au cœur de notre activité</h2>
        <p class="sous-titre" style="margin:1rem auto 0;" data-i18n="transport.modes.subtitle">
          Principalement spécialisés en transport routier, nous proposons également des solutions sur tous les autres modes selon vos besoins.
        </p>
      </div>

      <div class="modes-layout reveal">
        <!-- Donut SVG -->
        <div class="modes-donut-wrap">
          <svg class="modes-donut" viewBox="0 0 160 160" aria-hidden="true">
            <!-- Background ring -->
            <circle cx="80" cy="80" r="60" fill="none" stroke="#e8e8ed" stroke-width="22"/>
            <!-- Routier 85% -->
            <circle class="donut-seg donut-seg--routier" cx="80" cy="80" r="60"
              fill="none" stroke="#e30613" stroke-width="22"
              stroke-linecap="butt"
              style="transform:rotate(-90deg); transform-origin:80px 80px;"/>
            <!-- Maritime 8% -->
            <circle class="donut-seg donut-seg--maritime" cx="80" cy="80" r="60"
              fill="none" stroke="#3b82f6" stroke-width="22"
              stroke-linecap="butt"
              style="transform:rotate(216deg); transform-origin:80px 80px;"/>
            <!-- Aérien 4% -->
            <circle class="donut-seg donut-seg--aerien" cx="80" cy="80" r="60"
              fill="none" stroke="#f97316" stroke-width="22"
              stroke-linecap="butt"
              style="transform:rotate(244.8deg); transform-origin:80px 80px;"/>
            <!-- Rail + Fluvial 3% -->
            <circle class="donut-seg donut-seg--rail" cx="80" cy="80" r="60"
              fill="none" stroke="#8b8b8b" stroke-width="22"
              stroke-linecap="butt"
              style="transform:rotate(259.2deg); transform-origin:80px 80px;"/>
            <!-- Centre -->
            <circle cx="80" cy="80" r="44" fill="white"/>
            <text x="80" y="75" text-anchor="middle" font-size="28" font-weight="800" fill="#e30613" font-family="-apple-system, BlinkMacSystemFont, Inter, sans-serif">85%</text>
            <text x="80" y="92" text-anchor="middle" font-size="9" font-weight="600" fill="#6e6e73" font-family="-apple-system, BlinkMacSystemFont, Inter, sans-serif">Routier</text>
          </svg>
        </div>

        <!-- Barres de détail -->
        <div class="modes-bars">
          <div class="mode-row">
            <div class="mode-row__header">
              <span class="mode-dot" style="background:#e30613;"></span>
              <span class="mode-label" data-i18n="transport.mode.routier">Transport Routier</span>
              <span class="mode-pct mode-pct--primary">85%</span>
            </div>
            <div class="mode-bar-bg">
              <div class="mode-bar mode-bar--routier" data-target="85"></div>
            </div>
            <p class="mode-detail" data-i18n="transport.mode.routier.detail">FTL · LTL · Groupage · National & régional</p>
          </div>

          <div class="mode-row">
            <div class="mode-row__header">
              <span class="mode-dot" style="background:#3b82f6;"></span>
              <span class="mode-label" data-i18n="transport.mode.maritime">Transport Maritime</span>
              <span class="mode-pct">8%</span>
            </div>
            <div class="mode-bar-bg">
              <div class="mode-bar mode-bar--maritime" data-target="8"></div>
            </div>
            <p class="mode-detail" data-i18n="transport.mode.maritime.detail">Import · Export · Transbordement</p>
          </div>

          <div class="mode-row">
            <div class="mode-row__header">
              <span class="mode-dot" style="background:#f97316;"></span>
              <span class="mode-label" data-i18n="transport.mode.aerien">Transport Aérien</span>
              <span class="mode-pct">4%</span>
            </div>
            <div class="mode-bar-bg">
              <div class="mode-bar mode-bar--aerien" data-target="4"></div>
            </div>
            <p class="mode-detail" data-i18n="transport.mode.aerien.detail">Express · Haute valeur ajoutée · International</p>
          </div>

          <div class="mode-row">
            <div class="mode-row__header">
              <span class="mode-dot" style="background:#8b8b8b;"></span>
              <span class="mode-label" data-i18n="transport.mode.rail">Ferroviaire & Fluvial</span>
              <span class="mode-pct">3%</span>
            </div>
            <div class="mode-bar-bg">
              <div class="mode-bar mode-bar--rail" data-target="3"></div>
            </div>
            <p class="mode-detail" data-i18n="transport.mode.rail.detail">Intermodal · Massifié · Durable</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 5. CARTE FRANCE ═══════════════════════════════════════ -->
  <section class="section carte-transport">
    <div class="tooltip-map" id="tooltip-map">
      <span id="tt-map-nom"></span><span id="tt-map-j"></span>
    </div>
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:2.8rem;">
        <p class="eyebrow-rouge" data-i18n="transport.map.eyebrow">Couverture nationale</p>
        <h2 class="titre-section" data-i18n-html="transport.map.title">Délais de livraison <span>depuis Le Havre</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0;" data-i18n="transport.map.subtitle">
          Estimations indicatives · Hors week-ends et jours fériés
        </p>
      </div>

      <div class="carte-transport__inner reveal">
        <div class="carte-transport__map">
          <svg id="map-transport" viewBox="0 0 500 520"></svg>
        </div>

        <div class="carte-transport__legende">
          <span class="legende-titre" data-i18n="transport.map.legend">Délais estimés</span>

          <div class="legende-item">
            <div class="legende-couleur" style="background:#22c55e;"></div>
            <div>
              <div class="legende-delai">24h</div>
              <div class="legende-zones">Normandie · Île-de-France · Hauts-de-France<br>Centre · Grand Ouest · Bourgogne</div>
            </div>
          </div>
          <div class="legende-item">
            <div class="legende-couleur" style="background:#eab308;"></div>
            <div>
              <div class="legende-delai">48h</div>
              <div class="legende-zones">Bretagne · Grand Est · Pays de la Loire<br>Nouvelle-Aquitaine · Rhône-Alpes · PACA</div>
            </div>
          </div>
          <div class="legende-item">
            <div class="legende-couleur" style="background:#f97316;"></div>
            <div>
              <div class="legende-delai">72h</div>
              <div class="legende-zones">Ardèche · Lot · Lot-et-Garonne<br>Roussillon</div>
            </div>
          </div>
          <div class="legende-item">
            <div class="legende-couleur" style="background:#e30613;"></div>
            <div>
              <div class="legende-delai">96h</div>
              <div class="legende-zones">Lozère · Corse</div>
            </div>
          </div>

          <div class="legende-plateforme">
            <img src="/assets/lhaffretement/palteforme.gif" alt="Plateforme" width="16" height="16" />
            <span data-i18n="transport.map.plateforme">Présence d'une plateforme logistique</span>
          </div>

          <p class="carte-note" data-i18n="transport.map.note">Délais indicatifs pour livraisons en palettes, sur route.</p>
          <a href="/devis" class="btn-carte-devis" data-i18n="transport.map.cta">Demander un devis transport</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 6. CTA ════════════════════════════════════════════════ -->
  <section class="section section--gris cta-section-transport">
    <div class="container" style="text-align:center;">
      <div class="reveal">
        <p class="eyebrow-rouge" data-i18n="transport.cta.eyebrow">Prêt à expédier ?</p>
        <h2 class="titre-section" data-i18n-html="transport.cta.title">Un besoin transport&nbsp;?<br><span>Contactez LH Affrètement.</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0; max-width:560px;" data-i18n="transport.cta.subtitle">
          Notre équipe analyse votre besoin et vous propose la solution la plus adaptée — camion complet, groupage, ou affrètement multimodal.
        </p>
        <div class="cta-btns">
          <a href="/contact" class="btn-cta-rouge" data-i18n="transport.cta.contact">Nous contacter</a>
          <a href="/devis" class="btn-cta-outline" data-i18n="transport.cta.devis">Demander un devis</a>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<!-- D3.js local -->
<script src="/assets/d3.min.js" is:inline></script>

<script is:inline>
(function () {

  /* ── Donut Chart Animation ──────────────────────────────── */
  // Circonférence pour r=60 : 2*π*60 ≈ 376.99
  var C = 2 * Math.PI * 60;

  function animateModes() {
    var targets = [
      { sel: '.donut-seg--routier',  len: C * 0.85 },
      { sel: '.donut-seg--maritime', len: C * 0.08 },
      { sel: '.donut-seg--aerien',   len: C * 0.04 },
      { sel: '.donut-seg--rail',     len: C * 0.03 },
    ];
    targets.forEach(function (t) {
      var el = document.querySelector(t.sel);
      if (el) el.style.strokeDasharray = t.len.toFixed(1) + ' ' + C.toFixed(1);
    });

    // Barres horizontales
    document.querySelectorAll('.mode-bar').forEach(function (bar) {
      var pct = bar.getAttribute('data-target');
      bar.style.width = pct + '%';
    });
  }

  var modesSection = document.getElementById('modesSection');
  if (modesSection) {
    var modesObs = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        setTimeout(animateModes, 200);
        modesObs.disconnect();
      }
    }, { threshold: 0.25 });
    modesObs.observe(modesSection);
  }

  /* ── Carte France ─────────────────────────────────────────── */
  var delais = {
    '01':2,'02':1,'03':1,'04':2,'05':2,'06':2,'07':3,'08':1,'09':2,'10':1,
    '11':2,'12':3,'13':2,'14':1,'15':2,'16':1,'17':1,'18':1,'19':1,
    '21':1,'22':2, // bicolore : Est=1(24h) / Ouest=2(48h)
    '23':1,'24':1,'25':2,'26':2,'27':1,'28':1,'29':2,
    '30':2,'31':2,'32':2,'33':2,'34':2,'35':1,'36':1,'37':1,'38':2,'39':2,
    '40':2,'41':1,'42':2,'43':2,'44':1,'45':1,'46':3,'47':2,'48':4,'49':1,
    '50':2,'51':1,'52':1,'53':1,'54':2,'55':2,'56':2,'57':2,'58':1,'59':1,
    '60':1,'61':1,'62':1,'63':1,'64':2,'65':2,'66':3,'67':2,'68':2,'69':2,
    '70':2,'71':1,'72':1,'73':2,'74':2,'75':1,'76':1,'77':1,'78':1,'79':1,
    '80':1,'81':2,'82':2,'83':2,'84':2,'85':1,'86':1,'87':1,'88':2,'89':1,
    '90':2,'91':1,'92':1,'93':1,'94':1,'95':1,
    '2A':4,'2B':4
  };
  var plateformes = ['47', '69', '54'];
  var colorMap    = ['', '#22c55e', '#eab308', '#f97316', '#e30613'];
  var labelMap    = ['', '24h', '48h', '72h', '96h'];
  var w = 500, h = 520;

  var svg     = d3.select('#map-transport');
  var tooltip = document.getElementById('tooltip-map');
  var ttNom   = document.getElementById('tt-map-nom');
  var ttJ     = document.getElementById('tt-map-j');

  if (!svg.node()) return;

  fetch('/assets/departements.geojson')
    .then(function (r) { return r.json(); })
    .then(function (geo) {
      var projection = d3.geoConicConformal()
        .center([2.454071, 46.279229])
        .parallels([44, 49]);
      var path = d3.geoPath().projection(projection);
      projection.fitSize([w, h], { type: 'FeatureCollection', features: geo.features });

      // ── Gradient bicolore pour le dép. 22 ──
      var defs = svg.append('defs');
      var g22 = defs.append('linearGradient')
        .attr('id', 'grad-22')
        .attr('x1', '0%').attr('y1', '0%')
        .attr('x2', '100%').attr('y2', '0%');
      g22.append('stop').attr('offset', '0%').attr('stop-color', colorMap[2]);   // Ouest = 48h
      g22.append('stop').attr('offset', '100%').attr('stop-color', colorMap[1]); // Est = 24h

      var gPaths  = svg.append('g').attr('class', 'g-paths');
      var gLabels = svg.append('g').attr('class', 'g-labels');

      gPaths.selectAll('path')
        .data(geo.features)
        .enter().append('path')
        .attr('d', path)
        .attr('stroke', 'white')
        .attr('stroke-width', 0.9)
        .style('fill', function (d) {
          if (d.properties.code === '22') return 'url(#grad-22)';
          return colorMap[delais[d.properties.code] || 2];
        })
        .style('cursor', 'pointer')
        .on('mouseover', function (event, d) {
          var centroid = path.centroid(d);
          var cx = centroid[0], cy = centroid[1];
          d3.select(this)
            .raise()
            .transition().duration(160).ease(d3.easeCubicOut)
            .attr('stroke', '#fff').attr('stroke-width', 2)
            .attr('transform', 'translate(' + cx + ',' + cy + ') scale(1.12) translate(' + (-cx) + ',' + (-cy) + ')');

          gLabels.select('.hover-label').remove();
          gLabels.append('text')
            .attr('class', 'hover-label')
            .attr('x', cx).attr('y', cy - 14)
            .attr('text-anchor', 'middle').attr('font-size', '11').attr('font-weight', '700')
            .attr('fill', '#1d1d1f')
            .attr('font-family', '-apple-system, BlinkMacSystemFont, Inter, sans-serif')
            .attr('pointer-events', 'none')
            .style('filter', 'drop-shadow(0 1px 3px rgba(255,255,255,0.95))')
            .text(d.properties.nom);

          var code = d.properties.code;
          var jVal = code === '22' ? '24h (Est) / 48h (Ouest)' : (labelMap[delais[code]] || '48h');
          tooltip.style.opacity = '1';
          tooltip.style.left    = (event.clientX + 14) + 'px';
          tooltip.style.top     = (event.clientY - 10) + 'px';
          ttNom.textContent = d.properties.nom + ' (' + code + ')';
          ttJ.textContent   = ' · ' + jVal;
        })
        .on('mousemove', function (event) {
          tooltip.style.left = (event.clientX + 14) + 'px';
          tooltip.style.top  = (event.clientY - 10) + 'px';
        })
        .on('mouseleave', function () {
          d3.select(this)
            .transition().duration(200).ease(d3.easeCubicOut)
            .attr('stroke', 'white').attr('stroke-width', 0.9)
            .attr('transform', null);
          gLabels.select('.hover-label').transition().duration(120).style('opacity', 0).remove();
          tooltip.style.opacity = '0';
        });

      // ── Numéros de département ──
      gLabels.selectAll('text.dept-num')
        .data(geo.features)
        .enter().append('text')
        .attr('class', 'dept-num')
        .attr('x', function (d) { return path.centroid(d)[0]; })
        .attr('y', function (d) { return path.centroid(d)[1] + 1; })
        .attr('text-anchor', 'middle').attr('dominant-baseline', 'middle')
        .attr('font-size', '6.5').attr('font-weight', '700')
        .attr('fill', 'rgba(255,255,255,0.9)').attr('pointer-events', 'none')
        .attr('font-family', '-apple-system, BlinkMacSystemFont, Inter, sans-serif')
        .text(function (d) { return d.properties.code; });

      // ── Icônes Plateforme ──
      plateformes.forEach(function (code) {
        var feat = geo.features.find(function (f) { return f.properties.code === code; });
        if (!feat) return;
        var c = path.centroid(feat);
        // Groupe plateforme
        var g = svg.append('g')
          .attr('transform', 'translate(' + (c[0] - 8) + ',' + (c[1] + 6) + ')')
          .attr('pointer-events', 'none');
        g.append('image')
          .attr('href', '/assets/lhaffretement/palteforme.gif')
          .attr('width', 16).attr('height', 16)
          .attr('x', 0).attr('y', 0);
      });

      // ── Marqueur Le Havre ──
      var lh = projection([0.1074, 49.4944]);
      svg.append('circle').attr('cx', lh[0]).attr('cy', lh[1]).attr('r', 6)
        .attr('fill', '#e30613').attr('stroke', 'white').attr('stroke-width', 1.5);
      svg.append('text').attr('x', lh[0] + 9).attr('y', lh[1] + 4)
        .attr('font-size', '10').attr('font-weight', '700')
        .attr('fill', '#1d1d1f').attr('font-family', 'sans-serif').text('Le Havre');
    });

  /* ── Carousel navigation ─────────────────────────────────── */
  var track = document.getElementById('svcTrack');
  var dots  = document.querySelectorAll('.svc-dot');
  if (track && dots.length) {
    var cards = track.querySelectorAll('.svc-card');
    function scrollToPage(idx) {
      if (!cards[0]) return;
      var cardW = cards[0].getBoundingClientRect().width;
      var gap   = parseInt(getComputedStyle(track).gap) || 24;
      track.scrollTo({ left: idx * 3 * (cardW + gap), behavior: 'smooth' });
      dots.forEach(function (d, i) { d.classList.toggle('svc-dot--active', i === idx); });
    }
    dots.forEach(function (dot) {
      dot.addEventListener('click', function () { scrollToPage(parseInt(dot.getAttribute('data-idx'))); });
    });
    track.addEventListener('scroll', function () {
      if (!cards[0]) return;
      var cardW = cards[0].getBoundingClientRect().width;
      var gap   = parseInt(getComputedStyle(track).gap) || 24;
      var idx   = Math.round(track.scrollLeft / (3 * (cardW + gap)));
      dots.forEach(function (d, i) { d.classList.toggle('svc-dot--active', i === idx); });
    }, { passive: true });
  }

})();
</script>

