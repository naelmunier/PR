---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Transport"
  description="LH Affrètement, notre entreprise de transport dédiée depuis Le Havre. Transport routier, maritime, aérien, ferroviaire et affrètement sur-mesure partout en France."
  canonicalPath="/transport"
>

  <!-- PAGE HERO -->
  <section class="page-hero transport-hero">
    <div class="container page-hero__inner">
      <div class="hero-lh-badge animate-in">
        <img src="/assets/lhaffretement/lh-affretement.jpeg" alt="LH Affrètement" class="hero-lh-logo" />
      </div>
      <p class="eyebrow-rouge animate-in" style="animation-delay:0.08s;" data-i18n="transport.hero.eyebrow">Transport & Affrètement</p>
      <h1 class="titre-section animate-in" style="animation-delay:0.15s;" data-i18n-html="transport.hero.title">
        Transport <span>dédié</span> depuis Le Havre
      </h1>
      <p class="sous-titre animate-in" style="animation-delay:0.25s; margin: 1rem auto 0; max-width: 640px;" data-i18n="transport.hero.subtitle">
        Avec LH Affrètement, notre entreprise de transport dédiée, vos marchandises sont prises en charge de A à Z — réactivité, fiabilité et solutions sur-mesure, partout en France.
      </p>
    </div>
  </section>

  <!-- PRÉSENTATION LH AFFRÈTEMENT -->
  <section class="section lh-section">
    <div class="container">
      <div class="lh-grid">

        <!-- Texte gauche -->
        <div class="lh-texte reveal">
          <p class="eyebrow-rouge" data-i18n="transport.partner.eyebrow">Notre entreprise de transport</p>
          <h2 class="titre-section" data-i18n-html="transport.partner.title">LH <span>Affrètement</span></h2>
          <p class="lh-desc" data-i18n="transport.partner.desc1">
            LH Affrètement est notre entreprise de transport dédiée, spécialisée dans l'affrètement de marchandises. Elle agit comme interface opérationnelle entre vous et les transporteurs partenaires pour vous garantir le meilleur service au meilleur coût.
          </p>
          <p class="lh-desc" data-i18n="transport.partner.desc2">
            Que vous soyez chargeur ou partenaire logistique, LH Affrètement est votre levier pour optimiser vos flux, sécuriser vos opérations et accélérer vos performances — avec l'expertise terrain d'une équipe entièrement à votre service.
          </p>
          <div class="lh-kpis">
            <div class="lh-kpi">
              <span class="lh-kpi__val">24h</span>
              <span class="lh-kpi__label" data-i18n="transport.kpi.reponse">Réponse garantie</span>
            </div>
            <div class="lh-kpi lh-kpi--mid">
              <span class="lh-kpi__val">5</span>
              <span class="lh-kpi__label" data-i18n="transport.kpi.modes">Modes de transport</span>
            </div>
            <div class="lh-kpi">
              <span class="lh-kpi__val">100%</span>
              <span class="lh-kpi__label" data-i18n="transport.kpi.france">Couverture France</span>
            </div>
          </div>
        </div>

        <!-- Visuel droit -->
        <div class="lh-visuel reveal" style="transition-delay:0.12s;">
          <div class="lh-logo-card">
            <img src="/assets/lhaffretement/lh-affretement.jpeg" alt="LH Affrètement" class="lh-logo-img" />
          </div>
          <div class="lh-engagements">
            <div class="lh-eng">
              <div class="lh-eng__icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              </div>
              <span data-i18n="transport.eng.reactivite">Réactivité maximale</span>
            </div>
            <div class="lh-eng">
              <div class="lh-eng__icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93A10 10 0 0 0 4.93 19.07M4.93 4.93a10 10 0 0 0 14.14 14.14"/><path d="M12 2v4m0 12v4M2 12h4m12 0h4"/></svg>
              </div>
              <span data-i18n="transport.eng.surmesure">Solutions sur-mesure</span>
            </div>
            <div class="lh-eng">
              <div class="lh-eng__icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><circle cx="19" cy="19" r="3"/><circle cx="5" cy="19" r="3"/><path d="M12 8v3m-4.5 5.2L12 11m4.5 5.2L12 11"/></svg>
              </div>
              <span data-i18n="transport.eng.reseau">Réseau solide & performant</span>
            </div>
            <div class="lh-eng">
              <div class="lh-eng__icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </div>
              <span data-i18n="transport.eng.interlocuteur">Interlocuteur unique</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES TRANSPORT — CAROUSEL -->
  <section class="section section--gris transport-services-section">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:2.8rem;">
        <p class="eyebrow-rouge" data-i18n="transport.services.eyebrow">Nos services</p>
        <h2 class="titre-section" data-i18n-html="transport.services.title">Des solutions pour <span>chaque besoin</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0;" data-i18n="transport.services.subtitle">
          De l'affrètement routier à la gestion d'urgences, nous couvrons l'ensemble des modes de transport pour répondre à vos exigences les plus pointues.
        </p>
      </div>

      <!-- Carousel track -->
      <div class="svc-carousel-outer reveal">
        <div class="svc-carousel-track" id="svcTrack">

          <!-- Transport Routier -->
          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.routier.title">Transport Routier</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.routier.desc">Fret conventionnel, camion complet (FTL) ou groupage (LTL) — notre réseau couvre toute la France depuis Le Havre.</p>
          </div>

          <!-- Transport Maritime -->
          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 17h18M12 3 4 9v8h16V9z"/><path d="M12 3v6M8 9h8"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.maritime.title">Transport Maritime</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.maritime.desc">Coordination du fret maritime en partenariat avec les armateurs — import, export et transbordement depuis le port du Havre.</p>
          </div>

          <!-- Transport Aérien -->
          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.8 19.2 16 11l3.5-3.5C21 6 21 4 19 4s-2 1-3.5 2.5L9 4 4.8 6.2l7 3.5-2.6 2.6L7.5 12 5 11.5l-2 2 6 3.5 3.5 2 2-2-1.5-3 2.6-2.6 3.5 7Z"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.aerien.title">Transport Aérien</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.aerien.desc">Solutions express prioritaires pour vos envois urgents ou à haute valeur ajoutée, vers toutes les destinations internationales.</p>
          </div>

          <!-- Ferroviaire & Fluvial -->
          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="3" width="16" height="14" rx="2"/><path d="M4 11h16M12 3v8M8 19l-2 2m10-2 2 2"/><circle cx="8" cy="18" r="1" fill="currentColor"/><circle cx="16" cy="18" r="1" fill="currentColor"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.ferroviaire.title">Ferroviaire & Fluvial</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.ferroviaire.desc">Solutions intermodales combinant rail et voie d'eau pour une logistique durable, économique et adaptée aux grands volumes.</p>
          </div>

          <!-- Affrètement Dédié -->
          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.affretement.title">Affrètement Sur-Mesure</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.affretement.desc">Véhicule entier dédié ou groupage optimisé — nous concevons la solution la plus adaptée à chaque flux et chaque contrainte.</p>
          </div>

          <!-- Gestion d'Urgences -->
          <div class="svc-card">
            <div class="svc-card__icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <h3 class="svc-card__title" data-i18n="transport.svc.urgence.title">Gestion d'Urgences</h3>
            <p class="svc-card__desc" data-i18n="transport.svc.urgence.desc">Capacité à répondre aux imprévus avec une réactivité maximale — organisation de chargements en dehors des plages habituelles.</p>
          </div>

        </div>

        <!-- Dots de navigation -->
        <div class="svc-dots" id="svcDots">
          <button class="svc-dot svc-dot--active" data-idx="0" aria-label="Page 1"></button>
          <button class="svc-dot" data-idx="1" aria-label="Page 2"></button>
        </div>
      </div>
    </div>
  </section>

  <!-- CARTE FRANCE — DÉLAIS DE LIVRAISON -->
  <section class="section carte-transport">
    <div class="tooltip-map" id="tooltip-map">
      <span id="tt-map-nom"></span><span id="tt-map-j"></span>
    </div>
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:2.8rem;">
        <p class="eyebrow-rouge" data-i18n="transport.map.eyebrow">Couverture nationale</p>
        <h2 class="titre-section" data-i18n-html="transport.map.title">Délais de livraison <span>depuis Le Havre</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0;" data-i18n="transport.map.subtitle">
          Estimations indicatives · Hors week-ends et jours fériés
        </p>
      </div>

      <div class="carte-transport__inner reveal">
        <!-- SVG Map -->
        <div class="carte-transport__map">
          <svg id="map-transport" viewBox="0 0 500 520"></svg>
        </div>

        <!-- Légende -->
        <div class="carte-transport__legende">
          <span class="legende-titre" data-i18n="transport.map.legend">Délais estimés</span>

          <div class="legende-item">
            <div class="legende-couleur" style="background:#22c55e;"></div>
            <div>
              <div class="legende-delai">J + 1</div>
              <div class="legende-zones">Normandie · Île-de-France<br>Hauts-de-France</div>
            </div>
          </div>
          <div class="legende-item">
            <div class="legende-couleur" style="background:#eab308;"></div>
            <div>
              <div class="legende-delai">J + 2</div>
              <div class="legende-zones">Bretagne · Centre · Grand Est<br>Pays de la Loire · Bourgogne</div>
            </div>
          </div>
          <div class="legende-item">
            <div class="legende-couleur" style="background:#f97316;"></div>
            <div>
              <div class="legende-delai">J + 3</div>
              <div class="legende-zones">Nouvelle-Aquitaine<br>Auvergne-Rhône-Alpes</div>
            </div>
          </div>
          <div class="legende-item">
            <div class="legende-couleur" style="background:#e30613;"></div>
            <div>
              <div class="legende-delai">J + 4</div>
              <div class="legende-zones">Occitanie · PACA · Corse</div>
            </div>
          </div>

          <p class="carte-note" data-i18n="transport.map.note">Délais indicatifs pour livraisons en palettes depuis Le Havre, sur route.</p>
          <a href="/devis" class="btn-carte-devis" data-i18n="transport.map.cta">Demander un devis transport</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--gris cta-section-transport">
    <div class="container" style="text-align:center;">
      <div class="reveal">
        <p class="eyebrow-rouge" data-i18n="transport.cta.eyebrow">Prêt à expédier ?</p>
        <h2 class="titre-section" data-i18n-html="transport.cta.title">Un besoin transport&nbsp;?<br><span>Contactez LH Affrètement.</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0; max-width:560px;" data-i18n="transport.cta.subtitle">
          Notre équipe analyse votre besoin et vous propose la solution la plus adaptée — camion complet, groupage, ou affrètement multimodal.
        </p>
        <div class="cta-btns">
          <a href="/contact" class="btn-cta-rouge" data-i18n="transport.cta.contact">Nous contacter</a>
          <a href="/devis" class="btn-cta-outline" data-i18n="transport.cta.devis">Demander un devis</a>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<!-- D3.js local -->
<script src="/assets/d3.min.js" is:inline></script>

<!-- Carte interactive -->
<script is:inline>
(function() {
  var delais = {
    '76':1,'27':1,'14':1,'61':1,'50':1,'75':1,'77':1,'78':1,'91':1,'92':1,'93':1,'94':1,'95':1,'59':1,'62':1,'02':1,'60':1,'80':1,
    '29':2,'35':2,'22':2,'56':2,'44':2,'49':2,'72':2,'53':2,'85':2,'28':2,'37':2,'41':2,'45':2,'18':2,'36':2,'23':2,
    '57':2,'67':2,'68':2,'54':2,'55':2,'88':2,'08':2,'51':2,'10':2,'52':2,'70':2,'90':2,'25':2,'39':2,'21':2,'71':2,'58':2,'89':2,
    '86':3,'87':3,'19':3,'79':3,'16':3,'17':3,'24':3,'33':3,'40':3,'47':3,'64':3,
    '03':3,'63':3,'43':3,'42':3,'69':3,'01':3,'38':3,'26':3,'07':3,'74':3,'73':3,
    '09':4,'11':4,'12':4,'30':4,'31':4,'32':4,'34':4,'46':4,'48':4,'65':4,'66':4,'81':4,'82':4,
    '04':4,'05':4,'06':4,'13':4,'83':4,'84':4,'2A':4,'2B':4
  };
  var colorMap = ['','#22c55e','#eab308','#f97316','#e30613'];
  var labels   = ['','J+1','J+2','J+3','J+4'];
  var w = 500, h = 520;

  var svg     = d3.select('#map-transport');
  var tooltip = document.getElementById('tooltip-map');
  var ttNom   = document.getElementById('tt-map-nom');
  var ttJ     = document.getElementById('tt-map-j');

  if (!svg.node()) return;

  fetch('/assets/departements.geojson')
    .then(function(r){ return r.json(); })
    .then(function(geo) {
      var projection = d3.geoConicConformal()
        .center([2.454071, 46.279229])
        .parallels([44, 49]);
      var path = d3.geoPath().projection(projection);
      projection.fitSize([w, h], { type: 'FeatureCollection', features: geo.features });

      // Groupes (chemins en dessous des labels)
      var gPaths  = svg.append('g').attr('class', 'g-paths');
      var gLabels = svg.append('g').attr('class', 'g-labels');

      gPaths.selectAll('path')
        .data(geo.features)
        .enter().append('path')
        .attr('d', path)
        .attr('stroke', 'white')
        .attr('stroke-width', 0.9)
        .style('fill', function(d){ return colorMap[delais[d.properties.code] || 2]; })
        .style('cursor', 'pointer')
        .on('mouseover', function(event, d) {
          var centroid = path.centroid(d);
          var cx = centroid[0], cy = centroid[1];
          d3.select(this)
            .raise()
            .transition().duration(160).ease(d3.easeCubicOut)
            .attr('stroke', '#fff')
            .attr('stroke-width', 2)
            .attr('transform', 'translate('+cx+','+cy+') scale(1.13) translate('+(-cx)+','+(-cy)+')');

          // Label nom sur la carte
          gLabels.select('.hover-label').remove();
          gLabels.append('text')
            .attr('class', 'hover-label')
            .attr('x', cx).attr('y', cy - 14)
            .attr('text-anchor', 'middle')
            .attr('font-size', '11').attr('font-weight', '700')
            .attr('fill', '#1d1d1f')
            .attr('font-family', '-apple-system, BlinkMacSystemFont, Inter, sans-serif')
            .attr('pointer-events', 'none')
            .style('filter', 'drop-shadow(0 1px 3px rgba(255,255,255,0.95))')
            .text(d.properties.nom);

          // Tooltip
          var j = delais[d.properties.code] || 2;
          tooltip.style.opacity = '1';
          tooltip.style.left    = (event.clientX + 14) + 'px';
          tooltip.style.top     = (event.clientY - 10) + 'px';
          ttNom.textContent = d.properties.nom + ' (' + d.properties.code + ')';
          ttJ.textContent   = ' · ' + labels[j];
        })
        .on('mousemove', function(event) {
          tooltip.style.left = (event.clientX + 14) + 'px';
          tooltip.style.top  = (event.clientY - 10) + 'px';
        })
        .on('mouseleave', function() {
          d3.select(this)
            .transition().duration(200).ease(d3.easeCubicOut)
            .attr('stroke', 'white').attr('stroke-width', 0.9)
            .attr('transform', null);
          gLabels.select('.hover-label').transition().duration(120).style('opacity', 0).remove();
          tooltip.style.opacity = '0';
        });

      // Numéros de département
      gLabels.selectAll('text.dept-num')
        .data(geo.features)
        .enter().append('text')
        .attr('class', 'dept-num')
        .attr('x', function(d){ return path.centroid(d)[0]; })
        .attr('y', function(d){ return path.centroid(d)[1] + 1; })
        .attr('text-anchor', 'middle').attr('dominant-baseline', 'middle')
        .attr('font-size', '6.5').attr('font-weight', '700')
        .attr('fill', 'rgba(255,255,255,0.9)')
        .attr('pointer-events', 'none')
        .attr('font-family', '-apple-system, BlinkMacSystemFont, Inter, sans-serif')
        .text(function(d){ return d.properties.code; });

      // Marqueur Le Havre
      var lhCoords = projection([0.1074, 49.4944]);
      var lx = lhCoords[0], ly = lhCoords[1];
      svg.append('circle').attr('cx', lx).attr('cy', ly).attr('r', 6)
        .attr('fill', '#e30613').attr('stroke', 'white').attr('stroke-width', 1.5);
      svg.append('text').attr('x', lx+9).attr('y', ly+4)
        .attr('font-size','10').attr('font-weight','700')
        .attr('fill','#1d1d1f').attr('font-family','sans-serif').text('Le Havre');
    });

  // ── Carousel navigation ──────────────────────────────
  var track  = document.getElementById('svcTrack');
  var dots   = document.querySelectorAll('.svc-dot');
  if (track && dots.length) {
    var cards  = track.querySelectorAll('.svc-card');
    var perView = 3;

    function scrollToPage(idx) {
      var cardW = cards[0].getBoundingClientRect().width;
      var gap   = parseInt(getComputedStyle(track).gap) || 24;
      track.scrollTo({ left: idx * perView * (cardW + gap), behavior: 'smooth' });
      dots.forEach(function(d, i){ d.classList.toggle('svc-dot--active', i === idx); });
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        scrollToPage(parseInt(dot.getAttribute('data-idx')));
      });
    });

    // Sync dots on scroll
    track.addEventListener('scroll', function() {
      if (!cards[0]) return;
      var cardW = cards[0].getBoundingClientRect().width;
      var gap   = parseInt(getComputedStyle(track).gap) || 24;
      var idx   = Math.round(track.scrollLeft / (perView * (cardW + gap)));
      dots.forEach(function(d, i){ d.classList.toggle('svc-dot--active', i === idx); });
    }, { passive: true });
  }
})();
</script>

<style>
  /* ── HERO ─────────────────────────────────────────── */
  .transport-hero {
    background: linear-gradient(160deg, var(--gris-clair) 0%, #fff 60%);
    padding: 5rem 0 4.5rem;
    text-align: center;
  }

  .hero-lh-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.4rem;
    padding: 0.5rem 1.2rem;
    background: white;
    border: 1px solid rgba(0,0,0,0.09);
    border-radius: 2rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
  }

  .hero-lh-logo {
    height: 36px;
    width: auto;
    object-fit: contain;
    border-radius: 0 !important;
    mix-blend-mode: multiply;
  }

  /* ── LH PRÉSENTATION ─────────────────────────────── */
  .lh-section { background: white; }

  .lh-grid {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 5rem;
    align-items: center;
  }

  .lh-desc {
    font-size: 1.08rem;
    color: var(--gris-moyen);
    line-height: 1.75;
    margin-top: 1rem;
  }

  .lh-kpis {
    display: flex;
