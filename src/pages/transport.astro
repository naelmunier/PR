---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Transport"
  description="LH Affrètement, notre entreprise de transport dédiée depuis Le Havre. Transport routier, maritime, aérien, ferroviaire et affrètement sur-mesure partout en France."
  canonicalPath="/transport"
>

  <!-- ═══ 1. HERO ═══════════════════════════════════════════════ -->
  <section class="page-hero transport-hero">
    <div class="container page-hero__inner">
      <img
        src="/assets/lhaffretement/lh-affretement.jpeg"
        alt="LH Affrètement"
        class="hero-lh-grande animate-in"
      />
      <h1 class="titre-section animate-in" style="animation-delay:0.1s;" data-i18n-html="transport.hero.title">
        LH <span>Affrètement</span>
      </h1>
      <p class="sous-titre animate-in" style="animation-delay:0.2s; margin:1rem auto 0; max-width:660px;" data-i18n="transport.partner.desc1">
        LH Affrètement est notre entreprise de transport dédiée, spécialisée dans l'affrètement de marchandises. Elle agit comme interface opérationnelle entre vous et les transporteurs partenaires pour vous garantir le meilleur service au meilleur coût.
      </p>
    </div>
  </section>

  <!-- ═══ 2. EN QUELQUES MOTS ════════════════════════════════════ -->
  <section class="section section--gris lh-mots-section">
    <div class="container">
      <div class="atouts-bloc reveal">
        <div class="atouts-header">
          <h2 class="atouts-section-titre" data-i18n="transport.mots.eyebrow">En quelques mots…</h2>
        </div>
        <div class="atouts-grid">

          <div class="atout-card reveal" style="transition-delay:0.05s;">
            <div class="atout-card__icon">
              <img src="/assets/lhaffretement/réactivité.png" alt="Réactivité" />
            </div>
            <h3 class="atout-card__title" data-i18n="transport.eng.reactivite">Réactivité maximale</h3>
            <p class="atout-card__desc" data-i18n="transport.atout.reactivite.desc">Disponibilité et rapidité de réponse dans toutes les situations — même les plus urgentes.</p>
          </div>

          <div class="atout-card reveal" style="transition-delay:0.12s;">
            <div class="atout-card__icon">
              <img src="/assets/lhaffretement/sur-mesure.png" alt="Sur-mesure" />
            </div>
            <h3 class="atout-card__title" data-i18n="transport.eng.surmesure">Solutions sur-mesure</h3>
            <p class="atout-card__desc" data-i18n="transport.atout.surmesure.desc">Chaque demande est unique. Nous adaptons la solution transport à votre besoin, pas l'inverse.</p>
          </div>

          <div class="atout-card reveal" style="transition-delay:0.19s;">
            <div class="atout-card__icon">
              <img src="/assets/lhaffretement/interlocuteur-unique.png" alt="Interlocuteur unique" />
            </div>
            <h3 class="atout-card__title" data-i18n="transport.eng.interlocuteur">Interlocuteur unique</h3>
            <p class="atout-card__desc" data-i18n="transport.atout.interlocuteur.desc">Un seul contact pour l'ensemble de vos flux transport — suivi, coordination et reporting centralisés.</p>
          </div>

          <div class="atout-card reveal" style="transition-delay:0.26s;">
            <div class="atout-card__icon">
              <img src="/assets/lhaffretement/reseau.png" alt="Réseau" />
            </div>
            <h3 class="atout-card__title" data-i18n="transport.eng.reseau">Réseau solide & performant</h3>
            <p class="atout-card__desc" data-i18n="transport.atout.reseau.desc">Un réseau dense de transporteurs partenaires, sélectionnés pour leur fiabilité et leur expertise terrain.</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 3. MODES DE TRANSPORT — donut interactif ══════════════ -->
  <section class="section modes-section" id="modesSection">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:2.8rem;">
        <p class="eyebrow-rouge" data-i18n="transport.services.eyebrow">Nos modes de transport</p>
        <h2 class="titre-section" data-i18n-html="transport.modes.title">Solutions <span>transport</span></h2>
        <p class="sous-titre" style="margin:0.8rem auto 0; max-width:540px;" data-i18n="transport.modes.subtitle">
          Spécialisés en routier, nous assurons tous les modes selon vos besoins — de la livraison nationale à l'affrètement international.
        </p>
      </div>

      <!-- Layout : 4 cartes aux coins, donut au centre -->
      <div class="modes-outer reveal">

        <div class="mode-cards-grid">

          <div class="mode-card mode-card--routier corner-br" data-mode="routier">
            <div class="mode-card__icon-wrap" style="background:rgba(227,6,19,0.08);">
              <img src="/assets/lhaffretement/camion.gif" alt="Transport Routier" class="mode-card__gif" />
            </div>
            <div class="mode-card__content">
              <h3 class="mode-card__title" data-i18n="transport.svc.routier.title">Transport Routier</h3>
              <p class="mode-card__tag" data-i18n="transport.mode.routier.detail">FTL · LTL · Groupage</p>
              <p class="mode-card__text" data-i18n="transport.svc.routier.desc">Fret conventionnel, camion complet (FTL) ou groupage (LTL) — notre réseau couvre toute la France depuis Le Havre.</p>
            </div>
          </div>

          <div class="mode-card mode-card--maritime corner-bl" data-mode="maritime">
            <div class="mode-card__icon-wrap" style="background:rgba(127,29,29,0.08);">
              <img src="/assets/lhaffretement/maritime.gif" alt="Transport Maritime" class="mode-card__gif" />
            </div>
            <div class="mode-card__content">
              <h3 class="mode-card__title" data-i18n="transport.svc.maritime.title">Transport Maritime</h3>
              <p class="mode-card__tag" data-i18n="transport.mode.maritime.detail">Import · Export · FCL/LCL</p>
              <p class="mode-card__text" data-i18n="transport.svc.maritime.desc">Coordination du fret maritime en partenariat avec les armateurs — import, export et transbordement depuis le port du Havre.</p>
            </div>
          </div>

          <div class="mode-card mode-card--aerien corner-tr" data-mode="aerien">
            <div class="mode-card__icon-wrap" style="background:rgba(239,68,68,0.08);">
              <img src="/assets/lhaffretement/aerien.gif" alt="Transport Aérien" class="mode-card__gif" />
            </div>
            <div class="mode-card__content">
              <h3 class="mode-card__title" data-i18n="transport.svc.aerien.title">Transport Aérien</h3>
              <p class="mode-card__tag" data-i18n="transport.mode.aerien.detail">Express · International</p>
              <p class="mode-card__text" data-i18n="transport.svc.aerien.desc">Solutions express prioritaires pour vos envois urgents ou à haute valeur ajoutée, vers toutes les destinations internationales.</p>
            </div>
          </div>

          <div class="mode-card mode-card--rail corner-tl" data-mode="rail">
            <div class="mode-card__icon-wrap" style="background:rgba(185,28,28,0.08);">
              <img src="/assets/lhaffretement/train.gif" alt="Ferroviaire" class="mode-card__gif" />
            </div>
            <div class="mode-card__content">
              <h3 class="mode-card__title" data-i18n="transport.svc.ferroviaire.title">Ferroviaire & Fluvial</h3>
              <p class="mode-card__tag" data-i18n="transport.mode.rail.detail">Intermodal · Massifié</p>
              <p class="mode-card__text" data-i18n="transport.svc.ferroviaire.desc">Solutions intermodales combinant rail et voie d'eau pour une logistique durable, économique et adaptée aux grands volumes.</p>
            </div>
          </div>

        </div>

        <!-- Donut centré entre les 4 cartes -->
        <div class="modes-donut-center">
          <svg class="modes-donut" viewBox="0 0 160 160" aria-hidden="true">
            <circle cx="80" cy="80" r="60" fill="none" stroke="rgba(240,240,245,0.9)" stroke-width="26"/>
            <circle class="donut-seg donut-seg--routier" cx="80" cy="80" r="60"
              fill="none" stroke="#e30613" stroke-width="26" stroke-linecap="butt"
              style="transform:rotate(-90deg); transform-origin:80px 80px;"/>
            <circle class="donut-seg donut-seg--maritime" cx="80" cy="80" r="60"
              fill="none" stroke="#7f1d1d" stroke-width="24" stroke-linecap="butt"
              style="transform:rotate(216deg); transform-origin:80px 80px;"/>
            <circle class="donut-seg donut-seg--aerien" cx="80" cy="80" r="60"
              fill="none" stroke="#ef4444" stroke-width="24" stroke-linecap="butt"
              style="transform:rotate(244.8deg); transform-origin:80px 80px;"/>
            <circle class="donut-seg donut-seg--rail" cx="80" cy="80" r="60"
              fill="none" stroke="#b91c1c" stroke-width="24" stroke-linecap="butt"
              style="transform:rotate(259.2deg); transform-origin:80px 80px;"/>
            <circle cx="80" cy="80" r="41" fill="white"/>
            <text id="donut-center-label" x="80" y="77"
              text-anchor="middle" font-size="9.5" font-weight="700" fill="#e30613"
              font-family="-apple-system, BlinkMacSystemFont, Inter, sans-serif"></text>
            <text id="donut-sub-label" x="80" y="89"
              text-anchor="middle" font-size="7" fill="#8e8e93"
              font-family="-apple-system, BlinkMacSystemFont, Inter, sans-serif"></text>
          </svg>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ 4. CARTE FRANCE ═══════════════════════════════════════ -->
  <section class="section carte-transport">
    <div class="tooltip-map" id="tooltip-map">
      <div class="tt-nom" id="tt-map-nom"></div>
      <div class="tt-delai" id="tt-map-j"></div>
    </div>
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:2.8rem;">
        <p class="eyebrow-rouge" data-i18n="transport.map.eyebrow">Couverture nationale</p>
        <h2 class="titre-section" data-i18n-html="transport.map.title">Délais de livraison <span>en France</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0;" data-i18n="transport.map.subtitle">
          Estimations indicatives · Hors week-ends et jours fériés
        </p>
      </div>

      <div class="carte-transport__inner reveal">
        <div class="carte-transport__map">
          <svg id="map-transport" viewBox="0 0 500 520"></svg>
        </div>

        <div class="carte-sidebar">
          <!-- Encadré IDF -->
          <div class="idf-inset">
            <div class="idf-inset__header">
              <span class="idf-inset__title">Île-de-France</span>
              <span class="idf-inset__badge">24h</span>
            </div>
            <svg id="map-idf" viewBox="0 0 220 200"></svg>
          </div>

          <!-- Légende -->
          <div class="carte-transport__legende">
            <span class="legende-titre" data-i18n="transport.map.legend">Délais estimés</span>

            <div class="legende-item">
              <div class="legende-couleur" style="background:#4ade80;"></div>
              <div class="legende-delai">24h</div>
            </div>
            <div class="legende-item">
              <div class="legende-couleur" style="background:#fbbf24;"></div>
              <div class="legende-delai">48h</div>
            </div>
            <div class="legende-item">
              <div class="legende-couleur" style="background:#f97316;"></div>
              <div class="legende-delai">72h</div>
            </div>
            <div class="legende-item">
              <div class="legende-couleur" style="background:#e30613;"></div>
              <div class="legende-delai">96h</div>
            </div>

            <div class="legende-plateforme">
              <img src="/assets/lhaffretement/palteforme.gif" alt="Plateforme" width="16" height="16" class="plateforme-gif" />
              <span data-i18n="transport.map.plateforme">Présence d'une plateforme logistique</span>
            </div>

            <p class="carte-note" data-i18n="transport.map.note">Délais indicatifs pour livraisons en palettes, sur route.</p>
            <a href="/devis" class="btn-carte-devis" data-i18n="transport.map.cta">Demander un devis transport</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 5. CTA ════════════════════════════════════════════════ -->
  <section class="section section--gris cta-section-transport">
    <div class="container" style="text-align:center;">
      <div class="reveal">
        <p class="eyebrow-rouge" data-i18n="transport.cta.eyebrow">Prêt à expédier ?</p>
        <h2 class="titre-section" data-i18n-html="transport.cta.title">Un besoin transport&nbsp;?<br><span>Contactez LH Affrètement.</span></h2>
        <p class="sous-titre" style="margin:1rem auto 0; max-width:560px;" data-i18n="transport.cta.subtitle">
          Notre équipe analyse votre besoin et vous propose la solution la plus adaptée — camion complet, groupage, ou affrètement multimodal.
        </p>
        <div class="cta-btns">
          <a href="/contact" class="btn-cta-rouge" data-i18n="transport.cta.contact">Nous contacter</a>
          <a href="/devis" class="btn-cta-outline" data-i18n="transport.cta.devis">Demander un devis</a>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<!-- D3.js local -->
<script src="/assets/d3.min.js" is:inline></script>

<script is:inline>
(function () {

  /* ── Donut + Mode Cards interaction ────────────────────────── */
  var C = 2 * Math.PI * 60; // ≈ 376.99

  function animateModes() {
    var targets = [
      { sel: '.donut-seg--routier',  len: C * 0.85 },
      { sel: '.donut-seg--maritime', len: C * 0.08 },
      { sel: '.donut-seg--aerien',   len: C * 0.04 },
      { sel: '.donut-seg--rail',     len: C * 0.03 },
    ];
    targets.forEach(function (t) {
      var el = document.querySelector(t.sel);
      if (el) el.style.strokeDasharray = t.len.toFixed(1) + ' ' + C.toFixed(1);
    });
  }

  var modesSection = document.getElementById('modesSection');
  if (modesSection) {
    var modesObs = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        setTimeout(animateModes, 200);
        modesObs.disconnect();
      }
    }, { threshold: 0.25 });
    modesObs.observe(modesSection);
  }

  // Interaction cartes ↔ donut
  var allSegs   = document.querySelectorAll('.donut-seg');
  var modeCards = document.querySelectorAll('.mode-card');
  var centerLabel  = document.getElementById('donut-center-label');
  var donutSubLabel = document.getElementById('donut-sub-label');

  var segMap = {
    routier:  '.donut-seg--routier',
    maritime: '.donut-seg--maritime',
    aerien:   '.donut-seg--aerien',
    rail:     '.donut-seg--rail'
  };
  var labelMap2 = { routier:'Routier', maritime:'Maritime', aerien:'Aérien', rail:'Ferroviaire' };
  var tagMap    = {
    routier:  'FTL · LTL · Groupage',
    maritime: 'Import · Export · FCL/LCL',
    aerien:   'Express · International',
    rail:     'Intermodal · Massifié'
  };

  function setDonutDefault() {
    allSegs.forEach(function(s) { s.style.opacity = '1'; });
    if (centerLabel)   centerLabel.textContent   = '';
    if (donutSubLabel) donutSubLabel.textContent = '';
  }
  setDonutDefault();

  modeCards.forEach(function (card) {
    card.addEventListener('mouseenter', function () {
      var mode = card.getAttribute('data-mode');
      allSegs.forEach(function (s) { s.style.opacity = '0.15'; });
      var active = document.querySelector(segMap[mode]);
      if (active) active.style.opacity = '1';
      if (centerLabel)   centerLabel.textContent   = labelMap2[mode] || '';
      if (donutSubLabel) donutSubLabel.textContent = tagMap[mode] || '';
      modeCards.forEach(function (c) { c.classList.toggle('mode-card--active', c === card); });
    });
    card.addEventListener('mouseleave', function () {
      setDonutDefault();
      card.classList.remove('mode-card--active');
    });
  });

  /* ── Carte France ─────────────────────────────────────────── */
  var delais = {
    '01':2,'02':1,'03':1,'04':2,'05':2,'06':2,'07':2,'08':1,'09':2,'10':1,
    '11':2,'12':3,'13':2,'14':1,'15':2,'16':1,'17':1,'18':1,'19':1,
    '21':1,'22':2,
    '23':1,'24':1,'25':2,'26':2,'27':1,'28':1,'29':2,
    '30':2,'31':2,'32':2,'33':2,'34':2,'35':1,'36':1,'37':1,'38':2,'39':2,
    '40':2,'41':1,'42':2,'43':2,'44':1,'45':1,'46':3,'47':2,'48':3,'49':1,
    '50':2,'51':1,'52':1,'53':1,'54':2,'55':2,'56':2,'57':2,'58':1,'59':1,
    '60':1,'61':1,'62':1,'63':1,'64':2,'65':2,'66':2,'67':2,'68':2,'69':2,
    '70':2,'71':1,'72':1,'73':2,'74':2,'75':1,'76':1,'77':1,'78':1,'79':1,
    '80':1,'81':2,'82':2,'83':2,'84':2,'85':1,'86':1,'87':1,'88':2,'89':1,
    '90':2,'91':1,'92':1,'93':1,'94':1,'95':1
  };

  // Couleurs distinctes : vert → jaune → orange → rouge (site)
  var colorMap    = ['', '#4ade80', '#fbbf24', '#f97316', '#e30613'];
  // Faisceaux : version plus lumineuse de la couleur du département
  var beamColorMap = ['', 'rgba(134,239,172,0.9)', 'rgba(253,224,71,0.9)', 'rgba(251,146,60,0.9)', 'rgba(252,165,165,0.9)'];
  var labelMap = ['', '24h', '48h', '72h', '96h'];

  // Départements bicolores : c1 = début (0%), c2 = fin (100%)
  // horiz:true = ouest→est, horiz:false = nord→sud
  var bicolore = {
    '22': { horiz: true,  c1: 2, c2: 1, tooltip: '48h (Ouest) / 24h (Est)' },
    '48': { horiz: false, c1: 3, c2: 4, tooltip: '72h (Nord) / 96h (Sud)' },
    '07': { horiz: false, c1: 2, c2: 3, tooltip: '48h (Nord) / 72h (Sud)' },
    '66': { horiz: false, c1: 2, c2: 3, tooltip: '48h (Nord) / 72h (Sud)' },
    '26': { horiz: false, c1: 2, c2: 3, tooltip: '48h (Nord) / 72h (Sud)' },
    '46': { horiz: false, c1: 3, c2: 2, tooltip: '72h (Nord) / 48h (Sud)' }
  };

  var plateformes = ['47', '69', '54'];
  var w = 500, h = 520;

  var svg     = d3.select('#map-transport');
  var tooltip = document.getElementById('tooltip-map');
  var ttNom   = document.getElementById('tt-map-nom');
  var ttJ     = document.getElementById('tt-map-j');

  if (!svg.node()) return;

  fetch('/assets/departements.geojson')
    .then(function (r) { return r.json(); })
    .then(function (geo) {
      var projection = d3.geoConicConformal()
        .center([2.454071, 46.279229])
        .parallels([44, 49]);
      var path = d3.geoPath().projection(projection);

      // ── Filtrage : exclure la Corse ──
      var features = geo.features.filter(function (f) {
        var c = f.properties.code;
        return c !== '2A' && c !== '2B';
      });

      var defs = svg.append('defs');

      // ── Gradients bicolores ──
      Object.keys(bicolore).forEach(function (code) {
        var b = bicolore[code];
        var g = defs.append('linearGradient')
          .attr('id', 'grad-' + code)
          .attr('x1', b.horiz ? '0%' : '0%')
          .attr('y1', b.horiz ? '0%' : '0%')
          .attr('x2', b.horiz ? '100%' : '0%')
          .attr('y2', b.horiz ? '0%' : '100%');
        g.append('stop').attr('offset', '0%').attr('stop-color', colorMap[b.c1]);
        g.append('stop').attr('offset', '100%').attr('stop-color', colorMap[b.c2]);
      });

      // Projection ajustée sur la France métropolitaine uniquement
      projection.fitSize([w, h], { type: 'FeatureCollection', features: features });

      var gPaths  = svg.append('g').attr('class', 'g-paths');
      var gBeams  = svg.append('g').attr('class', 'g-beams');
      var gLabels = svg.append('g').attr('class', 'g-labels');

      // ── Chemins des départements ──
      gPaths.selectAll('path')
        .data(features)
        .enter().append('path')
        .attr('d', path)
        .attr('stroke', 'rgba(255,255,255,0.7)')
        .attr('stroke-width', 1)
        .style('fill', function (d) {
          var code = d.properties.code;
          if (bicolore[code]) return 'url(#grad-' + code + ')';
          return colorMap[delais[code] || 2];
        })
        .style('cursor', 'pointer')
        .on('mouseover', function (event, d) {
          var centroid = path.centroid(d);
          var cx = centroid[0], cy = centroid[1];
          d3.select(this).raise()
            .transition().duration(160).ease(d3.easeCubicOut)
            .attr('stroke', '#fff').attr('stroke-width', 2)
            .attr('transform', 'translate(' + cx + ',' + cy + ') scale(1.12) translate(' + (-cx) + ',' + (-cy) + ')');

          gLabels.select('.hover-label').remove();
          gLabels.append('text')
            .attr('class', 'hover-label')
            .attr('x', cx).attr('y', cy - 14)
            .attr('text-anchor', 'middle').attr('font-size', '11').attr('font-weight', '700')
            .attr('fill', '#1d1d1f')
            .attr('font-family', '-apple-system, BlinkMacSystemFont, Inter, sans-serif')
            .attr('pointer-events', 'none')
            .style('filter', 'drop-shadow(0 1px 3px rgba(255,255,255,0.95))')
            .text(d.properties.nom);

          var code = d.properties.code;
          var jVal = bicolore[code]
            ? bicolore[code].tooltip
            : (labelMap[delais[code]] || '48h');
          var lvl  = bicolore[code] ? bicolore[code].c1 : (delais[code] || 2);

          tooltip.style.opacity     = '1';
          tooltip.style.left        = (event.clientX + 16) + 'px';
          tooltip.style.top         = (event.clientY - 14) + 'px';
          tooltip.style.borderLeftColor = colorMap[lvl] || '#fbbf24';
          ttNom.textContent = d.properties.nom + ' (' + code + ')';
          ttJ.textContent   = jVal;
        })
        .on('mousemove', function (event) {
          tooltip.style.left = (event.clientX + 14) + 'px';
          tooltip.style.top  = (event.clientY - 10) + 'px';
        })
        .on('mouseleave', function () {
          d3.select(this)
            .transition().duration(200).ease(d3.easeCubicOut)
            .attr('stroke', 'rgba(255,255,255,0.7)').attr('stroke-width', 1)
            .attr('transform', null);
          gLabels.select('.hover-label').transition().duration(120).style('opacity', 0).remove();
          tooltip.style.opacity = '0';
        });

      // ── Faisceaux — paths réels des bordures géo ──
      // Chaque route est une suite de codes de depts contigus.
      // On concatène les paths SVG réels de chaque dept pour que
      // le faisceau se déplace sur leurs bordures géographiques.
      var beamSeqs = [
        { codes: ['76','27','28','45','18','03','63','69','26','13'], dur: 6.0, delay: 0 },
        { codes: ['76','14','61','35','44','85','17','33'],           dur: 5.0, delay: -2.0 },
        { codes: ['76','80','02','51','54','57','67'],                dur: 4.5, delay: -3.5 },
        { codes: ['76','60','77','89','21','71','42','31'],           dur: 6.5, delay: -1.5 },
        { codes: ['29','22','56','44','49','37','86','63','43','12','34','06'], dur: 8.0, delay: -5.0 },
      ];

      beamSeqs.forEach(function(route) {
        // Concaténation des paths SVG réels de chaque département
        var d = route.codes.map(function(code) {
          var feat = features.find(function(f) { return f.properties.code === code; });
          return feat ? path(feat) : null;
        }).filter(Boolean).join(' ');

        if (!d) return;
        var el = gBeams.append('path')
          .attr('d', d)
          .attr('fill', 'none').attr('pointer-events', 'none').node();
        var len = el.getTotalLength ? el.getTotalLength() : 2000;
        el.style.stroke           = 'rgba(227,6,19,0.75)';
        el.style.strokeWidth      = '1.2';
        el.style.strokeLinecap    = 'round';
        el.style.strokeDasharray  = '20 ' + (len + 30);
        el.style.strokeDashoffset = '20';
        el.style.animation = 'beam-cross ' + route.dur.toFixed(1) + 's ' + route.delay.toFixed(1) + 's linear infinite';
      });

      // ── Numéros de département ──
      gLabels.selectAll('text.dept-num')
        .data(features)
        .enter().append('text')
        .attr('class', 'dept-num')
        .attr('x', function (d) { return path.centroid(d)[0]; })
        .attr('y', function (d) { return path.centroid(d)[1] + 1; })
        .attr('text-anchor', 'middle').attr('dominant-baseline', 'middle')
        .attr('font-size', '6.5').attr('font-weight', '700')
        .attr('fill', 'rgba(255,255,255,0.92)').attr('pointer-events', 'none')
        .attr('font-family', '-apple-system, BlinkMacSystemFont, Inter, sans-serif')
        .text(function (d) { return d.properties.code; });

      // ── Icônes Plateforme ──
      plateformes.forEach(function (code) {
        var feat = features.find(function (f) { return f.properties.code === code; });
        if (!feat) return;
        var c = path.centroid(feat);
        svg.append('g')
          .attr('transform', 'translate(' + (c[0] - 8) + ',' + (c[1] + 6) + ')')
          .attr('pointer-events', 'none')
          .append('image')
          .attr('href', '/assets/lhaffretement/palteforme.gif')
          .attr('width', 16).attr('height', 16)
          .attr('x', 0).attr('y', 0)
          .style('mix-blend-mode', 'multiply');
      });

      // ── Marqueur Le Havre ──
      var lh = projection([0.1074, 49.4944]);
      svg.append('circle').attr('cx', lh[0]).attr('cy', lh[1]).attr('r', 6)
        .attr('fill', '#e30613').attr('stroke', 'white').attr('stroke-width', 1.5);
      svg.append('text').attr('x', lh[0] + 9).attr('y', lh[1] + 4)
        .attr('font-size', '10').attr('font-weight', '700')
        .attr('fill', '#1d1d1f').attr('font-family', 'sans-serif').text('Le Havre');

      // ── Mini-carte Île-de-France ──
      var idfCodes = ['75','77','78','91','92','93','94','95'];
      var idfFeats = features.filter(function (f) {
        return idfCodes.indexOf(f.properties.code) !== -1;
      });
      var svgIdf = d3.select('#map-idf');
      if (svgIdf.node() && idfFeats.length) {
        var projIdf = d3.geoConicConformal().center([2.454071, 46.279229]).parallels([44, 49]);
        var pathIdf = d3.geoPath().projection(projIdf);
        projIdf.fitSize([220, 200], { type: 'FeatureCollection', features: idfFeats });

        svgIdf.selectAll('path')
          .data(idfFeats)
          .enter().append('path')
          .attr('d', pathIdf)
          .attr('stroke', 'rgba(255,255,255,0.85)')
          .attr('stroke-width', 1.2)
          .style('fill', function (d) { return colorMap[delais[d.properties.code] || 1]; })
          .style('cursor', 'pointer')
          .on('mouseover', function (event, d) {
            d3.select(this).transition().duration(120)
              .attr('stroke', '#fff').attr('stroke-width', 2)
              .style('filter', 'brightness(1.12)');
            var code = d.properties.code;
            var jVal = labelMap[delais[code]] || '24h';
            tooltip.style.opacity     = '1';
            tooltip.style.left        = (event.clientX + 16) + 'px';
            tooltip.style.top         = (event.clientY - 14) + 'px';
            tooltip.style.borderLeftColor = colorMap[delais[code] || 1];
            ttNom.textContent = d.properties.nom + ' (' + code + ')';
            ttJ.textContent   = jVal;
          })
          .on('mousemove', function (event) {
            tooltip.style.left = (event.clientX + 16) + 'px';
            tooltip.style.top  = (event.clientY - 14) + 'px';
          })
          .on('mouseleave', function () {
            d3.select(this).transition().duration(150)
              .attr('stroke', 'rgba(255,255,255,0.85)').attr('stroke-width', 1.2)
              .style('filter', null);
            tooltip.style.opacity = '0';
          });

        // Numéros + noms dans la mini-carte
        svgIdf.selectAll('text')
          .data(idfFeats)
          .enter().append('text')
          .attr('x', function (d) { return pathIdf.centroid(d)[0]; })
          .attr('y', function (d) { return pathIdf.centroid(d)[1]; })
          .attr('text-anchor', 'middle').attr('dominant-baseline', 'middle')
          .attr('font-size', '8').attr('font-weight', '700')
          .attr('fill', 'rgba(255,255,255,0.95)')
          .attr('pointer-events', 'none')
          .attr('font-family', '-apple-system, BlinkMacSystemFont, Inter, sans-serif')
          .text(function (d) { return d.properties.code; });
      }
    });

})();
</script>

