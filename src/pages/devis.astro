---

<MainLayout title="Demander un devis" description="Demandez un devis personnalisé à PR Logistics pour vos besoins de logistique et transport au Havre.">

  <!-- HERO -->
  <section class="devis-hero">
    <div class="devis-blob devis-blob--1" aria-hidden="true"></div>
    <div class="devis-blob devis-blob--2" aria-hidden="true"></div>
    <div class="container devis-hero__inner animate-in">
      <p class="eyebrow-rouge">Gratuit & sans engagement</p>
      <h1 class="titre-section">Demander un <span>devis</span></h1>
      <p class="sous-titre" style="margin:1rem auto 0; max-width:520px;">
        Remplissez le formulaire ci-dessous et notre équipe vous répond sous 24h avec une offre personnalisée.
      </p>
    </div>
  </section>

  <!-- FORMULAIRE -->
  <section class="section devis-section">
    <div class="container">
      <form class="devis-form reveal" id="devisForm" novalidate>

        <!-- ① Adresses -->
        <div class="form-bloc">
          <div class="form-bloc__titre">
            <span class="form-step">1</span>
            <h2>Adresses de transport</h2>
          </div>

          <div class="adresses-grid">
            <!-- Départ -->
            <div class="adresse-card">
              <div class="adresse-card__header adresse-card__header--neutre">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="10" r="3"/><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
                Adresse de départ
              </div>
              <div class="form-group">
                <label class="form-label" for="depart_ville">Ville</label>
                <input type="text" id="depart_ville" name="depart_ville" class="form-input" placeholder="Le Havre" required />
              </div>
              <div class="form-group">
                <label class="form-label" for="depart_dept">Département</label>
                <div class="select-wrapper">
                  <select id="depart_dept" name="depart_dept" class="form-select" required>
                    <option value="" disabled selected>Sélectionnez</option>
                    {departements.map(d => <option value={d.code}>{d.code} — {d.nom}</option>)}
                  </select>
                  <span class="select-arrow" aria-hidden="true">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                  </span>
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Pays</label>
                <input type="text" value="France" class="form-input input--disabled" disabled />
              </div>
            </div>

            <!-- Séparateur discret -->
            <div class="adresses-sep" aria-hidden="true">
              <div class="adresses-sep__dot"></div>
            </div>

            <!-- Livraison -->
            <div class="adresse-card adresse-card--livraison">
              <div class="adresse-card__header">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Adresse de livraison
              </div>
              <div class="form-group">
                <label class="form-label" for="arrivee_ville">Ville</label>
                <input type="text" id="arrivee_ville" name="arrivee_ville" class="form-input" placeholder="Paris" required />
              </div>
              <div class="form-group">
                <label class="form-label" for="arrivee_dept">Département</label>
                <div class="select-wrapper">
                  <select id="arrivee_dept" name="arrivee_dept" class="form-select" required>
                    <option value="" disabled selected>Sélectionnez</option>
                    {departements.map(d => <option value={d.code}>{d.code} — {d.nom}</option>)}
                  </select>
                  <span class="select-arrow" aria-hidden="true">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                  </span>
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Pays</label>
                <input type="text" value="France" class="form-input input--disabled" disabled />
              </div>
            </div>
          </div>
        </div>

        <!-- ② Marchandise -->
        <div class="form-bloc">
          <div class="form-bloc__titre">
            <span class="form-step">2</span>
            <h2>Détails de la marchandise</h2>
          </div>

          <div id="lotsContainer"></div>

          <button type="button" id="addLotBtn" class="btn-add-lot">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Ajouter un lot
          </button>
        </div>

        <!-- ③ Coordonnées -->
        <div class="form-bloc">
          <div class="form-bloc__titre">
            <span class="form-step">3</span>
            <h2>Vos coordonnées</h2>
          </div>

          <div class="form-row form-row--3">
            <div class="form-group">
              <label class="form-label" for="nom">
                <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Nom / Société
              </label>
              <input type="text" id="nom" name="nom" class="form-input" placeholder="PR Logistics" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="email">
                <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                Adresse e-mail
              </label>
              <input type="email" id="email" name="email" class="form-input" placeholder="contact@exemple.fr" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="telephone">
                <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                Téléphone <span class="label-optional">Optionnel</span>
              </label>
              <input type="tel" id="telephone" name="telephone" class="form-input" placeholder="06 00 00 00 00" />
            </div>
          </div>

          <div class="form-group" style="margin-top:1.2rem;">
            <label class="form-label" for="message">
              <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              Informations complémentaires <span class="label-optional">Optionnel</span>
            </label>
            <textarea id="message" name="message" class="form-input form-textarea" rows="3"
              placeholder="Marchandises dangereuses, température dirigée, délais particuliers, accès particulier…"></textarea>
          </div>
        </div>

        <!-- Pied de formulaire -->
        <div class="form-footer">
          <p class="form-footer__mention">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Vos données sont utilisées uniquement pour traiter votre demande.
          </p>
          <button type="submit" class="btn btn--rouge btn--lg" id="submitBtn">
            <span id="submitLabel">Envoyer ma demande</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          </button>
        </div>

      </form>

      <!-- Confirmation -->
      <div class="form-success" id="formSuccess" hidden>
        <div class="form-success__icon">
          <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3>Demande envoyée !</h3>
        <p>Un récapitulatif PDF a été téléchargé.<br />Notre équipe vous contactera sous 24h.</p>
        <a href="/" class="btn btn--outline" style="margin-top:1.5rem;">Retour à l'accueil</a>
      </div>
    </div>
  </section>

</MainLayout>

<script is:inline define:vars={{ departementsJson }}>
  const PR_EMAIL = 'lehavre@pr-logistics.fr';

  const DEPARTEMENTS = JSON.parse(departementsJson);

  // ── Gestion des lots ─────────────────────────────────────────
  let lots   = [];
  let nextId = 1;

  const FORMATS = [
    { val: '',        label: 'Format…' },
    { val: '120x150', label: '120 × 150 cm (Europe)' },
    { val: '130x150', label: '130 × 150 cm (Industrielle)' },
  ];

  function selectHTML(name, id) {
    const opts = FORMATS.map(f =>
      `<option value="${f.val}"${f.val === '' ? ' disabled selected' : ''}>${f.label}</option>`
    ).join('');
    return `<div class="select-wrapper">
      <select name="${name}" id="${id}" class="form-select" required>
        ${opts}
      </select>
      <span class="select-arrow" aria-hidden="true">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </div>`;
  }

  function createLotRow(id, num) {
    const div = document.createElement('div');
    div.className = 'lot-card';
    div.dataset.lotId = id;
    div.innerHTML = `
      <div class="lot-card__header">
        <div class="lot-num">Lot ${num}</div>
        <button type="button" class="btn-remove-lot" title="Supprimer ce lot">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="lot-card__fields">
        <div class="form-group">
          <label class="form-label" for="pal_${id}">Nombre de palettes</label>
          <input type="number" name="pal_${id}" id="pal_${id}" min="1" max="9999"
            class="form-input" placeholder="Ex : 5" required />
        </div>
        <div class="form-group">
          <label class="form-label" for="tai_${id}">Format palette</label>
          ${selectHTML(`tai_${id}`, `tai_${id}`)}
        </div>
        <div class="form-group lot-card__contenu">
          <label class="form-label" for="con_${id}">Contenu de la marchandise</label>
          <input type="text" name="con_${id}" id="con_${id}"
            class="form-input" placeholder="Ex : Électronique, textile, produits alimentaires…" required />
        </div>
      </div>`;

    div.querySelector('.btn-remove-lot').addEventListener('click', () => removeLot(id, div));
    return div;
  }

  function addLot() {
    const id  = nextId++;
    const num = lots.length + 1;
    lots.push(id);
    const container = document.getElementById('lotsContainer');
    container.appendChild(createLotRow(id, num));
    updateRemoveBtns();
  }

  function removeLot(id, el) {
    lots = lots.filter(l => l !== id);
    el.remove();
    updateLotNumbers();
    updateRemoveBtns();
  }

  function updateLotNumbers() {
    document.querySelectorAll('.lot-row .lot-num').forEach((el, i) => {
      el.textContent = i + 1;
    });
  }

  function updateRemoveBtns() {
    const btns = document.querySelectorAll('.btn-remove-lot');
    btns.forEach(b => { b.style.visibility = btns.length === 1 ? 'hidden' : 'visible'; });
  }

  function collectLots() {
    return lots.map(id => ({
      palettes: document.getElementById(`pal_${id}`)?.value ?? '',
      taille:   document.querySelector(`[name="tai_${id}"]`)?.value ?? '',
      contenu:  document.getElementById(`con_${id}`)?.value ?? '',
    }));
  }

  // ── Génération PDF ────────────────────────────────────────────
  function deptLabel(code) {
    const d = DEPARTEMENTS.find(d => d.code === code);
    return d ? `${d.code} — ${d.nom}` : code;
  }

  function generatePDF(data) {
    const jsPDF = window.jspdf?.jsPDF;
    if (!jsPDF) return null;

    const doc  = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
    const W    = 210;
    const RED  = [227, 6, 19];
    const DARK = [29, 29, 31];
    const MID  = [100, 100, 100];
    const LITE = [245, 245, 247];
    const ref  = 'DEV-' + Date.now().toString().slice(-6).toUpperCase();
    const date = new Date().toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });

    // ── En-tête rouge
    doc.setFillColor(...RED);
    doc.rect(0, 0, W, 40, 'F');

    doc.setTextColor(255, 255, 255);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(22);
    doc.text('PR Logistics', 18, 18);

    doc.setFontSize(10);
    doc.setFont('helvetica', 'normal');
    doc.text('Prestataire logistique & transport · Le Havre', 18, 26);
    doc.text(`Demande de devis · ${date}`, 18, 33);

    doc.setFont('helvetica', 'bold');
    doc.setFontSize(11);
    doc.text(ref, W - 18, 24, { align: 'right' });
    doc.setFontSize(8);
    doc.setFont('helvetica', 'normal');
    doc.text('Référence', W - 18, 30, { align: 'right' });

    // ── Bloc client
    let y = 50;
    doc.setFillColor(...LITE);
    doc.roundedRect(15, y, W - 30, 22, 3, 3, 'F');
    doc.setTextColor(...DARK);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(8);
    doc.text('CLIENT', 22, y + 7);
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(10);
    doc.text(data.nom, 22, y + 14);
    doc.setTextColor(...MID);
    doc.setFontSize(9);
    const contactLine = [data.email, data.telephone].filter(Boolean).join('   ·   ');
    doc.text(contactLine, 22, y + 20);

    // ── Adresses
    y += 32;
    doc.setTextColor(...DARK);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(9);
    doc.setFillColor(...RED);
    doc.rect(15, y - 1, 2, 7, 'F');
    doc.text('TRANSPORT', 20, y + 5);

    y += 12;
    const colW = (W - 46) / 2;

    // Départ
    doc.setFillColor(...LITE);
    doc.roundedRect(15, y, colW, 26, 3, 3, 'F');
    doc.setTextColor(...RED);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(7.5);
    doc.text('DÉPART', 22, y + 7);
    doc.setTextColor(...DARK);
    doc.setFontSize(10);
    doc.setFont('helvetica', 'bold');
    doc.text(data.depart_ville, 22, y + 14);
    doc.setFont('helvetica', 'normal');
    doc.setTextColor(...MID);
    doc.setFontSize(8.5);
    doc.text(deptLabel(data.depart_dept), 22, y + 20);

    // Flèche
    const cx = W / 2;
    doc.setDrawColor(...RED);
    doc.setLineWidth(0.6);
    doc.line(15 + colW + 2, y + 13, cx + 6, y + 13);
    doc.setFillColor(...RED);
    doc.triangle(cx + 7, y + 11, cx + 7, y + 15, cx + 11, y + 13, 'F');

    // Arrivée
    doc.setFillColor(...LITE);
    doc.roundedRect(W - 15 - colW, y, colW, 26, 3, 3, 'F');
    doc.setTextColor(...RED);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(7.5);
    doc.text('LIVRAISON', W - 15 - colW + 7, y + 7);
    doc.setTextColor(...DARK);
    doc.setFontSize(10);
    doc.setFont('helvetica', 'bold');
    doc.text(data.arrivee_ville, W - 15 - colW + 7, y + 14);
    doc.setFont('helvetica', 'normal');
    doc.setTextColor(...MID);
    doc.setFontSize(8.5);
    doc.text(deptLabel(data.arrivee_dept), W - 15 - colW + 7, y + 20);

    // ── Lots
    y += 36;
    doc.setTextColor(...DARK);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(9);
    doc.setFillColor(...RED);
    doc.rect(15, y - 1, 2, 7, 'F');
    doc.text('MARCHANDISE', 20, y + 5);

    y += 12;
    // En-tête tableau
    doc.setFillColor(...RED);
    doc.roundedRect(15, y, W - 30, 8, 2, 2, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(8);
    doc.setFont('helvetica', 'bold');
    doc.text('Lot',        22, y + 5.5);
    doc.text('Palettes',   42, y + 5.5);
    doc.text('Format',     75, y + 5.5);
    doc.text('Contenu',   115, y + 5.5);

    y += 8;
    let totalPalettes = 0;
    data.lots.forEach((lot, i) => {
      const bg = i % 2 === 0 ? [255, 255, 255] : LITE;
      doc.setFillColor(...bg);
      doc.rect(15, y, W - 30, 9, 'F');
      doc.setTextColor(...DARK);
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(9);
      doc.text(String(i + 1),     22, y + 6);
      doc.text(lot.palettes,      42, y + 6);
      doc.text(lot.taille,        75, y + 6);
      const contenuMax = doc.splitTextToSize(lot.contenu, 75);
      doc.text(contenuMax[0] + (contenuMax.length > 1 ? '…' : ''), 115, y + 6);
      totalPalettes += parseInt(lot.palettes) || 0;
      y += 9;
    });

    // Total
    doc.setFillColor(...LITE);
    doc.rect(15, y, W - 30, 8, 'F');
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(9);
    doc.setTextColor(...RED);
    doc.text('TOTAL', 22, y + 5.5);
    doc.setTextColor(...DARK);
    doc.text(String(totalPalettes) + ' palettes', 42, y + 5.5);
    y += 16;

    // ── Message
    if (data.message) {
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(8.5);
      doc.setTextColor(...MID);
      doc.text('INFORMATIONS COMPLÉMENTAIRES', 15, y);
      y += 5;
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(9);
      doc.setTextColor(...DARK);
      const lines = doc.splitTextToSize(data.message, W - 30);
      doc.text(lines, 15, y);
      y += lines.length * 5 + 8;
    }

    // ── Pied de page
    const footerY = 280;
    doc.setDrawColor(220, 220, 220);
    doc.setLineWidth(0.4);
    doc.line(15, footerY, W - 15, footerY);
    doc.setTextColor(...MID);
    doc.setFontSize(8);
    doc.setFont('helvetica', 'normal');
    doc.text('PR Logistics  ·  PLPN 1 – Port 4935, 76700 Rogerville', W / 2, footerY + 5, { align: 'center' });
    doc.text('02.32.72.48.03  ·  lehavre@pr-logistics.fr', W / 2, footerY + 10, { align: 'center' });

    return doc;
  }

  // ── Envoi via mailto (TO: PR Logistics, CC: client) ──────────
  function sendMailto(data) {
    const totalPal = data.lots.reduce((s, l) => s + (parseInt(l.palettes)||0), 0);
    const lotsText = data.lots.map((l, i) =>
      `  Lot ${i+1} : ${l.palettes} palette(s) — Format ${l.taille} — Contenu : ${l.contenu}`
    ).join('\n');

    const sujet = `Demande de devis via le site — ${data.nom} — ${totalPal} palette(s) — ${data.depart_ville} → ${data.arrivee_ville}`;
    const corps =
`Demande de devis PR Logistics
==============================

Client : ${data.nom}
Email  : ${data.email}${data.telephone ? '\nTél    : '+data.telephone : ''}

TRANSPORT
---------
Départ   : ${data.depart_ville} (${deptLabel(data.depart_dept)})
Livraison: ${data.arrivee_ville} (${deptLabel(data.arrivee_dept)})

MARCHANDISE
-----------
${lotsText}
Total : ${totalPal} palette(s)${data.message ? '\n\nINFORMATIONS COMPLÉMENTAIRES\n'+data.message : ''}

---
PR Logistics · PLPN 1 – Port 4935, 76700 Rogerville
02.32.72.48.03 · lehavre@pr-logistics.fr`;

    const url = `mailto:${PR_EMAIL}?cc=${encodeURIComponent(data.email)}&subject=${encodeURIComponent(sujet)}&body=${encodeURIComponent(corps)}`;
    window.location.href = url;
  }

  // ── Initialisation ────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', async () => {
    // Charger jsPDF
    const jsPDFScript = document.createElement('script');
    jsPDFScript.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
    document.head.appendChild(jsPDFScript);

    // Premier lot
    addLot();
    document.getElementById('addLotBtn')?.addEventListener('click', addLot);

    // Soumission
    const form    = document.getElementById('devisForm');
    const success = document.getElementById('formSuccess');
    const btn     = document.getElementById('submitBtn');
    const label   = document.getElementById('submitLabel');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Validation native
      const invalids = form.querySelectorAll(':invalid');
      if (invalids.length) {
        invalids.forEach(el => el.classList.add('input--error'));
        invalids[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      btn.disabled = true;
      label.textContent = 'Génération du PDF…';

      const fd = new FormData(form);
      const data = {
        nom:           fd.get('nom'),
        email:         fd.get('email'),
        telephone:     fd.get('telephone'),
        message:       fd.get('message'),
        depart_ville:  fd.get('depart_ville'),
        depart_dept:   fd.get('depart_dept'),
        arrivee_ville: fd.get('arrivee_ville'),
        arrivee_dept:  fd.get('arrivee_dept'),
        lots:          collectLots(),
      };

      // Attendre jsPDF
      let tries = 0;
      while (!window.jspdf && tries++ < 20) await new Promise(r => setTimeout(r, 200));

      // Télécharger le PDF
      const pdf = generatePDF(data);
      if (pdf) pdf.save(`Devis_PR_Logistics_${data.nom.replace(/\s+/g,'_')}.pdf`);

      // Ouvrir le client mail (TO: PR, CC: client)
      label.textContent = 'Ouverture du mail…';
      setTimeout(() => sendMailto(data), 300);

      // Afficher la confirmation
      setTimeout(() => {
        form.style.transition = 'opacity 0.4s';
        form.style.opacity = '0';
        setTimeout(() => {
          form.hidden = true;
          success.hidden = false;
        }, 380);
      }, 400);
    });

    form?.addEventListener('input', e => e.target.classList.remove('input--error'));
  });
</script>

<style>
