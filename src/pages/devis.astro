---

<MainLayout title="Demander un devis" description="Demandez un devis personnalisé à PR Logistics pour vos besoins de logistique et transport au Havre.">

  <!-- HERO -->
  <section class="devis-hero">
    <div class="devis-blob devis-blob--1" aria-hidden="true"></div>
    <div class="devis-blob devis-blob--2" aria-hidden="true"></div>
    <div class="container devis-hero__inner animate-in">
      <p class="eyebrow-rouge">Gratuit & sans engagement</p>
      <h1 class="titre-section">Demander un <span>devis</span></h1>
      <p class="sous-titre" style="margin:1rem auto 0; max-width:520px;">
        Remplissez le formulaire ci-dessous et notre équipe vous répond sous 24h avec une offre personnalisée.
      </p>
    </div>
  </section>

  <!-- FORMULAIRE -->
  <section class="section devis-section">
    <div class="container">
      <form class="devis-form reveal" id="devisForm" novalidate>

        <!-- Étape 1 : Adresses -->
        <div class="form-bloc">
          <div class="form-bloc__titre">
            <span class="form-step">1</span>
            <h2>Adresses de transport</h2>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="depart" class="form-label">
                <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
                Département de départ
              </label>
              <div class="select-wrapper">
                <select id="depart" name="depart" class="form-select" required>
                  <option value="" disabled selected>Sélectionnez un département</option>
                  {departements.map(d => (
                    <option value={d.code}>{d.code} — {d.nom}</option>
                  ))}
                </select>
                <span class="select-arrow" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </div>
            </div>

            <div class="form-separateur-h" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </div>

            <div class="form-group">
              <label for="arrivee" class="form-label">
                <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Département d'arrivée
              </label>
              <div class="select-wrapper">
                <select id="arrivee" name="arrivee" class="form-select" required>
                  <option value="" disabled selected>Sélectionnez un département</option>
                  {departements.map(d => (
                    <option value={d.code}>{d.code} — {d.nom}</option>
                  ))}
                </select>
                <span class="select-arrow" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </div>
            </div>
          </div>
        </div>

        <!-- Étape 2 : Marchandise -->
        <div class="form-bloc">
          <div class="form-bloc__titre">
            <span class="form-step">2</span>
            <h2>Détails de la marchandise</h2>
          </div>
          <div class="form-row form-row--3">
            <div class="form-group">
              <label for="palettes" class="form-label">
                <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="14" width="20" height="3" rx="1"/><rect x="4" y="8" width="16" height="6" rx="1"/><line x1="8" y1="14" x2="8" y2="17"/><line x1="16" y1="14" x2="16" y2="17"/></svg>
                Nombre de palettes
              </label>
              <input
                type="number"
                id="palettes"
                name="palettes"
                class="form-input"
                min="1"
                max="9999"
                placeholder="Ex : 12"
                required
              />
            </div>

            <div class="form-group">
              <label for="taille" class="form-label">
                <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18v18H3z"/><path d="M3 9h18M9 3v18"/></svg>
                Taille des palettes
              </label>
              <div class="select-wrapper">
                <select id="taille" name="taille" class="form-select" required>
                  <option value="" disabled selected>Choisissez un format</option>
                  <option value="120x150">120 × 150 cm (Europe)</option>
                  <option value="130x150">130 × 150 cm (Industrielle)</option>
                </select>
                <span class="select-arrow" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </div>
            </div>

            <div class="form-group">
              <label for="poids" class="form-label">
                <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a4 4 0 014 4H8a4 4 0 014-4z"/><path d="M5 8h14l-1.5 12h-11L5 8z"/></svg>
                Poids total estimé (kg)
                <span class="label-optional">Optionnel</span>
              </label>
              <input
                type="number"
                id="poids"
                name="poids"
                class="form-input"
                min="1"
                placeholder="Ex : 5 000"
              />
            </div>
          </div>
        </div>

        <!-- Étape 3 : Contact -->
        <div class="form-bloc">
          <div class="form-bloc__titre">
            <span class="form-step">3</span>
            <h2>Vos coordonnées</h2>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="nom" class="form-label">Nom / Société</label>
              <input type="text" id="nom" name="nom" class="form-input" placeholder="PR Logistics" required />
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Adresse e-mail</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="contact@exemple.fr" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="telephone" class="form-label">Téléphone <span class="label-optional">Optionnel</span></label>
              <input type="tel" id="telephone" name="telephone" class="form-input" placeholder="06 00 00 00 00" />
            </div>
            <div class="form-group">
              <label for="message" class="form-label">Informations complémentaires <span class="label-optional">Optionnel</span></label>
              <textarea id="message" name="message" class="form-input form-textarea" placeholder="Marchandises dangereuses, température dirigée, délais particuliers…" rows="3"></textarea>
            </div>
          </div>
        </div>

        <!-- Récap + bouton -->
        <div class="form-footer">
          <p class="form-footer__mention">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Vos données sont utilisées uniquement pour traiter votre demande.
          </p>
          <button type="submit" class="btn btn--rouge btn--lg" id="submitBtn">
            Envoyer ma demande
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          </button>
        </div>

        <!-- Message de confirmation -->
        <div class="form-success" id="formSuccess" aria-live="polite" hidden>
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <h3>Demande envoyée !</h3>
          <p>Notre équipe vous contactera sous 24h avec une offre personnalisée.</p>
        </div>

      </form>
    </div>
  </section>

</MainLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form    = document.getElementById('devisForm')    as HTMLFormElement;
    const success = document.getElementById('formSuccess')  as HTMLElement;
    const btn     = document.getElementById('submitBtn')    as HTMLButtonElement;

    form?.addEventListener('submit', (e: Event) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
          'input[required], select[required]'
        ).forEach(el => {
          if (!el.validity.valid) el.classList.add('input--error');
        });
        return;
      }

      const data  = new FormData(form);
      const depart   = (document.getElementById('depart')    as HTMLSelectElement).options[(document.getElementById('depart') as HTMLSelectElement).selectedIndex]?.text ?? data.get('depart');
      const arrivee  = (document.getElementById('arrivee')   as HTMLSelectElement).options[(document.getElementById('arrivee') as HTMLSelectElement).selectedIndex]?.text ?? data.get('arrivee');
      const palettes = data.get('palettes');
      const taille   = data.get('taille');
      const poids    = data.get('poids') ? ` — Poids estimé : ${data.get('poids')} kg` : '';
      const nom      = data.get('nom');
      const email    = data.get('email');
      const tel      = data.get('telephone') ? ` — Tél : ${data.get('telephone')}` : '';
      const msg      = data.get('message')   ? `\n\nInformations complémentaires :\n${data.get('message')}` : '';

      const sujet = `Demande de devis via le site — ${palettes} palettes ${depart} → ${arrivee}`;
      const corps = `Demande de devis PR Logistics\n\nExpéditeur : ${nom} (${email})${tel}\n\nDétails du transport :\n• Départ : ${depart}\n• Arrivée : ${arrivee}\n• Nombre de palettes : ${palettes}\n• Format palette : ${taille}${poids}${msg}`;

      const mailto = `mailto:lehavre@pr-logistics.fr?subject=${encodeURIComponent(sujet)}&body=${encodeURIComponent(corps)}`;
      window.location.href = mailto;

      /* Affiche la confirmation après un court délai */
      setTimeout(() => {
        form.style.opacity = '0';
        form.style.transform = 'translateY(-10px)';
        form.style.transition = 'opacity 0.4s, transform 0.4s';
        setTimeout(() => {
          form.hidden = true;
          success.hidden = false;
        }, 400);
      }, 600);
    });

    /* Enlève la classe erreur dès que l'utilisateur corrige */
    form?.addEventListener('input', (e: Event) => {
      (e.target as HTMLElement).classList.remove('input--error');
    });
  });
</script>

<style>
  /* HERO */
  .devis-hero {
    position: relative;
    background: linear-gradient(135deg, #fff 0%, var(--gris-clair) 100%);
    padding: 5rem 0 4rem;
    text-align: center;
    overflow: hidden;
  }

  .devis-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
  }

  .devis-blob--1 {
    width: 400px; height: 400px;
    top: -150px; right: -80px;
    background: rgba(227,6,19,0.08);
  }

  .devis-blob--2 {
    width: 320px; height: 320px;
    bottom: -120px; left: -60px;
    background: rgba(227,6,19,0.06);
  }

  .devis-hero__inner { position: relative; }

  /* SECTION */
  .devis-section {
    background: var(--gris-clair);
  }

  /* FORMULAIRE */
  .devis-form {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  /* Blocs numérotés */
  .form-bloc {
    background: white;
    border-radius: var(--rayon-lg);
    padding: 2rem 2.2rem;
    box-shadow: 0 2px 24px rgba(0,0,0,0.06);
  }

  .form-bloc__titre {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1.6rem;
  }

  .form-step {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--rouge);
    color: white;
    font-size: 0.85rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .form-bloc__titre h2 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--gris-fonce);
    margin: 0;
  }

  /* Rangées */
  .form-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.2rem;
    align-items: end;
  }

  .form-row--3 {
    grid-template-columns: 1fr 1fr 1fr;
  }

  /* Flèche séparatrice */
  .form-separateur-h {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-bottom: 0.65rem;
    color: var(--rouge);
    opacity: 0.6;
  }

  /* Groupes */
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--gris-fonce);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .label-icon {
    width: 14px;
    height: 14px;
    color: var(--rouge);
    flex-shrink: 0;
  }

  .label-optional {
    font-size: 0.72rem;
    font-weight: 500;
    color: #aaa;
    text-transform: none;
    letter-spacing: 0;
    margin-left: 0.3rem;
  }

  /* Inputs */
  .form-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1.5px solid #e8e8e8;
    border-radius: 0.75rem;
    font-size: 0.95rem;
    color: var(--gris-fonce);
    background: white;
    transition: border-color 0.2s, box-shadow 0.2s;
    font-family: inherit;
    appearance: none;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--rouge);
    box-shadow: 0 0 0 3px rgba(227,6,19,0.08);
  }

  .form-input::placeholder { color: #bbb; }

  .form-textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-input.input--error {
    border-color: #e30613;
    box-shadow: 0 0 0 3px rgba(227,6,19,0.1);
  }

  /* Select custom */
  .select-wrapper {
    position: relative;
  }

  .select-wrapper .form-select {
    width: 100%;
    padding: 0.75rem 2.5rem 0.75rem 1rem;
    border: 1.5px solid #e8e8e8;
    border-radius: 0.75rem;
    font-size: 0.95rem;
    color: var(--gris-fonce);
    background: white;
    appearance: none;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s;
    font-family: inherit;
  }

  .select-wrapper .form-select:focus {
    outline: none;
    border-color: var(--rouge);
    box-shadow: 0 0 0 3px rgba(227,6,19,0.08);
  }

  .select-arrow {
    position: absolute;
    right: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--gris-moyen);
  }

  /* Footer du formulaire */
  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: 0 0.2rem;
  }

  .form-footer__mention {
    font-size: 0.82rem;
    color: #aaa;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .btn--lg {
    padding: 0.9rem 2rem;
    font-size: 1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  /* Confirmation */
  .form-success {
    background: white;
    border-radius: var(--rayon-lg);
    padding: 4rem 2rem;
    text-align: center;
    box-shadow: 0 2px 24px rgba(0,0,0,0.06);
    max-width: 860px;
    margin: 0 auto;
  }

  .form-success svg {
    color: #15803d;
    margin-bottom: 1rem;
  }

  .form-success h3 {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--gris-fonce);
    margin-bottom: 0.6rem;
  }

  .form-success p {
    font-size: 1rem;
    color: var(--gris-moyen);
  }

  /* Responsive */
  @media (max-width: 700px) {
    .form-row {
      grid-template-columns: 1fr;
    }
    .form-row--3 {
      grid-template-columns: 1fr;
    }
    .form-separateur-h { display: none; }
    .form-footer {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
    }
    .btn--lg { justify-content: center; }
  }
</style>
