<MainLayout title="Demander un devis" description="Demandez un devis personnalisé à PR Logistics pour vos besoins de logistique et transport au Havre.">

  <!-- ═══ HERO ═══ -->
  <section class="devis-hero">
    <div class="devis-blob devis-blob--1" aria-hidden="true"></div>
    <div class="devis-blob devis-blob--2" aria-hidden="true"></div>
    <div class="container devis-hero__inner animate-in">
      <p class="eyebrow-rouge" data-i18n="devis.hero.eyebrow">Gratuit & sans engagement</p>
      <h1 class="titre-section" data-i18n-html="devis.hero.title">Demander un <span>devis</span></h1>
      <p class="sous-titre" style="margin:1rem auto 0; max-width:520px;" data-i18n="devis.hero.subtitle">
        Choisissez votre prestation, remplissez le formulaire et notre équipe vous répond sous 24h.
      </p>
    </div>
  </section>

  <!-- ═══ SÉLECTION DU SERVICE ═══ -->
  <section class="section services-select" id="servicesSelect">
    <div class="container">
      <div class="services-intro reveal">
        <p class="eyebrow-rouge" data-i18n="devis.step1.eyebrow">Étape 1 — Votre besoin</p>
        <h2 class="titre-section" style="margin:0.4rem 0 0.8rem" data-i18n-html="devis.step1.title">Quel service<br>vous intéresse ?</h2>
        <p class="sous-titre" style="margin:0 auto; max-width:480px; font-size:1rem;" data-i18n="devis.step1.subtitle">
          Sélectionnez votre prestation pour accéder au formulaire correspondant.
        </p>
      </div>

      <div class="services-grid reveal">

        <!-- Dépotage / Empotage -->
        <div class="service-card" data-service="depotage" role="button" tabindex="0"
             aria-label="Demander un devis Dépotage / Empotage">
          <div class="service-card__icon-wrap">
            <img src="/assets/services/depotage.png" alt="" class="service-card__icon">
          </div>
          <div class="service-card__body">
            <h3 class="service-card__title" data-i18n="devis.card.depotage.title">Dépotage / Empotage</h3>
            <p class="service-card__desc" data-i18n="devis.card.depotage.desc">Chargement et déchargement de vos conteneurs dans nos entrepôts au cœur du port du Havre.</p>
          </div>
          <div class="service-card__footer">
            <span class="service-card__cta">
              <span data-i18n="devis.card.cta">Demander un devis</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
          <div class="service-card__selected-badge" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            <span data-i18n="devis.card.selected">Sélectionné</span>
          </div>
        </div>

        <!-- Stockage -->
        <div class="service-card" data-service="stockage" role="button" tabindex="0"
             aria-label="Demander un devis Stockage">
          <div class="service-card__icon-wrap">
            <img src="/assets/services/Storage.png" alt="" class="service-card__icon">
          </div>
          <div class="service-card__body">
            <h3 class="service-card__title" data-i18n="devis.card.stockage.title">Stockage</h3>
            <p class="service-card__desc" data-i18n="devis.card.stockage.desc">Entreposage sécurisé de vos marchandises dans notre entrepôt de 8 000 m² au Havre.</p>
          </div>
          <div class="service-card__footer">
            <span class="service-card__cta">
              <span data-i18n="devis.card.cta">Demander un devis</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
          <div class="service-card__selected-badge" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            <span data-i18n="devis.card.selected">Sélectionné</span>
          </div>
        </div>

        <!-- Traction -->
        <div class="service-card" data-service="traction" role="button" tabindex="0"
             aria-label="Demander un devis Traction">
          <div class="service-card__icon-wrap">
            <img src="/assets/services/traction.png" alt="" class="service-card__icon">
          </div>
          <div class="service-card__body">
            <h3 class="service-card__title" data-i18n="devis.card.traction.title">Traction</h3>
            <p class="service-card__desc" data-i18n="devis.card.traction.desc">Déplacement de vos semi-remorques et conteneurs entre le port et leur destination finale.</p>
          </div>
          <div class="service-card__footer">
            <span class="service-card__cta">
              <span data-i18n="devis.card.cta">Demander un devis</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
          <div class="service-card__selected-badge" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            <span data-i18n="devis.card.selected">Sélectionné</span>
          </div>
        </div>

        <!-- Transport & Livraison -->
        <div class="service-card" data-service="transport" role="button" tabindex="0"
             aria-label="Demander un devis Transport et Livraison">
          <div class="service-card__icon-wrap">
            <img src="/assets/services/livraison.png" alt="" class="service-card__icon">
          </div>
          <div class="service-card__body">
            <h3 class="service-card__title" data-i18n="devis.card.transport.title">Transport & Livraison</h3>
            <p class="service-card__desc" data-i18n="devis.card.transport.desc">Prise en charge et livraison de vos palettes jusqu'à votre client final partout en France.</p>
          </div>
          <div class="service-card__footer">
            <span class="service-card__cta">
              <span data-i18n="devis.card.cta">Demander un devis</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
          <div class="service-card__selected-badge" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            <span data-i18n="devis.card.selected">Sélectionné</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ FORMULAIRE ═══ -->
  <section class="section devis-section" id="devisSection">
    <div class="container">

      <!-- Barre de navigation du formulaire -->
      <div class="form-topbar">
        <button type="button" class="btn-retour" id="btnRetour">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          <span data-i18n="devis.back">Changer de prestation</span>
        </button>
        <div class="form-service-badge" id="formServiceBadge">
          <img id="formServiceIcon" src="" alt="" class="form-service-badge__icon">
          <span id="formServiceLabel"></span>
        </div>
      </div>

      <!-- Message d'erreur d'envoi -->
      <p id="sendError" hidden style="color:#e30613; font-size:0.88rem; margin-bottom:0.8rem; text-align:right; max-width:900px; margin-left:auto; margin-right:auto;"></p>

      <form class="devis-form" id="devisForm" novalidate>

        <!-- ══════════════════════════════════════════════
             BLOC: Adresses  [transport, traction]
        ══════════════════════════════════════════════ -->
        <div class="form-bloc" data-for="transport traction" id="bloc-adresses">
          <div class="form-bloc__titre">
            <span class="form-step">1</span>
            <h2 id="adresses-titre">Adresses de transport</h2>
          </div>

          <div class="adresses-grid">
            <div class="adresse-card">
              <div class="adresse-card__header adresse-card__header--neutre">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="10" r="3"/><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
                <span id="label-depart">Adresse de départ</span>
              </div>
              <div class="form-group">
                <label class="form-label" for="depart_ville">Ville</label>
                <input type="text" id="depart_ville" name="depart_ville" class="form-input" placeholder="Le Havre" required />
              </div>
              <div class="form-group">
                <label class="form-label" for="depart_dept">Département</label>
                <div class="select-wrapper">
                  <select id="depart_dept" name="depart_dept" class="form-select" required>
                    <option value="" disabled selected>Sélectionnez</option>
                    {departements.map(d => <option value={d.code}>{d.code} — {d.nom}</option>)}
                  </select>
                  <span class="select-arrow" aria-hidden="true">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                  </span>
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Pays</label>
                <input type="text" value="France" class="form-input input--disabled" disabled />
              </div>
            </div>

            <div class="adresses-sep" aria-hidden="true">
              <div class="adresses-sep__dot"></div>
            </div>

            <div class="adresse-card adresse-card--livraison">
              <div class="adresse-card__header">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span id="label-arrivee">Adresse de livraison</span>
              </div>
              <div class="form-group">
                <label class="form-label" for="arrivee_ville">Ville</label>
                <input type="text" id="arrivee_ville" name="arrivee_ville" class="form-input" placeholder="Paris" required />
              </div>
              <div class="form-group">
                <label class="form-label" for="arrivee_dept">Département</label>
                <div class="select-wrapper">
                  <select id="arrivee_dept" name="arrivee_dept" class="form-select" required>
                    <option value="" disabled selected>Sélectionnez</option>
                    {departements.map(d => <option value={d.code}>{d.code} — {d.nom}</option>)}
                  </select>
                  <span class="select-arrow" aria-hidden="true">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                  </span>
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Pays</label>
                <input type="text" value="France" class="form-input input--disabled" disabled />
              </div>
            </div>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════
             BLOC: Site de stockage  [stockage]
        ══════════════════════════════════════════════ -->
        <div class="form-bloc" data-for="stockage" id="bloc-stockage-site">
          <div class="form-bloc__titre">
            <span class="form-step">1</span>
            <h2>Site de stockage</h2>
          </div>
          <div class="info-banner">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Par défaut, stockage dans notre entrepôt au <strong>Port du Havre — 76700 Rogerville</strong>. Précisez ci-dessous si vous souhaitez un site différent.
          </div>
          <div class="form-row form-row--2" style="margin-top:1.2rem">
            <div class="form-group">
              <label class="form-label" for="stock_ville">Autre ville souhaitée <span class="label-optional">Optionnel</span></label>
              <input type="text" id="stock_ville" name="stock_ville" class="form-input" placeholder="Le Havre" />
            </div>
            <div class="form-group">
              <label class="form-label" for="stock_dept">Département</label>
              <div class="select-wrapper">
                <select id="stock_dept" name="stock_dept" class="form-select">
                  <option value="" disabled selected>Sélectionnez</option>
                  {departements.map(d => <option value={d.code}>{d.code} — {d.nom}</option>)}
                </select>
                <span class="select-arrow" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </div>
            </div>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════
             BLOC: Opération dépotage  [depotage]
        ══════════════════════════════════════════════ -->
        <div class="form-bloc" data-for="depotage" id="bloc-depotage-op">
          <div class="form-bloc__titre">
            <span class="form-step">1</span>
            <h2>Détails de l'opération</h2>
          </div>

          <!-- Type d'opération — radio visuel -->
          <div class="form-group" style="margin-bottom:1.6rem">
            <label class="form-label">Type d'opération</label>
            <div class="radio-group">
              <label class="radio-card">
                <input type="radio" name="depot_operation" value="depotage" required>
                <div class="radio-card__content">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="7.5 4.21 12 6.81 16.5 4.21"/><polyline points="7.5 19.79 7.5 14.6 3 12"/><polyline points="21 12 16.5 14.6 16.5 19.79"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                  <strong>Dépotage</strong>
                  <span>Conteneur → Entrepôt</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="depot_operation" value="empotage">
                <div class="radio-card__content">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  <strong>Empotage</strong>
                  <span>Entrepôt → Conteneur</span>
                </div>
              </label>
            </div>
          </div>

          <div class="form-row form-row--3">
            <div class="form-group">
              <label class="form-label" for="depot_nb">Nombre de conteneurs</label>
              <input type="number" id="depot_nb" name="depot_nb" class="form-input" min="1" max="999" placeholder="Ex : 2" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="depot_type_cont">Type de conteneur</label>
              <div class="select-wrapper">
                <select id="depot_type_cont" name="depot_type_cont" class="form-select" required>
                  <option value="" disabled selected>Sélectionnez</option>
                  <option value="20">20' — standard</option>
                  <option value="40">40' — standard</option>
                  <option value="40hc">40' High Cube</option>
                  <option value="45hc">45' High Cube</option>
                  <option value="reefer">Réfrigéré (Reefer)</option>
                  <option value="autre">Autre</option>
                </select>
                <span class="select-arrow" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="depot_date">Date souhaitée</label>
              <input type="date" id="depot_date" name="depot_date" class="form-input" required />
            </div>
          </div>

          <div class="form-row form-row--2" style="margin-top:1.2rem">
            <div class="form-group">
              <label class="form-label" for="depot_port">Port / Terminal</label>
              <input type="text" id="depot_port" name="depot_port" class="form-input" placeholder="Port du Havre" value="Port du Havre" />
            </div>
            <div class="form-group">
              <label class="form-label" for="depot_poids">Poids total estimé <span class="label-optional">Optionnel</span></label>
              <div class="input-with-unit">
                <input type="number" id="depot_poids" name="depot_poids" class="form-input" placeholder="Ex : 15 000" />
                <div class="select-wrapper input-unit">
                  <select name="depot_poids_unite" class="form-select">
                    <option value="kg">kg</option>
                    <option value="t" selected>t</option>
                  </select>
                  <span class="select-arrow" aria-hidden="true">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════
             BLOC: Détails traction  [traction]
        ══════════════════════════════════════════════ -->
        <div class="form-bloc" data-for="traction" id="bloc-traction">
          <div class="form-bloc__titre">
            <span class="form-step">2</span>
            <h2>Détails de la traction</h2>
          </div>
          <div class="form-row form-row--3">
            <div class="form-group">
              <label class="form-label" for="trac_vehicule">Type de véhicule</label>
              <div class="select-wrapper">
                <select id="trac_vehicule" name="trac_vehicule" class="form-select" required>
                  <option value="" disabled selected>Sélectionnez</option>
                  <option value="bache">Semi bâchée</option>
                  <option value="frigo">Semi frigorifique</option>
                  <option value="plateau">Plateau</option>
                  <option value="citerne">Citerne</option>
                  <option value="conteneur">Porte-conteneur</option>
                  <option value="autre">Autre</option>
                </select>
                <span class="select-arrow" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="trac_poids">Poids total <span class="label-optional">Optionnel</span></label>
              <div class="input-with-unit">
                <input type="number" id="trac_poids" name="trac_poids" class="form-input" placeholder="Ex : 22 000" />
                <div class="select-wrapper input-unit">
                  <select name="trac_poids_unite" class="form-select">
                    <option value="kg">kg</option>
                    <option value="t" selected>t</option>
                  </select>
                  <span class="select-arrow" aria-hidden="true">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                  </span>
                </div>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="trac_date">Date souhaitée</label>
              <input type="date" id="trac_date" name="trac_date" class="form-input" required />
            </div>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════
             BLOC: Marchandise — lots  [tous les services]
        ══════════════════════════════════════════════ -->
        <div class="form-bloc" data-for="transport stockage depotage traction" id="bloc-marchandise">
          <div class="form-bloc__titre">
            <span class="form-step">2</span>
            <h2>Détails de la marchandise</h2>
          </div>
          <div id="lotsContainer"></div>
          <button type="button" id="addLotBtn" class="btn-add-lot">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Ajouter un lot
          </button>
        </div>

        <!-- ══════════════════════════════════════════════
             BLOC: Conditions de stockage  [stockage]
        ══════════════════════════════════════════════ -->
        <div class="form-bloc" data-for="stockage" id="bloc-stockage-details">
          <div class="form-bloc__titre">
            <span class="form-step">3</span>
            <h2>Conditions de stockage</h2>
          </div>

          <div class="form-row form-row--2" style="margin-bottom:1.2rem">
            <div class="form-group">
              <label class="form-label" for="stock_poids">Poids total estimé <span class="label-optional">Optionnel</span></label>
              <div class="input-with-unit">
                <input type="number" id="stock_poids" name="stock_poids" class="form-input" placeholder="Ex : 5 000" />
                <div class="select-wrapper input-unit">
                  <select name="stock_poids_unite" class="form-select">
                    <option value="kg">kg</option>
                    <option value="t" selected>t</option>
                  </select>
                  <span class="select-arrow" aria-hidden="true">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                  </span>
                </div>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="stock_duree">Durée souhaitée</label>
              <div class="select-wrapper">
                <select id="stock_duree" name="stock_duree" class="form-select" required>
                  <option value="" disabled selected>Sélectionnez</option>
                  <option value="<1sem">Moins d'une semaine</option>
                  <option value="1mois">Environ 1 mois</option>
                  <option value="1-3mois">1 à 3 mois</option>
                  <option value="3-6mois">3 à 6 mois</option>
                  <option value=">6mois">Plus de 6 mois</option>
                  <option value="indetermine">Durée indéterminée</option>
                </select>
                <span class="select-arrow" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </div>
            </div>
          </div>

          <div class="form-row form-row--2" style="margin-bottom:1.4rem">
            <div class="form-group">
              <label class="form-label" for="stock_date_entree">Date d'entrée souhaitée</label>
              <input type="date" id="stock_date_entree" name="stock_date_entree" class="form-input" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="stock_date_sortie">Date de sortie estimée <span class="label-optional">Optionnel</span></label>
              <input type="date" id="stock_date_sortie" name="stock_date_sortie" class="form-input" />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Conditions particulières <span class="label-optional">Optionnel</span></label>
            <div class="checkboxes-grid">
              <label class="checkbox-item">
                <input type="checkbox" name="cond_froid" value="1">
                <span>Température dirigée</span>
              </label>
              <label class="checkbox-item">
                <input type="checkbox" name="cond_dangereux" value="1">
                <span>Matières dangereuses</span>
              </label>
              <label class="checkbox-item">
                <input type="checkbox" name="cond_alcool" value="1">
                <span>Alcool / produits réglementés</span>
              </label>
              <label class="checkbox-item">
                <input type="checkbox" name="cond_bio" value="1">
                <span>Produits biologiques</span>
              </label>
              <label class="checkbox-item">
                <input type="checkbox" name="cond_racks" value="1">
                <span>Stockage en racks</span>
              </label>
              <label class="checkbox-item">
                <input type="checkbox" name="cond_securite" value="1">
                <span>Sécurité renforcée</span>
              </label>
            </div>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════
             BLOC: Vos coordonnées  [tous les services]
        ══════════════════════════════════════════════ -->
        <div class="form-bloc" data-for="transport stockage depotage traction" id="bloc-coordonnees">
          <div class="form-bloc__titre">
            <span class="form-step">3</span>
            <h2>Vos coordonnées</h2>
          </div>

          <div class="form-row form-row--3">
            <div class="form-group">
              <label class="form-label" for="nom">
                <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Nom / Société
              </label>
              <input type="text" id="nom" name="nom" class="form-input" placeholder="PR Logistics" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="email">
                <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                Adresse e-mail
              </label>
              <input type="email" id="email" name="email" class="form-input" placeholder="contact@exemple.fr" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="telephone">
                <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                Téléphone <span class="label-optional">Optionnel</span>
              </label>
              <input type="tel" id="telephone" name="telephone" class="form-input" placeholder="06 00 00 00 00" />
            </div>
          </div>

          <div class="form-group" style="margin-top:1.2rem">
            <label class="form-label" for="message">
              <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              Informations complémentaires <span class="label-optional">Optionnel</span>
            </label>
            <textarea id="message" name="message" class="form-input form-textarea" rows="3"
              placeholder="Délais particuliers, accès spécifique, contraintes techniques…"></textarea>
          </div>
        </div>

        <!-- Pied de formulaire -->
        <div class="form-footer">
          <p class="form-footer__mention">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Vos données sont utilisées uniquement pour traiter votre demande.
          </p>
          <button type="submit" class="btn btn--rouge btn--lg" id="submitBtn">
            <span id="submitLabel">Envoyer ma demande</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          </button>
        </div>

      </form>

      <!-- Confirmation -->
      <div class="form-success" id="formSuccess" hidden>
        <div class="form-success__icon">
          <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3>Demande envoyée !</h3>
        <p>Un email de confirmation avec votre devis en PDF a été envoyé à votre adresse.<br />Notre équipe vous contactera sous 24h.</p>
        <a href="/" class="btn btn--outline" style="margin-top:1.5rem;">Retour à l'accueil</a>
      </div>

    </div>
  </section>

</MainLayout>

<!-- ═══════════════════════════════════════════════════════════
     SCRIPT
═══════════════════════════════════════════════════════════ -->
<script is:inline define:vars={{ departementsJson }}>
  const PR_EMAIL   = 'lehavre@pr-logistics.fr';
  const DEPARTEMENTS = JSON.parse(departementsJson);

  // ── Infos par service ────────────────────────────────────────
  const SERVICE_INFO = {
    depotage:  { label: 'Dépotage / Empotage',   icon: '/assets/services/depotage.png' },
    stockage:  { label: 'Stockage',               icon: '/assets/services/Storage.png' },
    traction:  { label: 'Traction',               icon: '/assets/services/traction.png' },
    transport: { label: 'Transport & Livraison',  icon: '/assets/services/livraison.png' },
  };

  let currentService = null;

  // ── Sélection du service ─────────────────────────────────────
  function selectService(name) {
    currentService = name;
    const info = SERVICE_INFO[name];

    // Mise à jour visuelle des cartes + état de la grille
    const grid = document.querySelector('.services-grid');
    grid.classList.add('has-selection');
    document.querySelectorAll('.service-card').forEach(c => {
      c.classList.toggle('selected', c.dataset.service === name);
    });

    // Badge service dans le formulaire
    const icon  = document.getElementById('formServiceIcon');
    const label = document.getElementById('formServiceLabel');
    if (icon)  { icon.src = info.icon; icon.alt = info.label; }
    if (label) { label.textContent = info.label; }

    // Labels adresses selon service
    const labelDepart  = document.getElementById('label-depart');
    const labelArrivee = document.getElementById('label-arrivee');
    const adressesTitre = document.getElementById('adresses-titre');
    if (name === 'traction') {
      if (labelDepart)  labelDepart.textContent  = "Point d'enlèvement";
      if (labelArrivee) labelArrivee.textContent = 'Point de livraison';
      if (adressesTitre) adressesTitre.textContent = 'Itinéraire de traction';
    } else {
      if (labelDepart)  labelDepart.textContent  = 'Adresse de départ';
      if (labelArrivee) labelArrivee.textContent = 'Adresse de livraison';
      if (adressesTitre) adressesTitre.textContent = 'Adresses de transport';
    }

    // Afficher / masquer les blocs + activer/désactiver les inputs
    document.querySelectorAll('.form-bloc[data-for]').forEach(bloc => {
      const services = bloc.dataset.for.split(' ');
      const active   = services.includes(name);
      bloc.style.display = active ? '' : 'none';
      bloc.querySelectorAll('input, select, textarea').forEach(el => {
        if (!el.classList.contains('input--disabled')) {
          el.disabled = !active;
        }
      });
    });

    // Renuméroter les étapes
    updateStepNumbers();

    // Afficher la section formulaire
    const section = document.getElementById('devisSection');
    section.style.display = 'block';

    // Préparer les blocs visibles pour le stagger (état initial masqué)
    const visibleBlocs = [...document.querySelectorAll('.form-bloc[data-for]')]
      .filter(b => b.style.display !== 'none');
    const formTopbar  = document.querySelector('.form-topbar');
    const formFooter  = document.querySelector('.form-footer');
    const allEls = [formTopbar, ...visibleBlocs, formFooter].filter(Boolean);
    allEls.forEach(el => {
      el.style.transition = 'none';
      el.style.opacity    = '0';
      el.style.transform  = 'translateY(28px)';
    });

    // Délai léger pour laisser l'animation de la carte jouer
    setTimeout(() => {
      // Révéler le conteneur
      section.classList.add('form-visible');

      // Stagger des éléments
      allEls.forEach((el, i) => {
        setTimeout(() => {
          el.style.transition = 'opacity 0.52s cubic-bezier(0.16,1,0.3,1), transform 0.52s cubic-bezier(0.16,1,0.3,1)';
          el.style.opacity    = '1';
          el.style.transform  = 'translateY(0)';
        }, i * 80);
      });

      // Scroll fluide après le début de l'animation
      setTimeout(() => {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 160);
    }, 220);
  }

  function resetToSelection() {
    currentService = null;
    const grid = document.querySelector('.services-grid');
    grid.classList.remove('has-selection');
    document.querySelectorAll('.service-card').forEach(c => c.classList.remove('selected'));
    const section = document.getElementById('devisSection');
    section.classList.remove('form-visible');
    setTimeout(() => { section.style.display = 'none'; }, 450);
    document.getElementById('servicesSelect').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function updateStepNumbers() {
    const visibles = [...document.querySelectorAll('.form-bloc[data-for]')]
      .filter(b => b.style.display !== 'none' && !b.hasAttribute('data-no-step'));
    visibles.forEach((bloc, i) => {
      const step = bloc.querySelector('.form-step');
      if (step) step.textContent = i + 1;
    });
  }

  // ── Gestion des lots ─────────────────────────────────────────
  let lots   = [];
  let nextId = 1;

  const FORMATS = [
    { val: '',        label: 'Format…' },
    { val: '80x100',  label: '80 × 100 cm' },
    { val: '80x120',  label: '80 × 120 cm (Euro)' },
    { val: '100x120', label: '100 × 120 cm' },
  ];

  const TYPES_MARCHANDISE = [
    { val: '',          label: 'Type de marchandise…' },
    { val: 'standard',  label: 'Marchandise standard' },
    { val: 'froid',     label: 'Température dirigée (froid)' },
    { val: 'dangereux', label: 'Marchandise dangereuse' },
    { val: 'alcool',    label: 'Alcool' },
    { val: 'bio',       label: 'Produits biologiques' },
    { val: 'autre',     label: 'Autre' },
  ];

  function selectHTML(name, id) {
    const opts = FORMATS.map(f =>
      `<option value="${f.val}"${f.val === '' ? ' disabled selected' : ''}>${f.label}</option>`
    ).join('');
    return `<div class="select-wrapper"><select name="${name}" id="${id}" class="form-select" required>${opts}</select><span class="select-arrow" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span></div>`;
  }

  function typeSelectHTML(name, id) {
    const opts = TYPES_MARCHANDISE.map(t =>
      `<option value="${t.val}"${t.val === '' ? ' disabled selected' : ''}>${t.label}</option>`
    ).join('');
    return `<div class="select-wrapper"><select name="${name}" id="${id}" class="form-select" required>${opts}</select><span class="select-arrow" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span></div>`;
  }

  function createLotRow(id, num) {
    const div = document.createElement('div');
    div.className = 'lot-card';
    div.dataset.lotId = id;
    div.innerHTML = `
      <div class="lot-card__header">
        <div class="lot-badge">Lot ${num}</div>
        <button type="button" class="btn-remove-lot" title="Supprimer ce lot">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          Supprimer
        </button>
      </div>
      <div class="lot-card__fields lot-card__fields--row1">
        <div class="form-group">
          <label class="form-label" for="pal_${id}">Nombre de palettes <span class="req-star">*</span></label>
          <input type="number" name="pal_${id}" id="pal_${id}" min="1" max="9999" class="form-input" placeholder="Ex : 5" required />
        </div>
        <div class="form-group">
          <label class="form-label" for="tai_${id}">Taille des palettes <span class="req-star">*</span></label>
          ${selectHTML(`tai_${id}`, `tai_${id}`)}
        </div>
      </div>
      <div class="lot-card__fields lot-card__fields--row2">
        <div class="form-group">
          <label class="form-label" for="typ_${id}">Type de marchandise <span class="req-star">*</span></label>
          ${typeSelectHTML(`typ_${id}`, `typ_${id}`)}
        </div>
        <div class="form-group">
          <label class="form-label" for="con_${id}">Contenu de la marchandise <span class="label-optional">Optionnel</span></label>
          <input type="text" name="con_${id}" id="con_${id}" class="form-input" placeholder="Ex : Électronique, textile…" />
        </div>
      </div>`;
    div.querySelector('.btn-remove-lot').addEventListener('click', () => removeLot(id, div));
    return div;
  }

  function addLot() {
    const id  = nextId++;
    const num = lots.length + 1;
    lots.push(id);
    document.getElementById('lotsContainer').appendChild(createLotRow(id, num));
    updateRemoveBtns();
  }

  function removeLot(id, el) {
    lots = lots.filter(l => l !== id);
    el.remove();
    updateLotNumbers();
    updateRemoveBtns();
  }

  function updateLotNumbers() {
    document.querySelectorAll('.lot-card .lot-badge').forEach((el, i) => {
      el.textContent = `Lot ${i + 1}`;
    });
  }

  function updateRemoveBtns() {
    const btns = document.querySelectorAll('.btn-remove-lot');
    btns.forEach(b => { b.style.visibility = btns.length === 1 ? 'hidden' : 'visible'; });
  }

  function collectLots() {
    return lots.map(id => ({
      palettes: document.getElementById(`pal_${id}`)?.value ?? '',
      taille:   document.querySelector(`[name="tai_${id}"]`)?.value ?? '',
      type:     document.querySelector(`[name="typ_${id}"]`)?.value ?? '',
      contenu:  document.getElementById(`con_${id}`)?.value ?? '',
    }));
  }

  // ── PDF ───────────────────────────────────────────────────────
  function deptLabel(code) {
    const d = DEPARTEMENTS.find(d => d.code === code);
    return d ? `${d.code} — ${d.nom}` : code;
  }

  function generatePDF(data) {
    const jsPDF = window.jspdf?.jsPDF;
    if (!jsPDF) return null;

    const doc  = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
    const W    = 210;
    const RED  = [227, 6, 19];
    const DARK = [29, 29, 31];
    const MID  = [100, 100, 100];
    const LITE = [245, 245, 247];
    const ref  = 'DEV-' + Date.now().toString().slice(-6).toUpperCase();
    const date = new Date().toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
    const serviceLabel = SERVICE_INFO[data.service]?.label ?? data.service;

    // En-tête rouge
    doc.setFillColor(...RED);
    doc.rect(0, 0, W, 40, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(22);
    doc.text('PR Logistics', 18, 18);
    doc.setFontSize(10);
    doc.setFont('helvetica', 'normal');
    doc.text(`Demande de devis — ${serviceLabel}`, 18, 26);
    doc.text(`${date}`, 18, 33);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(11);
    doc.text(ref, W - 18, 24, { align: 'right' });
    doc.setFontSize(8);
    doc.setFont('helvetica', 'normal');
    doc.text('Référence', W - 18, 30, { align: 'right' });

    // Bloc client
    let y = 50;
    doc.setFillColor(...LITE);
    doc.roundedRect(15, y, W - 30, 22, 3, 3, 'F');
    doc.setTextColor(...DARK);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(8);
    doc.text('CLIENT', 22, y + 7);
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(10);
    doc.text(data.nom, 22, y + 14);
    doc.setTextColor(...MID);
    doc.setFontSize(9);
    doc.text([data.email, data.telephone].filter(Boolean).join('   ·   '), 22, y + 20);

    y += 32;

    // ── Sections selon le service ─────────────────────────────
    function sectionTitle(title) {
      doc.setFillColor(...RED);
      doc.rect(15, y - 1, 2, 7, 'F');
      doc.setTextColor(...DARK);
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(9);
      doc.text(title, 20, y + 5);
      y += 12;
    }

    if (data.service === 'transport' || data.service === 'traction') {
      sectionTitle(data.service === 'traction' ? 'ITINÉRAIRE DE TRACTION' : 'TRANSPORT');
      const colW = (W - 46) / 2;
      // Départ
      doc.setFillColor(...LITE);
      doc.roundedRect(15, y, colW, 24, 3, 3, 'F');
      doc.setTextColor(...RED);
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(7.5);
      doc.text(data.service === 'traction' ? 'ENLÈVEMENT' : 'DÉPART', 22, y + 7);
      doc.setTextColor(...DARK);
      doc.setFontSize(10);
      doc.text(data.depart_ville, 22, y + 14);
      doc.setTextColor(...MID);
      doc.setFontSize(8.5);
      doc.setFont('helvetica', 'normal');
      doc.text(deptLabel(data.depart_dept), 22, y + 20);
      // Flèche
      const cx = W / 2;
      doc.setDrawColor(...RED);
      doc.setLineWidth(0.6);
      doc.line(15 + colW + 2, y + 12, cx + 5, y + 12);
      doc.setFillColor(...RED);
      doc.triangle(cx + 6, y + 10, cx + 6, y + 14, cx + 10, y + 12, 'F');
      // Arrivée
      doc.setFillColor(...LITE);
      doc.roundedRect(W - 15 - colW, y, colW, 24, 3, 3, 'F');
      doc.setTextColor(...RED);
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(7.5);
      doc.text('LIVRAISON', W - 15 - colW + 7, y + 7);
      doc.setTextColor(...DARK);
      doc.setFontSize(10);
      doc.text(data.arrivee_ville, W - 15 - colW + 7, y + 14);
      doc.setTextColor(...MID);
      doc.setFontSize(8.5);
      doc.setFont('helvetica', 'normal');
      doc.text(deptLabel(data.arrivee_dept), W - 15 - colW + 7, y + 20);
      y += 34;

      if (data.service === 'traction' && data.trac_vehicule) {
        sectionTitle('DÉTAILS TRACTION');
        doc.setFontSize(9);
        doc.setTextColor(...DARK);
        doc.text(`Véhicule : ${data.trac_vehicule}`, 22, y);
        y += 6;
        if (data.trac_poids) doc.text(`Poids : ${data.trac_poids} ${data.trac_poids_unite}`, 22, y), y += 6;
        if (data.trac_date)  doc.text(`Date : ${data.trac_date}`, 22, y), y += 6;
        y += 4;
      }
    }

    if (data.service === 'stockage') {
      sectionTitle('SITE DE STOCKAGE');
      doc.setFontSize(9);
      doc.setTextColor(...DARK);
      doc.setFont('helvetica', 'normal');
      const site = data.stock_ville ? `${data.stock_ville} (${deptLabel(data.stock_dept)})` : 'Port du Havre — 76700 Rogerville (entrepôt PR Logistics)';
      doc.text(site, 22, y);
      y += 14;
      sectionTitle('CONDITIONS DE STOCKAGE');
      if (data.stock_poids) { doc.text(`Poids estimé : ${data.stock_poids} ${data.stock_poids_unite}`, 22, y); y += 6; }
      if (data.stock_duree) { doc.text(`Durée : ${data.stock_duree}`, 22, y); y += 6; }
      if (data.stock_date_entree) { doc.text(`Entrée : ${data.stock_date_entree}`, 22, y); y += 6; }
      if (data.stock_date_sortie) { doc.text(`Sortie estimée : ${data.stock_date_sortie}`, 22, y); y += 6; }
      if (data.stock_conditions?.length) { doc.text(`Conditions : ${data.stock_conditions.join(', ')}`, 22, y); y += 6; }
      y += 6;
    }

    if (data.service === 'depotage') {
      sectionTitle('DÉTAILS DE L\'OPÉRATION');
      doc.setFontSize(9);
      doc.setTextColor(...DARK);
      doc.setFont('helvetica', 'normal');
      if (data.depot_operation) { doc.text(`Opération : ${data.depot_operation === 'depotage' ? 'Dépotage (Conteneur → Entrepôt)' : 'Empotage (Entrepôt → Conteneur)'}`, 22, y); y += 6; }
      if (data.depot_nb)        { doc.text(`Nombre de conteneurs : ${data.depot_nb}`, 22, y); y += 6; }
      if (data.depot_type_cont) {
        doc.text(`Type de conteneur : ${data.depot_type_cont}`, 22, y); y += 6;
      }
      if (data.depot_date)  { doc.text(`Date souhaitée : ${new Date(data.depot_date).toLocaleDateString('fr-FR')}`, 22, y); y += 6; }
      if (data.depot_port)  { doc.text(`Port / Terminal : ${data.depot_port}`, 22, y); y += 6; }
      if (data.depot_poids) { doc.text(`Poids estimé : ${data.depot_poids} ${data.depot_poids_unite}`, 22, y); y += 6; }
      y += 6;
    }

    // Tableau des lots
    sectionTitle('MARCHANDISE');
    doc.setFillColor(...RED);
    doc.roundedRect(15, y, W - 30, 8, 2, 2, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(8);
    doc.setFont('helvetica', 'bold');
    doc.text('Lot', 22, y + 5.5);
    doc.text('Palettes', 42, y + 5.5);
    doc.text('Format', 72, y + 5.5);
    doc.text('Type', 105, y + 5.5);
    doc.text('Contenu', 145, y + 5.5);
    y += 8;
    let totalPalettes = 0;
    data.lots.forEach((lot, i) => {
      doc.setFillColor(...(i % 2 === 0 ? [255,255,255] : LITE));
      doc.rect(15, y, W - 30, 9, 'F');
      doc.setTextColor(...DARK);
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(9);
      doc.text(String(i + 1), 22, y + 6);
      doc.text(lot.palettes, 42, y + 6);
      doc.text(lot.taille, 72, y + 6);
      doc.text(lot.type, 105, y + 6);
      const c = doc.splitTextToSize(lot.contenu, 45);
      doc.text(c[0] + (c.length > 1 ? '…' : ''), 145, y + 6);
      totalPalettes += parseInt(lot.palettes) || 0;
      y += 9;
    });
    doc.setFillColor(...LITE);
    doc.rect(15, y, W - 30, 8, 'F');
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(9);
    doc.setTextColor(...RED);
    doc.text('TOTAL', 22, y + 5.5);
    doc.setTextColor(...DARK);
    doc.text(String(totalPalettes) + ' palette(s)', 42, y + 5.5);
    y += 14;

    if (data.message) {
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(8.5);
      doc.setTextColor(...MID);
      doc.text('INFORMATIONS COMPLÉMENTAIRES', 15, y);
      y += 5;
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(9);
      doc.setTextColor(...DARK);
      const lines = doc.splitTextToSize(data.message, W - 30);
      doc.text(lines, 15, y);
    }

    // Pied de page
    doc.setDrawColor(220, 220, 220);
    doc.setLineWidth(0.4);
    doc.line(15, 280, W - 15, 280);
    doc.setTextColor(...MID);
    doc.setFontSize(8);
    doc.setFont('helvetica', 'normal');
    doc.text('PR Logistics  ·  PLPN 1 – Port 4935, 76700 Rogerville', W / 2, 285, { align: 'center' });
    doc.text('02.32.72.48.03  ·  lehavre@pr-logistics.fr', W / 2, 290, { align: 'center' });

    return doc;
  }

  // ── Envoi serveur ─────────────────────────────────────────────
  async function sendToServer(data, pdfBase64) {
    try {
      const res = await fetch('/send-devis.php', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ ...data, pdf_base64: pdfBase64 }),
      });
      return await res.json();
    } catch (err) {
      return { success: false, error: err.message };
    }
  }

  // ── Initialisation ────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    // Charger jsPDF
    const s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
    document.head.appendChild(s);

    // Cacher la section formulaire au départ
    const devisSection = document.getElementById('devisSection');
    devisSection.style.display = 'none';

    // Clics sur les cartes de service
    document.querySelectorAll('.service-card').forEach(card => {
      card.addEventListener('click', () => selectService(card.dataset.service));
      card.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectService(card.dataset.service); }
      });
    });

    // Bouton retour
    document.getElementById('btnRetour')?.addEventListener('click', resetToSelection);

    // Initialiser un premier lot
    addLot();
    document.getElementById('addLotBtn')?.addEventListener('click', addLot);

    // Soumission du formulaire
    const form    = document.getElementById('devisForm');
    const success = document.getElementById('formSuccess');
    const btn     = document.getElementById('submitBtn');
    const label   = document.getElementById('submitLabel');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const invalids = form.querySelectorAll(':invalid');
      if (invalids.length) {
        invalids.forEach(el => el.classList.add('input--error'));
        invalids[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      btn.disabled = true;
      label.textContent = 'Génération du PDF…';

      const fd = new FormData(form);
      const data = {
        service:       currentService,
        nom:           fd.get('nom'),
        email:         fd.get('email'),
        telephone:     fd.get('telephone'),
        message:       fd.get('message'),
        lots:          collectLots(),
        // Transport & traction
        depart_ville:  fd.get('depart_ville')  || '',
        depart_dept:   fd.get('depart_dept')   || '',
        arrivee_ville: fd.get('arrivee_ville') || '',
        arrivee_dept:  fd.get('arrivee_dept')  || '',
        // Traction
        trac_vehicule:     fd.get('trac_vehicule')     || '',
        trac_poids:        fd.get('trac_poids')        || '',
        trac_poids_unite:  fd.get('trac_poids_unite')  || 't',
        trac_date:         fd.get('trac_date')         || '',
        // Stockage
        stock_ville:        fd.get('stock_ville')       || '',
        stock_dept:         fd.get('stock_dept')        || '',
        stock_poids:        fd.get('stock_poids')       || '',
        stock_poids_unite:  fd.get('stock_poids_unite') || 't',
        stock_duree:        fd.get('stock_duree')       || '',
        stock_date_entree:  fd.get('stock_date_entree') || '',
        stock_date_sortie:  fd.get('stock_date_sortie') || '',
        stock_conditions:   ['froid','dangereux','alcool','bio','racks','securite']
                              .filter(c => fd.get(`cond_${c}`) === '1'),
        // Dépotage
        depot_operation:    fd.get('depot_operation')    || '',
        depot_nb:           fd.get('depot_nb')           || '',
        depot_type_cont:    fd.get('depot_type_cont')    || '',
        depot_date:         fd.get('depot_date')         || '',
        depot_port:         fd.get('depot_port')         || '',
        depot_poids:        fd.get('depot_poids')        || '',
        depot_poids_unite:  fd.get('depot_poids_unite')  || 't',
      };

      // Attendre jsPDF
      let tries = 0;
      while (!window.jspdf && tries++ < 20) await new Promise(r => setTimeout(r, 200));

      // Générer PDF en base64
      const pdf = generatePDF(data);
      let pdfBase64 = null;
      if (pdf) pdfBase64 = pdf.output('datauristring').split(',')[1];

      // Envoyer au serveur
      label.textContent = 'Envoi des emails…';
      const result = await sendToServer(data, pdfBase64);

      if (!result.success) {
        btn.disabled = false;
        label.textContent = 'Envoyer ma demande';
        const errMsg = document.getElementById('sendError');
        if (errMsg) {
          errMsg.hidden = false;
          const detail = result.details1 || result.details2 || result.error || 'Erreur inconnue';
          errMsg.textContent = "Erreur : " + detail;
        }
        console.error('[Devis] Erreur serveur :', result);
        return;
      }

      // PDF envoyé par mail uniquement — pas de téléchargement direct

      // Afficher la confirmation
      form.style.transition = 'opacity 0.4s';
      form.style.opacity = '0';
      setTimeout(() => { form.hidden = true; success.hidden = false; }, 380);
    });

    form?.addEventListener('input', e => {
      e.target.classList.remove('input--error');
    });
  });
</script>

