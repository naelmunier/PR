---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  rawTitle?: boolean;
  canonicalPath?: string;
}

const SITE_URL = 'https://prlogistics.fr';

const {
  title,
  description = 'PR Logistics – Prestataire logistique et transport au Havre. Dépotage, empotage, stockage, traction et transport de palettes. Entrepôt de 8 000 m² au Port du Havre.',
  rawTitle = false,
  canonicalPath = '/',
} = Astro.props;

const fullTitle    = rawTitle ? title : `${title} | PR Logistics – Le Havre`;
const canonicalUrl = `${SITE_URL}${canonicalPath}`;

// Données structurées JSON-LD (entreprise locale)
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "PR Logistics",
  "description": "Prestataire logistique et transport au port du Havre. Dépotage, empotage, stockage, traction et livraison de palettes.",
  "url": SITE_URL,
  "logo": `${SITE_URL}/assets/logo.jpeg`,
  "image": `${SITE_URL}/assets/home/port-havre-2.jpg`,
  "telephone": "+33232724803",
  "email": "lehavre@pr-logistics.fr",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "PLPN 1 – Port 4935",
    "addressLocality": "Rogerville",
    "postalCode": "76700",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 49.4936,
    "longitude": 0.1969
  },
  "areaServed": "France",
  "openingHours": "Mo-Fr 08:00-18:00",
  "sameAs": [],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Services logistiques",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Dépotage et empotage de conteneurs" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Stockage et entreposage" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Traction portuaire" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Transport et livraison de palettes" } }
    ]
  }
};
