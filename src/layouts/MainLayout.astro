        function applyTranslations(lang) {
          var t = T[lang] || T.en;
          document.querySelectorAll('[data-i18n]').forEach(function(el) {
            var k = el.getAttribute('data-i18n');
            if (t[k] !== undefined) el.textContent = t[k];
          });
          document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
            var k = el.getAttribute('data-i18n-html');
            if (t[k] !== undefined) el.innerHTML = t[k];
          });
          document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
            var k = el.getAttribute('data-i18n-placeholder');
            if (t[k] !== undefined) el.setAttribute('placeholder', t[k]);
          });
          document.documentElement.lang = lang;
          document.querySelectorAll('[data-lang-btn]').forEach(function(btn) {
            btn.classList.toggle('lang-active', btn.getAttribute('data-lang-btn') === lang);
          });
          // Mettre à jour l'affichage du sélecteur (drapeau + code)
          var flagEl = document.getElementById('langFlag');
          var codeEl = document.getElementById('langCode');
          if (flagEl) { flagEl.src = lang === 'fr' ? '/assets/home/france.png' : '/assets/home/english.png'; flagEl.alt = lang === 'fr' ? 'FR' : 'EN'; }
          if (codeEl) codeEl.textContent = lang === 'fr' ? 'FR' : 'EN';
          // Fermer la dropdown si ouverte
          var dd = document.getElementById('langDropdown');
          var tr = document.getElementById('langTrigger');
          if (dd) dd.classList.remove('open');
          if (tr) tr.setAttribute('aria-expanded', 'false');
          window.__lang = lang;
          // Notifier les composants qui ont des textes dynamiques
          document.dispatchEvent(new CustomEvent('i18n:changed', { detail: { lang: lang } }));
        }

        function detectLanguage() {
          var saved = localStorage.getItem('pr-lang');
          if (saved === 'fr' || saved === 'en') return saved;
          var bl = (navigator.language || '').toLowerCase();
          return bl.startsWith('fr') ? 'fr' : 'en';
        }

        window.I18N = {
          t: function(key) {
            var lang = window.__lang || 'en';
            var t = T[lang] || T.en;
            return t[key] !== undefined ? t[key] : (T.en[key] || key);
          },
          set: function(lang) {
            localStorage.setItem('pr-lang', lang);
            applyTranslations(lang);
          },
          apply: applyTranslations,
          detect: detectLanguage
        };

        window.__lang = detectLanguage();

        document.addEventListener('DOMContentLoaded', function() {
          applyTranslations(window.__lang);
        });
      })();
    </script>
  </head>
  <body>
    <Header />
    <main style="padding-top: 84px;">
      <slot />
    </main>
    <Footer />

    <script>
      // Animation reveal au scroll
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
