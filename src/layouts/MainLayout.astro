---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  rawTitle?: boolean;
  canonicalPath?: string;
}

const SITE_URL = 'https://prlogistics.fr';

const {
  title,
  description = 'PR Logistics – Prestataire logistique et transport au Havre. Dépotage, empotage, stockage, traction et transport de palettes. Entrepôt de 8 000 m² au Port du Havre.',
  rawTitle = false,
  canonicalPath = '/',
} = Astro.props;

const fullTitle    = rawTitle ? title : `${title} | PR Logistics – Le Havre`;
const canonicalUrl = `${SITE_URL}${canonicalPath}`;

// Données structurées JSON-LD (entreprise locale)
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "PR Logistics",
  "description": "Prestataire logistique et transport au port du Havre. Dépotage, empotage, stockage, traction et livraison de palettes.",
  "url": SITE_URL,
  "logo": `${SITE_URL}/assets/logo.jpeg`,
  "image": `${SITE_URL}/assets/home/port-havre-2.jpg`,
  "telephone": "+33232724803",
  "email": "lehavre@pr-logistics.fr",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "PLPN 1 – Port 4935",
    "addressLocality": "Rogerville",
    "postalCode": "76700",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 49.4936,
    "longitude": 0.1969
  },
  "areaServed": "France",
  "openingHours": "Mo-Fr 08:00-18:00",
  "sameAs": [],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Services logistiques",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Dépotage et empotage de conteneurs" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Stockage et entreposage" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Traction portuaire" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Transport et livraison de palettes" } }
    ]
  }
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO principal -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph (partage réseaux sociaux + aperçu Google) -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="PR Logistics" />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:image"       content={`${SITE_URL}/assets/home/port-havre-2.jpg`} />
    <meta property="og:locale"      content="fr_FR" />

    <!-- Données structurées pour Google (entreprise locale) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" type="image/jpeg" href="/assets/logo.jpeg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main style="padding-top: 84px;">
      <slot />
    </main>
    <Footer />

    <script>
      // Animation reveal au scroll
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
